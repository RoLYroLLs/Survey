{
  "ConnectionStrings": {
    "Default": "Data Source=Data/survey-development.db"
  },
  "Database": {
    "Provider": "Sqlite"
  },
  "App": {
    "PublicOrigin": "https://localhost:7150"
  },
  "BackgroundJobs": {
    "Enabled": true,
    "DashboardPath": "/admin/hangfire",
    "WorkerCount": 1,
    "PollingIntervalMilliseconds": 750,
    "DefaultQueueName": "default",
    "SetupQueueName": "setup",
    "EmailQueueName": "email"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
