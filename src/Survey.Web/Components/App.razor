@using Microsoft.AspNetCore.Components
@inject ISurveyExperienceService ExperienceService

<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<base href="/" />
	<ResourcePreloader />
	<link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
	<link rel="stylesheet" href="@Assets["app.css"]" />
	<link rel="stylesheet" href="@Assets["Survey.Web.styles.css"]" />
	<style>@((MarkupString)_themeCssVariables)</style>
	<ImportMap />
	<link rel="icon" type="image/png" href="favicon.png" />
	<HeadOutlet @rendermode="@PageRenderMode" />
</head>

<body>
	<Routes @rendermode="@PageRenderMode" />
	<ReconnectModal />
	<script src="@Assets["js/secretInput.js"]"></script>
	<script src="@Assets["js/searchableSelect.js"]"></script>
	<script src="@Assets["js/topbarMenus.js"]"></script>
	<script src="@Assets["_framework/blazor.web.js"]"></script>
	<script src="@Assets["Components/Account/Shared/PasskeySubmit.razor.js"]" type="module"></script>
</body>

</html>

@code {
	[CascadingParameter]
	private HttpContext HttpContext { get; set; } = default!;

	private string _themeCssVariables = SiteThemePresetCatalog.BuildCssVariablesBlock(null);

	private IComponentRenderMode? PageRenderMode
		=> HttpContext.AcceptsInteractiveRouting() ? InteractiveServer : null;

	protected override async Task OnParametersSetAsync()
	{
		var appearance = await ExperienceService.GetSiteAppearanceAsync(HttpContext.RequestAborted);
		_themeCssVariables = appearance.CssVariablesBlock;
	}
}
