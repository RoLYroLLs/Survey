@page "/app/sections/new"
@page "/app/sections/{Id:int}"
@page "/app/sections/{Id:int}/{Mode}"
@attribute [TenantAuthorize]
@inject ITenantAdministrationService AdministrationService
@inject ITenantPermissionEvaluator TenantPermissionEvaluator
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>@GetPageTitle()</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Survey Section</p>
			<h1>@GetPageTitle()</h1>
			<p>View or update this survey section.</p>
		</div>
	</div>

	<div class="form-card narrow-card">
		@if (_model.IsLocked)
		{
			<div class="inline-banner mb-3">This section belongs to a locked survey version.</div>
		}

		@if (!string.IsNullOrWhiteSpace(_errorMessage))
		{
			<div class="inline-banner inline-banner--danger mb-3">@_errorMessage</div>
		}

		@if (_model.IsLocked && !Id.HasValue)
		{
			<div class="form-footer">
				<button class="btn btn-outline-primary" type="button" @onclick="Cancel">Cancel</button>
			</div>
		}
		else if (IsViewMode)
		{
			<div class="page-stack">
				<div class="assignment-detail-list">
					<div class="assignment-detail-row">
						<strong>Survey Version</strong>
						<span>@GetSelectedOptionLabel(_model.SurveyVersionOptions, _model.SurveyVersionId)</span>
					</div>
					<div class="assignment-detail-row">
						<strong>Title</strong>
						<span>@DisplayOrDash(_model.Title)</span>
					</div>
					<div class="assignment-detail-row">
						<strong>Description</strong>
						<span>@DisplayOrDash(_model.Description)</span>
					</div>
					<div class="assignment-detail-row">
						<strong>Sort Order</strong>
						<span>@_model.SortOrder</span>
					</div>
					<div class="assignment-detail-row">
						<strong>Locked</strong>
						<span>@(_model.IsLocked ? "Yes" : "No")</span>
					</div>
				</div>

				<div class="form-footer">
					<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.SurveysEdit)">
						<Authorized>
							<a class="btn btn-primary" href="@GetSectionEditUrl(Id!.Value)">Edit Section</a>
						</Authorized>
					</AuthorizeView>
					<a class="btn btn-outline-primary" href="@GetQuestionsUrl(_model.Id ?? 0, _model.SurveyVersionId, _model.SurveyDefinitionId)">Questions</a>
					<a class="btn btn-outline-primary" href="@GetSectionsUrl()">Back to Sections</a>
				</div>
			</div>
		}
		else
		{
			<EditForm Model="_model" OnValidSubmit="SaveAsync">
				<DataAnnotationsValidator />
				<div class="form-grid form-grid--single">
					<div class="field-stack">
						<FieldLabel Text="Survey Version" Required />
						<SearchableSelect class="form-select"
										  @bind-Value="_model.SurveyVersionId"
										  Options="_model.SurveyVersionOptions"
										  Disabled="@_model.Id.HasValue" />
					</div>
					<div class="field-stack">
						<FieldLabel Text="Title" Required />
						<InputText class="form-control" @bind-Value="_model.Title" disabled="@_model.IsLocked" />
						<ValidationMessage For="@(() => _model.Title)" />
					</div>
					<div class="field-stack">
						<label>Description</label>
						<InputTextArea class="form-control" rows="4" @bind-Value="_model.Description" disabled="@_model.IsLocked" />
					</div>
					<div class="field-stack">
						<label>Sort Order</label>
						<InputNumber class="form-control" @bind-Value="_model.SortOrder" disabled="@_model.IsLocked" />
						<ValidationMessage For="@(() => _model.SortOrder)" />
					</div>
				</div>

				<div class="form-footer">
					<button class="btn btn-primary" type="submit" disabled="@_model.IsLocked">Save Section</button>
					<button class="btn btn-outline-primary" type="button" @onclick="Cancel">Cancel</button>
				</div>
			</EditForm>
		}
	</div>
</div>

@code {
	[Parameter]
	public int? Id { get; set; }

	[Parameter]
	public string? Mode { get; set; }

	[SupplyParameterFromQuery]
	public int? SurveyVersionId { get; set; }

	[SupplyParameterFromQuery]
	public int? SurveyDefinitionId { get; set; }

	private SurveySectionEditModel _model = new();
	private string? _errorMessage;
	private bool IsEditMode => string.Equals(Mode, "edit", StringComparison.OrdinalIgnoreCase);
	private bool IsViewMode => Id.HasValue && !IsEditMode;

	protected override async Task OnParametersSetAsync()
	{
		if (!await EnsurePageAccessAsync())
		{
			return;
		}

		_model = await AdministrationService.GetSurveySectionAsync(Id, SurveyVersionId);
		_errorMessage = null;
	}

	private async Task SaveAsync()
	{
		try
		{
			var savedId = await AdministrationService.SaveSurveySectionAsync(_model);
			_errorMessage = null;
			ToastService.ShowSuccess("Section saved successfully.", "Saved");
			NavigationManager.NavigateTo(GetSectionViewUrl(savedId));
		}
		catch (Exception ex)
		{
			_errorMessage = null;
			ToastService.ShowError(ex.Message, "Save failed");
		}
	}

	private string GetSectionsUrl()
	{
		var surveyVersionId = _model.SurveyVersionId > 0 ? _model.SurveyVersionId : SurveyVersionId ?? 0;
		var surveyDefinitionId = _model.SurveyDefinitionId > 0 ? _model.SurveyDefinitionId : SurveyDefinitionId ?? 0;
		return surveyDefinitionId > 0
			? $"/app/sections?surveyVersionId={surveyVersionId}&surveyDefinitionId={surveyDefinitionId}"
			: $"/app/sections?surveyVersionId={surveyVersionId}";
	}

	private string GetQuestionsUrl(int surveySectionId, int surveyVersionId, int surveyDefinitionId)
	{
		return surveyDefinitionId > 0
			? $"/app/questions?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&surveyDefinitionId={surveyDefinitionId}"
			: $"/app/questions?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}";
	}

	private string GetSectionEditUrl(int sectionId)
	{
		var surveyVersionId = _model.SurveyVersionId > 0 ? _model.SurveyVersionId : SurveyVersionId ?? 0;
		var surveyDefinitionId = _model.SurveyDefinitionId > 0 ? _model.SurveyDefinitionId : SurveyDefinitionId ?? 0;
		return surveyDefinitionId > 0
			? $"/app/sections/{sectionId}/edit?surveyVersionId={surveyVersionId}&surveyDefinitionId={surveyDefinitionId}"
			: $"/app/sections/{sectionId}/edit?surveyVersionId={surveyVersionId}";
	}

	private string GetSectionViewUrl(int sectionId)
	{
		var surveyVersionId = _model.SurveyVersionId > 0 ? _model.SurveyVersionId : SurveyVersionId ?? 0;
		var surveyDefinitionId = _model.SurveyDefinitionId > 0 ? _model.SurveyDefinitionId : SurveyDefinitionId ?? 0;
		return surveyDefinitionId > 0
			? $"/app/sections/{sectionId}?surveyVersionId={surveyVersionId}&surveyDefinitionId={surveyDefinitionId}"
			: $"/app/sections/{sectionId}?surveyVersionId={surveyVersionId}";
	}

	private string GetCancelUrl()
	{
		return Id.HasValue ? GetSectionViewUrl(Id.Value) : GetSectionsUrl();
	}

	private void Cancel()
	{
		NavigationManager.NavigateTo(GetCancelUrl());
	}

	private string GetPageTitle()
	{
		if (IsViewMode)
		{
			return "Section";
		}

		return Id.HasValue ? "Edit Section" : "New Section";
	}

	private static string DisplayOrDash(string? value)
	{
		return string.IsNullOrWhiteSpace(value) ? "-" : value;
	}

	private static string GetSelectedOptionLabel(IEnumerable<SelectOption> options, int value)
	{
		return options.FirstOrDefault(option => option.Value == value.ToString())?.Label ?? "-";
	}

	private async Task<bool> EnsurePageAccessAsync()
	{
		var permissionKey = IsViewMode
			? TenantPermissionKeys.SurveysView
			: Id.HasValue
				? TenantPermissionKeys.SurveysEdit
				: TenantPermissionKeys.SurveysCreate;
		if (await TenantPermissionEvaluator.HasPermissionAsync(permissionKey))
		{
			return true;
		}

		NavigationManager.NavigateTo("/Account/AccessDenied", true);
		return false;
	}
}
