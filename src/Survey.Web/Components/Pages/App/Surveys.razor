@page "/app/surveys"
@attribute [TenantAuthorize(TenantPermissionKeys.SurveysView)]
@inject ITenantAdministrationService AdministrationService
@inject NavigationManager NavigationManager

<PageTitle>Surveys</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Survey Definitions</p>
			<h1>@(ShowArchived ? "Archived Surveys" : "Surveys")</h1>
			<p>@(ShowArchived
				? "Archived surveys stay available for reference and can be restored when needed."
				: "Each survey can have multiple immutable versions once assignments begin.")</p>
		</div>
		<div class="toolbar">
			<a class="btn btn-outline-primary" href="@GetActiveUrl()">Active Surveys</a>
			<a class="btn btn-outline-primary" href="@GetArchivedUrl()">Archived Surveys</a>
			@if (!ShowArchived)
			{
				<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.SurveysCreate)">
					<Authorized>
						<a class="btn btn-primary" href="app/surveys/new">Add Survey</a>
					</Authorized>
				</AuthorizeView>
			}
		</div>
	</div>

	<div class="list-card">
		@if (_items.Count == 0)
		{
			<p class="empty-state">No surveys have been created yet.</p>
		}
		else
		{
			<table class="admin-table">
				<thead>
					<tr>
						<th><SortableHeader Label="Name" SortKey="name" CurrentSort="@Sort" Href="@GetSortUrl("name")" /></th>
						<th><SortableHeader Label="Description" SortKey="description" CurrentSort="@Sort" Href="@GetSortUrl("description")" /></th>
						<th><SortableHeader Label="Versions" SortKey="versions" CurrentSort="@Sort" Href="@GetSortUrl("versions")" /></th>
						<th><SortableHeader Label="Archived" SortKey="archived" CurrentSort="@Sort" Href="@GetSortUrl("archived")" /></th>
						<th><SortableHeader Label="Updated" SortKey="updated" CurrentSort="@Sort" Href="@GetSortUrl("updated")" /></th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in _items)
					{
						<tr>
							<td>@item.Name</td>
							<td>@item.Description</td>
							<td>@item.VersionCount</td>
							<td>@(item.IsArchived ? "Yes" : "No")</td>
							<td>@item.UpdatedUtc.LocalDateTime.ToString("g")</td>
							<td>
								<div class="table-actions">
									<a class="btn btn-sm btn-outline-primary" href="@($"app/surveys/{item.Id}?showArchived={ShowArchived.ToString().ToLowerInvariant()}")">View</a>
									<a class="btn btn-sm btn-outline-primary" href="@($"app/versions?surveyDefinitionId={item.Id}&showArchived={ShowArchived.ToString().ToLowerInvariant()}")">Versions</a>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}

		<ListPager ShownCount="_items.Count"
				   TotalCount="_totalCount"
				   PageSize="_pageSize"
				   HasMore="_hasMore"
				   IsLoadingMore="_isLoadingMore"
				   PageSizeOptions="ListPagingDefaults.PageSizeOptions"
				   PageSizeChanged="OnPageSizeChangedAsync"
				   OnLoadMore="LoadMoreAsync" />
	</div>
</div>

@code {
	[SupplyParameterFromQuery]
	public bool ShowArchived { get; set; }

	[SupplyParameterFromQuery(Name = "pageSize")]
	public int? PageSize { get; set; }

	[SupplyParameterFromQuery(Name = "sort")]
	public string? Sort { get; set; }

	private IReadOnlyList<SurveyDefinitionListItem> _items = Array.Empty<SurveyDefinitionListItem>();
	private int _pageSize = PagedQuery.DefaultLimit;
	private int _totalCount;
	private bool _hasMore;
	private bool _isLoadingMore;

	protected override async Task OnParametersSetAsync()
	{
		_pageSize = ListPagingDefaults.NormalizePageSize(PageSize);
		await LoadAsync();
	}

	private async Task LoadAsync(bool append = false)
	{
		var result = await AdministrationService.GetSurveyDefinitionsAsync(
			ListPagingDefaults.CreateRequest(_pageSize, append ? _items.Count : 0, Sort),
			ShowArchived);
		_items = append ? _items.Concat(result.Items).ToArray() : result.Items;
		_totalCount = result.TotalCount;
		_hasMore = result.HasMore;
	}

	private async Task LoadMoreAsync()
	{
		_isLoadingMore = true;
		try
		{
			await LoadAsync(append: true);
		}
		finally
		{
			_isLoadingMore = false;
		}
	}

	private Task OnPageSizeChangedAsync(int pageSize)
	{
		NavigationManager.NavigateTo(BuildUrl(ShowArchived, pageSize, Sort));
		return Task.CompletedTask;
	}

	private string GetActiveUrl()
	{
		return BuildUrl(false, _pageSize, Sort);
	}

	private string GetArchivedUrl()
	{
		return BuildUrl(true, _pageSize, Sort);
	}

	private string GetSortUrl(string key)
	{
		return BuildUrl(ShowArchived, _pageSize, PagingSort.Toggle(Sort, key));
	}

	private static string BuildUrl(bool showArchived, int pageSize, string? sort)
	{
		var queryParts = new List<string>
		{
			$"pageSize={pageSize}"
		};
		if (showArchived)
		{
			queryParts.Add("showArchived=true");
		}
		if (!string.IsNullOrWhiteSpace(sort))
		{
			queryParts.Add($"sort={Uri.EscapeDataString(sort)}");
		}

		return $"/app/surveys?{string.Join("&", queryParts)}";
	}
}
