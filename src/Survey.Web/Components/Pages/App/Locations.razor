@page "/app/people/{PersonId:int}/locations"
@attribute [TenantAuthorize(TenantPermissionKeys.LocationsView)]
@inject ITenantAdministrationService AdministrationService
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>Locations</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Recipient Locations</p>
			<h1>Locations</h1>
			<p>View the locations saved for this person.</p>
		</div>
		<div class="toolbar">
			<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.LocationsCreate)">
				<Authorized>
					<a class="btn btn-primary" href="/app/people/@PersonId/locations/new">Add Location</a>
				</Authorized>
			</AuthorizeView>
			<a class="btn btn-outline-primary" href="/app/people/@PersonId">Back to Person</a>
		</div>
	</div>

	<div class="list-card">
		@if (_items.Count == 0)
		{
			<p class="empty-state">No locations have been added for this person yet.</p>
		}
		else
		{
			<table class="admin-table">
				<thead>
					<tr>
						<th><SortableHeader Label="Nickname" SortKey="nickname" CurrentSort="@Sort" Href="@GetSortUrl("nickname")" /></th>
						<th><SortableHeader Label="ZIP" SortKey="zip" CurrentSort="@Sort" Href="@GetSortUrl("zip")" /></th>
						<th><SortableHeader Label="Email" SortKey="email" CurrentSort="@Sort" Href="@GetSortUrl("email")" /></th>
						<th><SortableHeader Label="Phone" SortKey="phone" CurrentSort="@Sort" Href="@GetSortUrl("phone")" /></th>
						<th><SortableHeader Label="Assignments" SortKey="assignments" CurrentSort="@Sort" Href="@GetSortUrl("assignments")" /></th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in _items)
					{
						<tr>
							<td>@item.Nickname</td>
							<td>@item.PostalCode</td>
							<td>@item.Email</td>
							<td>@item.PhoneNumber</td>
							<td>@item.AssignmentCount</td>
							<td>
								<div class="table-actions">
									<a class="btn btn-sm btn-outline-primary" href="/app/people/@PersonId/locations/@item.Id">View</a>
									<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.LocationsDelete)">
										<Authorized>
											@if (item.AssignmentCount == 0)
											{
												<button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => RemoveLocationAsync(item.Id)">Remove</button>
											}
											else
											{
												<button class="btn btn-sm btn-muted-disabled" type="button" disabled>Remove</button>
											}
										</Authorized>
									</AuthorizeView>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}

		<ListPager ShownCount="_items.Count"
				   TotalCount="_totalCount"
				   PageSize="_pageSize"
				   HasMore="_hasMore"
				   IsLoadingMore="_isLoadingMore"
				   PageSizeOptions="ListPagingDefaults.PageSizeOptions"
				   PageSizeChanged="OnPageSizeChangedAsync"
				   OnLoadMore="LoadMoreAsync" />
	</div>
</div>

@code {
	[Parameter]
	public int PersonId { get; set; }

	[SupplyParameterFromQuery(Name = "pageSize")]
	public int? PageSize { get; set; }

	[SupplyParameterFromQuery(Name = "sort")]
	public string? Sort { get; set; }

	private IReadOnlyList<LocationListItem> _items = Array.Empty<LocationListItem>();
	private int _pageSize = PagedQuery.DefaultLimit;
	private int _totalCount;
	private bool _hasMore;
	private bool _isLoadingMore;

	protected override async Task OnParametersSetAsync()
	{
		_pageSize = ListPagingDefaults.NormalizePageSize(PageSize);
		await LoadAsync();
	}

	private async Task RemoveLocationAsync(int locationId)
	{
		try
		{
			await AdministrationService.DeleteLocationAsync(locationId);
			await LoadAsync();
			ToastService.ShowSuccess("Location removed successfully.", "Removed");
		}
		catch (Exception ex)
		{
			ToastService.ShowError(ex.Message, "Remove failed");
		}
	}

	private async Task LoadAsync(bool append = false)
	{
		var result = await AdministrationService.GetLocationsAsync(
			ListPagingDefaults.CreateRequest(_pageSize, append ? _items.Count : 0, Sort),
			PersonId);
		_items = append ? _items.Concat(result.Items).ToArray() : result.Items;
		_totalCount = result.TotalCount;
		_hasMore = result.HasMore;
	}

	private async Task LoadMoreAsync()
	{
		_isLoadingMore = true;
		try
		{
			await LoadAsync(append: true);
		}
		finally
		{
			_isLoadingMore = false;
		}
	}

	private Task OnPageSizeChangedAsync(int pageSize)
	{
		NavigationManager.NavigateTo(BuildUrl(pageSize, Sort));
		return Task.CompletedTask;
	}

	private string GetSortUrl(string key)
	{
		return BuildUrl(_pageSize, PagingSort.Toggle(Sort, key));
	}

	private string BuildUrl(int pageSize, string? sort)
	{
		var queryParts = new List<string>
		{
			$"pageSize={pageSize}"
		};
		if (!string.IsNullOrWhiteSpace(sort))
		{
			queryParts.Add($"sort={Uri.EscapeDataString(sort)}");
		}

		return $"/app/people/{PersonId}/locations?{string.Join("&", queryParts)}";
	}
}
