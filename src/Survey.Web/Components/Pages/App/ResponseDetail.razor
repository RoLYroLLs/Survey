@page "/app/responses/{Id:int}"
@attribute [TenantAuthorize(TenantPermissionKeys.ResponsesView)]
@inject ITenantAdministrationService AdministrationService

<PageTitle>Response</PageTitle>

@if (_item is null)
{
	<div class="status-card narrow-card">
		<p class="eyebrow">Response</p>
		<h1>That response couldn't be found.</h1>
		<p class="mb-0">It may have been removed or the link may be invalid.</p>
	</div>
}
else
{
	<div class="page-stack">
		<div class="page-header">
			<div>
				<p class="eyebrow">Response</p>
				<h1>Response</h1>
				<p>@_item.RespondentName | @_item.SurveyName | @_item.VersionName | @_item.PersonName | @_item.LocationName</p>
			</div>
			<div class="toolbar">
				<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.PeopleEdit)">
					<Authorized>
						<a class="btn btn-outline-primary" href="/app/people/@_item.PersonId/edit">Edit Person</a>
					</Authorized>
				</AuthorizeView>
				<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.LocationsEdit)">
					<Authorized>
						<a class="btn btn-outline-primary" href="/app/people/@_item.PersonId/locations/@_item.LocationId/edit">Edit Location</a>
					</Authorized>
				</AuthorizeView>
				@if (_item.RespondentPostalAddressId.HasValue)
				{
					<AuthorizeView Policy="@SurveyAuthorizationPolicies.PlatformPermission(PlatformPermissionKeys.GeographyManage)">
						<Authorized>
							<a class="btn btn-outline-primary" href="/admin/addresses/@_item.RespondentPostalAddressId.Value/edit">Edit Shared Address</a>
						</Authorized>
					</AuthorizeView>
				}
				<a class="btn btn-outline-primary" href="/app/responses">Back to Responses</a>
			</div>
		</div>

		<div class="card-grid">
			<section class="content-card">
				<h2>Contact Snapshot</h2>
				<p class="mb-1"><strong>Physical Address:</strong> @_item.HomeAddress</p>
				<p class="mb-1"><strong>Mailing Address:</strong> @_item.MailingAddress</p>
				<p class="mb-1"><strong>Postal Code:</strong> @_item.PostalCode</p>
				<p class="mb-1"><strong>County:</strong> @_item.CountyName</p>
				<p class="mb-1"><strong>Phone:</strong> @(string.IsNullOrWhiteSpace(_item.PhoneLabel) ? _item.PhoneNumber : $"{_item.PhoneLabel}: {_item.PhoneNumber}")</p>
				<p class="mb-1"><strong>Best Time:</strong> @_item.BestTimeToContact</p>
				<p class="mb-1"><strong>Preferred Method:</strong> @_item.PreferredContactMethod</p>
				<p class="mb-0"><strong>Email:</strong> @(string.IsNullOrWhiteSpace(_item.EmailLabel) ? _item.Email : $"{_item.EmailLabel}: {_item.Email}")</p>
			</section>
			<section class="content-card">
				<h2>Audit</h2>
				<p class="mb-1"><strong>Submitted By:</strong> @_item.SubmittedByLabel</p>
				<p class="mb-0"><strong>Submitted:</strong> @_item.SubmittedUtc.LocalDateTime.ToString("f")</p>
			</section>
		</div>

		<div class="list-card">
			<h2>Answers</h2>
			<table class="admin-table">
				<thead>
					<tr>
						<th>Question</th>
						<th>Answer</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var answer in _item.Answers)
					{
						<tr>
							<td>@answer.Question</td>
							<td>@answer.Answer</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	</div>
}

@code {
	[Parameter]
	public int Id { get; set; }

	private SurveyResponseDetailModel? _item;

	protected override async Task OnParametersSetAsync()
	{
		_item = await AdministrationService.GetResponseAsync(Id);
	}
}
