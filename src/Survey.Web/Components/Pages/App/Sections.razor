@page "/app/sections"
@attribute [TenantAuthorize(TenantPermissionKeys.SurveysView)]
@inject ITenantAdministrationService AdministrationService
@inject NavigationManager NavigationManager

<PageTitle>Sections</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Section Builder</p>
			<h1>Sections</h1>
			<p>View the sections in the selected survey version.</p>
		</div>
		<div class="toolbar">
			@if (SurveyDefinitionId.HasValue)
			{
				<a class="btn btn-outline-primary" href="@($"app/versions?surveyDefinitionId={SurveyDefinitionId.Value}&pageSize={_pageSize}")">Back to Versions</a>
			}
			<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.SurveysCreate)">
				<Authorized>
					<a class="btn btn-primary" href="@GetAddUrl()">Add Section</a>
				</Authorized>
			</AuthorizeView>
		</div>
	</div>

	@if (!SurveyVersionId.HasValue)
	{
		<div class="inline-banner">Choose a survey version before managing sections.</div>
	}
	else
	{
		<div class="list-card">
			@if (_items.Count == 0)
			{
				<p class="empty-state">No sections exist for this version yet.</p>
			}
			else
			{
				<table class="admin-table">
					<thead>
						<tr>
							<th><SortableHeader Label="Title" SortKey="title" CurrentSort="@Sort" Href="@GetSortUrl("title")" /></th>
							<th><SortableHeader Label="Order" SortKey="order" CurrentSort="@Sort" Href="@GetSortUrl("order")" /></th>
							<th><SortableHeader Label="Questions" SortKey="questions" CurrentSort="@Sort" Href="@GetSortUrl("questions")" /></th>
							<th><SortableHeader Label="Locked" SortKey="locked" CurrentSort="@Sort" Href="@GetSortUrl("locked")" /></th>
							<th></th>
						</tr>
					</thead>
					<tbody>
						@foreach (var item in _items)
						{
							<tr>
								<td>@item.Title</td>
								<td>@item.SortOrder</td>
								<td>@item.QuestionCount</td>
								<td>@(item.IsLocked ? "Yes" : "No")</td>
								<td>
									<div class="table-actions">
										<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.SurveysEdit)">
											<Authorized>
												<a class="btn btn-sm btn-outline-primary" href="@GetEditUrl(item.Id)">Edit</a>
											</Authorized>
										</AuthorizeView>
										<a class="btn btn-sm btn-outline-primary" href="@GetQuestionsUrl(item.Id)">Questions</a>
									</div>
								</td>
							</tr>
						}
					</tbody>
				</table>
			}

			<ListPager ShownCount="_items.Count"
					   TotalCount="_totalCount"
					   PageSize="_pageSize"
					   HasMore="_hasMore"
					   IsLoadingMore="_isLoadingMore"
					   PageSizeOptions="ListPagingDefaults.PageSizeOptions"
					   PageSizeChanged="OnPageSizeChangedAsync"
					   OnLoadMore="LoadMoreAsync" />
		</div>
	}
</div>

@code {
	[SupplyParameterFromQuery]
	public int? SurveyVersionId { get; set; }

	[SupplyParameterFromQuery]
	public int? SurveyDefinitionId { get; set; }

	[SupplyParameterFromQuery(Name = "pageSize")]
	public int? PageSize { get; set; }

	[SupplyParameterFromQuery(Name = "sort")]
	public string? Sort { get; set; }

	private IReadOnlyList<SurveySectionListItem> _items = Array.Empty<SurveySectionListItem>();
	private int _pageSize = PagedQuery.DefaultLimit;
	private int _totalCount;
	private bool _hasMore;
	private bool _isLoadingMore;

	protected override async Task OnParametersSetAsync()
	{
		_pageSize = ListPagingDefaults.NormalizePageSize(PageSize);
		if (!SurveyVersionId.HasValue)
		{
			_items = Array.Empty<SurveySectionListItem>();
			_totalCount = 0;
			_hasMore = false;
			return;
		}

		var result = await AdministrationService.GetSurveySectionsAsync(ListPagingDefaults.CreateRequest(_pageSize, 0, Sort), SurveyVersionId.Value);
		_items = result.Items;
		_totalCount = result.TotalCount;
		_hasMore = result.HasMore;
	}

	private string GetAddUrl()
	{
		var surveyVersionId = SurveyVersionId ?? 0;
		return SurveyDefinitionId.HasValue
			? $"app/sections/new?surveyVersionId={surveyVersionId}&surveyDefinitionId={SurveyDefinitionId.Value}&pageSize={_pageSize}"
			: $"app/sections/new?surveyVersionId={surveyVersionId}&pageSize={_pageSize}";
	}

	private string GetQuestionsUrl(int surveySectionId)
	{
		var surveyVersionId = SurveyVersionId ?? 0;
		return SurveyDefinitionId.HasValue
			? $"app/questions?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&surveyDefinitionId={SurveyDefinitionId.Value}&pageSize={_pageSize}"
			: $"app/questions?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&pageSize={_pageSize}";
	}

	private string GetEditUrl(int sectionId)
	{
		var surveyVersionId = SurveyVersionId ?? 0;
		return SurveyDefinitionId.HasValue
			? $"app/sections/{sectionId}/edit?surveyVersionId={surveyVersionId}&surveyDefinitionId={SurveyDefinitionId.Value}&pageSize={_pageSize}"
			: $"app/sections/{sectionId}/edit?surveyVersionId={surveyVersionId}&pageSize={_pageSize}";
	}

	private async Task LoadMoreAsync()
	{
		if (!SurveyVersionId.HasValue)
		{
			return;
		}

		_isLoadingMore = true;
		try
		{
			var result = await AdministrationService.GetSurveySectionsAsync(
				ListPagingDefaults.CreateRequest(_pageSize, _items.Count, Sort),
				SurveyVersionId.Value);
			_items = _items.Concat(result.Items).ToArray();
			_totalCount = result.TotalCount;
			_hasMore = result.HasMore;
		}
		finally
		{
			_isLoadingMore = false;
		}
	}

	private Task OnPageSizeChangedAsync(int pageSize)
	{
		NavigationManager.NavigateTo(BuildUrl(pageSize, Sort));
		return Task.CompletedTask;
	}

	private string GetSortUrl(string key)
	{
		return BuildUrl(_pageSize, PagingSort.Toggle(Sort, key));
	}

	private string BuildUrl(int pageSize, string? sort)
	{
		var queryParts = new List<string>
		{
			$"surveyVersionId={SurveyVersionId ?? 0}",
			$"pageSize={pageSize}"
		};
		if (SurveyDefinitionId.HasValue)
		{
			queryParts.Add($"surveyDefinitionId={SurveyDefinitionId.Value}");
		}
		if (!string.IsNullOrWhiteSpace(sort))
		{
			queryParts.Add($"sort={Uri.EscapeDataString(sort)}");
		}

		return $"/app/sections?{string.Join("&", queryParts)}";
	}
}
