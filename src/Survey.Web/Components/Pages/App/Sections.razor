@page "/app/sections"
@attribute [TenantAuthorize(TenantPermissionKeys.SurveysView)]
@inject ITenantAdministrationService AdministrationService
@inject ITenantPermissionEvaluator TenantPermissionEvaluator
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>Sections</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Section Builder</p>
			<h1>Sections</h1>
			<p>View the sections in the selected survey version and drag them into the right order.</p>
		</div>
		<div class="toolbar">
			@if (SurveyDefinitionId.HasValue)
			{
				<a class="btn btn-outline-primary" href="@($"/app/versions?surveyDefinitionId={SurveyDefinitionId.Value}&pageSize={_pageSize}")">Back to Versions</a>
			}
			<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.SurveysCreate)">
				<Authorized>
					<a class="btn btn-primary" href="@GetAddUrl()">Add Section</a>
				</Authorized>
			</AuthorizeView>
		</div>
	</div>

	@if (!SurveyVersionId.HasValue)
	{
		<div class="inline-banner">Choose a survey version before managing sections.</div>
	}
	else
	{
		@if (!string.IsNullOrWhiteSpace(_reorderErrorMessage))
		{
			<div class="inline-banner inline-banner--danger">@_reorderErrorMessage</div>
		}

		@if (_canReorder)
		{
			<div class="inline-banner">Drag a row by its handle to reorder sections. Changes save automatically when you drop.</div>
		}

		<div class="list-card">
			@if (!_hasLoadedInitialState)
			{
				<p class="empty-state">Loading...</p>
			}
			else if (_items.Count == 0)
			{
				<p class="empty-state">No sections exist for this version yet.</p>
			}
			else
			{
				<table class="admin-table admin-table--reorderable">
					<thead>
						<tr>
							<th class="admin-table__drag-column"></th>
							<th>Title</th>
							<th>Order</th>
							<th>Questions</th>
							<th>Locked</th>
							<th></th>
						</tr>
					</thead>
					<tbody>
						@foreach (var item in _items)
						{
							<tr class="@GetRowClass(item.Id)"
								@ondragenter="@(() => SetDropTarget(item.Id))"
								@ondragover:preventDefault="true"
								@ondrop="@(() => DropAsync(item.Id))"
								@ondragend="ClearDragState">
								<td class="admin-table__drag-column">
									@if (CanDragRow(item))
									{
										<button class="reorder-handle"
												type="button"
												draggable="true"
												title="Drag to reorder section"
												aria-label="Drag to reorder section"
												@ondragstart="@(args => BeginDrag(args, item.Id))"
												@ondragend="ClearDragState">
											<span aria-hidden="true">::</span>
										</button>
									}
								</td>
								<td>@item.Title</td>
								<td>@item.SortOrder</td>
								<td>@item.QuestionCount</td>
								<td>@(item.IsLocked ? "Yes" : "No")</td>
								<td>
									<div class="table-actions">
										<a class="btn btn-sm btn-outline-primary" href="@GetViewUrl(item.Id)">View</a>
										<a class="btn btn-sm btn-outline-primary" href="@GetQuestionsUrl(item.Id)">Questions</a>
									</div>
								</td>
							</tr>
						}
					</tbody>
				</table>
			}
		</div>
	}
</div>

@code {
	[SupplyParameterFromQuery]
	public int? SurveyVersionId { get; set; }

	[SupplyParameterFromQuery]
	public int? SurveyDefinitionId { get; set; }

	private IReadOnlyList<SurveySectionListItem> _items = Array.Empty<SurveySectionListItem>();
	private int _pageSize = PagedQuery.MaxLimit;
	private int _totalCount;
	private bool _canReorder;
	private bool _isSavingOrder;
	private bool _hasLoadedInitialState;
	private int? _draggedSectionId;
	private int? _dropTargetSectionId;
	private string? _reorderErrorMessage;

	protected override async Task OnParametersSetAsync()
	{
		if (!SurveyVersionId.HasValue)
		{
			_items = Array.Empty<SurveySectionListItem>();
			_totalCount = 0;
			_canReorder = false;
			_hasLoadedInitialState = true;
			return;
		}

		_hasLoadedInitialState = false;
		try
		{
			var result = await AdministrationService.GetSurveySectionsAsync(new PagedQuery
			{
				Limit = PagedQuery.MaxLimit
			}, SurveyVersionId.Value);
			_items = result.Items;
			_totalCount = result.TotalCount;
			_canReorder = await TenantPermissionEvaluator.HasPermissionAsync(TenantPermissionKeys.SurveysEdit)
				&& _items.Count == _totalCount
				&& _items.Count > 1
				&& !_items.Any(item => item.IsLocked);
			_reorderErrorMessage = null;
		}
		finally
		{
			_hasLoadedInitialState = true;
		}
	}

	private string GetAddUrl()
	{
		var surveyVersionId = SurveyVersionId ?? 0;
		return SurveyDefinitionId.HasValue
			? $"/app/sections/new?surveyVersionId={surveyVersionId}&surveyDefinitionId={SurveyDefinitionId.Value}&pageSize={_pageSize}"
			: $"/app/sections/new?surveyVersionId={surveyVersionId}&pageSize={_pageSize}";
	}

	private string GetQuestionsUrl(int surveySectionId)
	{
		var surveyVersionId = SurveyVersionId ?? 0;
		return SurveyDefinitionId.HasValue
			? $"/app/questions?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&surveyDefinitionId={SurveyDefinitionId.Value}&pageSize={_pageSize}"
			: $"/app/questions?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&pageSize={_pageSize}";
	}

	private string GetViewUrl(int sectionId)
	{
		var surveyVersionId = SurveyVersionId ?? 0;
		return SurveyDefinitionId.HasValue
			? $"/app/sections/{sectionId}?surveyVersionId={surveyVersionId}&surveyDefinitionId={SurveyDefinitionId.Value}&pageSize={_pageSize}"
			: $"/app/sections/{sectionId}?surveyVersionId={surveyVersionId}&pageSize={_pageSize}";
	}

	private bool CanDragRow(SurveySectionListItem item)
	{
		return _canReorder && !_isSavingOrder && !item.IsLocked;
	}

	private void BeginDrag(DragEventArgs args, int sectionId)
	{
		if (!_canReorder || _isSavingOrder)
		{
			return;
		}

		if (args.DataTransfer is not null)
		{
			args.DataTransfer.DropEffect = "move";
			args.DataTransfer.EffectAllowed = "move";
		}

		_draggedSectionId = sectionId;
		_dropTargetSectionId = sectionId;
		_reorderErrorMessage = null;
	}

	private void SetDropTarget(int sectionId)
	{
		if (_draggedSectionId.HasValue && _draggedSectionId.Value != sectionId)
		{
			_dropTargetSectionId = sectionId;
		}
	}

	private async Task DropAsync(int sectionId)
	{
		if (!_draggedSectionId.HasValue || !SurveyVersionId.HasValue || _isSavingOrder)
		{
			return;
		}

		var sourceId = _draggedSectionId.Value;
		ClearDragState();
		if (sourceId == sectionId)
		{
			return;
		}

		var reorderedItems = ReorderItems(sourceId, sectionId);
		if (reorderedItems is null)
		{
			return;
		}

		var originalItems = _items.Select(CloneItem).ToArray();
		_items = reorderedItems.Select(CloneItem).ToArray();
		_isSavingOrder = true;
		_reorderErrorMessage = null;

		try
		{
			await AdministrationService.ReorderSurveySectionsAsync(SurveyVersionId.Value, reorderedItems.Select(item => item.Id).ToArray());
			ToastService.ShowSuccess("Section order updated.", "Saved");
		}
		catch (Exception ex)
		{
			_items = originalItems;
			_reorderErrorMessage = ex.Message;
			ToastService.ShowError(ex.Message, "Reorder failed");
		}
		finally
		{
			_isSavingOrder = false;
		}
	}

	private List<SurveySectionListItem>? ReorderItems(int sourceId, int targetId)
	{
		var reorderedItems = _items.Select(CloneItem).ToList();
		var sourceIndex = reorderedItems.FindIndex(item => item.Id == sourceId);
		var targetIndex = reorderedItems.FindIndex(item => item.Id == targetId);
		if (sourceIndex < 0 || targetIndex < 0)
		{
			return null;
		}

		var sourceItem = reorderedItems[sourceIndex];
		reorderedItems.RemoveAt(sourceIndex);
		if (sourceIndex > targetIndex)
		{
			reorderedItems.Insert(targetIndex, sourceItem);
		}
		else
		{
			reorderedItems.Insert(targetIndex, sourceItem);
		}

		for (var index = 0; index < reorderedItems.Count; index++)
		{
			reorderedItems[index].SortOrder = index + 1;
		}

		return reorderedItems;
	}

	private string GetRowClass(int sectionId)
	{
		var classes = new List<string>();
		if (_draggedSectionId == sectionId)
		{
			classes.Add("admin-table__row--dragging");
		}

		if (_dropTargetSectionId == sectionId)
		{
			classes.Add("admin-table__row--drop-target");
		}

		if (_isSavingOrder)
		{
			classes.Add("admin-table__row--saving");
		}

		return string.Join(" ", classes);
	}

	private void ClearDragState()
	{
		_draggedSectionId = null;
		_dropTargetSectionId = null;
	}

	private static SurveySectionListItem CloneItem(SurveySectionListItem item)
	{
		return new SurveySectionListItem
		{
			Id = item.Id,
			SurveyDefinitionId = item.SurveyDefinitionId,
			SurveyVersionId = item.SurveyVersionId,
			VersionName = item.VersionName,
			Title = item.Title,
			SortOrder = item.SortOrder,
			QuestionCount = item.QuestionCount,
			IsLocked = item.IsLocked
		};
	}
}
