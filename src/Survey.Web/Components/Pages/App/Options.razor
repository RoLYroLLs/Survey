@page "/app/options"
@attribute [TenantAuthorize(TenantPermissionKeys.SurveysView)]
@inject ITenantAdministrationService AdministrationService
@inject NavigationManager NavigationManager

<PageTitle>Options</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Question Options</p>
			<h1>Options</h1>
			<p>@GetHeaderDescription()</p>
		</div>
		<div class="toolbar">
			<a class="btn btn-outline-primary" href="@GetQuestionsUrl()">Back to Questions</a>
			@if (_context.SurveyQuestionId > 0)
			{
				<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.SurveysEdit)">
					<Authorized>
						<a class="btn btn-outline-primary" href="@GetQuestionEditUrl()">Edit Question</a>
					</Authorized>
				</AuthorizeView>
			}
			@if (CanAddOptions())
			{
				<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.SurveysCreate)">
					<Authorized>
						<a class="btn btn-primary" href="@GetAddUrl()">Add Option</a>
					</Authorized>
				</AuthorizeView>
			}
		</div>
	</div>

	@if (!SurveyQuestionId.HasValue)
	{
		<div class="inline-banner">Choose a question before managing options.</div>
	}
	else if (!_context.SupportsOptions)
	{
		<div class="inline-banner">Options are only available for single-choice and multi-select questions.</div>
	}
	else
	{
		<div class="list-card">
			@if (_items.Count == 0)
			{
				<p class="empty-state">No options exist for this question yet.</p>
			}
			else
			{
				<table class="admin-table">
					<thead>
						<tr>
							<th><SortableHeader Label="Label" SortKey="label" CurrentSort="@Sort" Href="@GetSortUrl("label")" /></th>
							<th><SortableHeader Label="Order" SortKey="order" CurrentSort="@Sort" Href="@GetSortUrl("order")" /></th>
							<th><SortableHeader Label="Locked" SortKey="locked" CurrentSort="@Sort" Href="@GetSortUrl("locked")" /></th>
							<th></th>
						</tr>
					</thead>
					<tbody>
						@foreach (var item in _items)
						{
							<tr>
								<td>@item.Label</td>
								<td>@item.SortOrder</td>
								<td>@(item.IsLocked ? "Yes" : "No")</td>
								<td>
									<div class="table-actions">
										<a class="btn btn-sm btn-outline-primary" href="@GetViewUrl(item.Id)">View</a>
									</div>
								</td>
							</tr>
						}
					</tbody>
				</table>
			}

			<ListPager ShownCount="_items.Count"
					   TotalCount="_totalCount"
					   PageSize="_pageSize"
					   HasMore="_hasMore"
					   IsLoadingMore="_isLoadingMore"
					   PageSizeOptions="ListPagingDefaults.PageSizeOptions"
					   PageSizeChanged="OnPageSizeChangedAsync"
					   OnLoadMore="LoadMoreAsync" />
		</div>
	}
</div>

@code {
	[SupplyParameterFromQuery]
	public int? SurveyQuestionId { get; set; }

	[SupplyParameterFromQuery]
	public int? SurveySectionId { get; set; }

	[SupplyParameterFromQuery]
	public int? SurveyVersionId { get; set; }

	[SupplyParameterFromQuery]
	public int? SurveyDefinitionId { get; set; }

	[SupplyParameterFromQuery(Name = "pageSize")]
	public int? PageSize { get; set; }

	[SupplyParameterFromQuery(Name = "sort")]
	public string? Sort { get; set; }

	private IReadOnlyList<QuestionOptionListItem> _items = Array.Empty<QuestionOptionListItem>();
	private QuestionOptionEditModel _context = new();
	private int _pageSize = PagedQuery.DefaultLimit;
	private int _totalCount;
	private bool _hasMore;
	private bool _isLoadingMore;

	protected override async Task OnParametersSetAsync()
	{
		_pageSize = ListPagingDefaults.NormalizePageSize(PageSize);
		if (!SurveyQuestionId.HasValue)
		{
			_context = new();
			_items = Array.Empty<QuestionOptionListItem>();
			_totalCount = 0;
			_hasMore = false;
			return;
		}

		_context = await AdministrationService.GetQuestionOptionAsync(null, SurveyQuestionId.Value);
		if (_context.SupportsOptions)
		{
			var result = await AdministrationService.GetQuestionOptionsAsync(ListPagingDefaults.CreateRequest(_pageSize, 0, Sort), SurveyQuestionId.Value);
			_items = result.Items;
			_totalCount = result.TotalCount;
			_hasMore = result.HasMore;
		}
		else
		{
			_items = Array.Empty<QuestionOptionListItem>();
			_totalCount = 0;
			_hasMore = false;
		}
		SurveySectionId ??= _context.SurveySectionId;
		SurveyVersionId ??= _context.SurveyVersionId;
		SurveyDefinitionId ??= _context.SurveyDefinitionId;
	}

	private bool CanAddOptions()
	{
		return _context.SurveyQuestionId > 0 && _context.SupportsOptions && !_context.IsLocked;
	}

	private string GetHeaderDescription()
	{
		if (string.IsNullOrWhiteSpace(_context.QuestionPrompt))
		{
			return "View the options for the selected question.";
		}

		return $"View the answer choices for '{_context.QuestionPrompt}'.";
	}

	private string GetAddUrl()
	{
		var surveyQuestionId = SurveyQuestionId ?? 0;
		return GetOptionsEditorUrl($"/app/options/new?surveyQuestionId={surveyQuestionId}");
	}

	private string GetViewUrl(int optionId)
	{
		return GetOptionsEditorUrl($"/app/options/{optionId}");
	}

	private string GetQuestionsUrl()
	{
		var surveySectionId = SurveySectionId ?? _context.SurveySectionId;
		var surveyVersionId = SurveyVersionId ?? _context.SurveyVersionId;
		var surveyDefinitionId = SurveyDefinitionId ?? _context.SurveyDefinitionId;
		return surveyDefinitionId > 0
			? $"/app/questions?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&surveyDefinitionId={surveyDefinitionId}&pageSize={_pageSize}"
			: $"/app/questions?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&pageSize={_pageSize}";
	}

	private string GetQuestionEditUrl()
	{
		var surveyQuestionId = SurveyQuestionId ?? _context.SurveyQuestionId;
		var surveyVersionId = SurveyVersionId ?? _context.SurveyVersionId;
		var surveyDefinitionId = SurveyDefinitionId ?? _context.SurveyDefinitionId;
		var surveySectionId = SurveySectionId ?? _context.SurveySectionId;
		return surveyDefinitionId > 0
			? $"/app/questions/{surveyQuestionId}/edit?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&surveyDefinitionId={surveyDefinitionId}&pageSize={_pageSize}"
			: $"/app/questions/{surveyQuestionId}/edit?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&pageSize={_pageSize}";
	}

	private string GetOptionsEditorUrl(string baseUrl)
	{
		var surveySectionId = SurveySectionId ?? _context.SurveySectionId;
		var surveyVersionId = SurveyVersionId ?? _context.SurveyVersionId;
		var surveyDefinitionId = SurveyDefinitionId ?? _context.SurveyDefinitionId;
		return surveyDefinitionId > 0
			? $"{baseUrl}&surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&surveyDefinitionId={surveyDefinitionId}&pageSize={_pageSize}"
			: $"{baseUrl}&surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&pageSize={_pageSize}";
	}

	private async Task LoadMoreAsync()
	{
		if (!_context.SupportsOptions || !SurveyQuestionId.HasValue)
		{
			return;
		}

		_isLoadingMore = true;
		try
		{
			var result = await AdministrationService.GetQuestionOptionsAsync(
				ListPagingDefaults.CreateRequest(_pageSize, _items.Count, Sort),
				SurveyQuestionId.Value);
			_items = _items.Concat(result.Items).ToArray();
			_totalCount = result.TotalCount;
			_hasMore = result.HasMore;
		}
		finally
		{
			_isLoadingMore = false;
		}
	}

	private Task OnPageSizeChangedAsync(int pageSize)
	{
		NavigationManager.NavigateTo(BuildUrl(pageSize, Sort));
		return Task.CompletedTask;
	}

	private string GetSortUrl(string key)
	{
		return BuildUrl(_pageSize, PagingSort.Toggle(Sort, key));
	}

	private string BuildUrl(int pageSize, string? sort)
	{
		var queryParts = new List<string>
		{
			$"surveyQuestionId={SurveyQuestionId ?? 0}",
			$"pageSize={pageSize}"
		};
		if (SurveySectionId.HasValue)
		{
			queryParts.Add($"surveySectionId={SurveySectionId.Value}");
		}
		if (SurveyVersionId.HasValue)
		{
			queryParts.Add($"surveyVersionId={SurveyVersionId.Value}");
		}
		if (SurveyDefinitionId.HasValue)
		{
			queryParts.Add($"surveyDefinitionId={SurveyDefinitionId.Value}");
		}
		if (!string.IsNullOrWhiteSpace(sort))
		{
			queryParts.Add($"sort={Uri.EscapeDataString(sort)}");
		}

		return $"/app/options?{string.Join("&", queryParts)}";
	}
}
