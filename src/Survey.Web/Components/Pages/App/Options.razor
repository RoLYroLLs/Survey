@page "/app/options"
@attribute [TenantAuthorize(TenantPermissionKeys.SurveysView)]
@inject ITenantAdministrationService AdministrationService
@inject ITenantPermissionEvaluator TenantPermissionEvaluator
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>Options</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Question Options</p>
			<h1>Options</h1>
			<p>@GetHeaderDescription()</p>
		</div>
		<div class="toolbar">
			<a class="btn btn-outline-primary" href="@GetQuestionsUrl()">Back to Questions</a>
			@if (_context.SurveyQuestionId > 0)
			{
				<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.SurveysEdit)">
					<Authorized>
						<a class="btn btn-outline-primary" href="@GetQuestionEditUrl()">Edit Question</a>
					</Authorized>
				</AuthorizeView>
			}
			@if (CanAddOptions())
			{
				<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.SurveysCreate)">
					<Authorized>
						<a class="btn btn-primary" href="@GetAddUrl()">Add Option</a>
					</Authorized>
				</AuthorizeView>
			}
		</div>
	</div>

	@if (!SurveyQuestionId.HasValue)
	{
		<div class="inline-banner">Choose a question before managing options.</div>
	}
	else if (!_context.SupportsOptions)
	{
		<div class="inline-banner">Options are only available for single-choice and multi-select questions.</div>
	}
	else
	{
		@if (!string.IsNullOrWhiteSpace(_reorderErrorMessage))
		{
			<div class="inline-banner inline-banner--danger">@_reorderErrorMessage</div>
		}

		@if (_canReorder)
		{
			<div class="inline-banner">Drag a row by its handle to reorder options. Changes save automatically when you drop.</div>
		}

		<div class="list-card">
			@if (_items.Count == 0)
			{
				<p class="empty-state">No options exist for this question yet.</p>
			}
			else
			{
				<table class="admin-table admin-table--reorderable">
					<thead>
						<tr>
							<th class="admin-table__drag-column"></th>
							<th>Label</th>
							<th>Order</th>
							<th>Locked</th>
							<th></th>
						</tr>
					</thead>
					<tbody>
						@foreach (var item in _items)
						{
							<tr class="@GetRowClass(item.Id)"
								@ondragenter="@(() => SetDropTarget(item.Id))"
								@ondragover:preventDefault="true"
								@ondrop="@(() => DropAsync(item.Id))"
								@ondragend="ClearDragState">
								<td class="admin-table__drag-column">
									@if (CanDragRow(item))
									{
										<button class="reorder-handle"
												type="button"
												draggable="true"
												title="Drag to reorder option"
												aria-label="Drag to reorder option"
												@ondragstart="@(args => BeginDrag(args, item.Id))"
												@ondragend="ClearDragState">
											<span aria-hidden="true">::</span>
										</button>
									}
								</td>
								<td>@item.Label</td>
								<td>@item.SortOrder</td>
								<td>@(item.IsLocked ? "Yes" : "No")</td>
								<td>
									<div class="table-actions">
										<a class="btn btn-sm btn-outline-primary" href="@GetViewUrl(item.Id)">View</a>
									</div>
								</td>
							</tr>
						}
					</tbody>
				</table>
			}

		</div>
	}
</div>

@code {
	[SupplyParameterFromQuery]
	public int? SurveyQuestionId { get; set; }

	[SupplyParameterFromQuery]
	public int? SurveySectionId { get; set; }

	[SupplyParameterFromQuery]
	public int? SurveyVersionId { get; set; }

	[SupplyParameterFromQuery]
	public int? SurveyDefinitionId { get; set; }

	private IReadOnlyList<QuestionOptionListItem> _items = Array.Empty<QuestionOptionListItem>();
	private QuestionOptionEditModel _context = new();
	private int _pageSize = PagedQuery.MaxLimit;
	private int _totalCount;
	private bool _canReorder;
	private bool _isSavingOrder;
	private int? _draggedOptionId;
	private int? _dropTargetOptionId;
	private string? _reorderErrorMessage;

	protected override async Task OnParametersSetAsync()
	{
		if (!SurveyQuestionId.HasValue)
		{
			_context = new();
			_items = Array.Empty<QuestionOptionListItem>();
			_totalCount = 0;
			_canReorder = false;
			return;
		}

		_context = await AdministrationService.GetQuestionOptionAsync(null, SurveyQuestionId.Value);
		if (_context.SupportsOptions)
		{
			var result = await AdministrationService.GetQuestionOptionsAsync(new PagedQuery
			{
				Limit = PagedQuery.MaxLimit
			}, SurveyQuestionId.Value);
			_items = result.Items;
			_totalCount = result.TotalCount;
			_canReorder = await TenantPermissionEvaluator.HasPermissionAsync(TenantPermissionKeys.SurveysEdit)
				&& _items.Count == _totalCount
				&& _items.Count > 1
				&& !_items.Any(item => item.IsLocked);
		}
		else
		{
			_items = Array.Empty<QuestionOptionListItem>();
			_totalCount = 0;
			_canReorder = false;
		}
		SurveySectionId ??= _context.SurveySectionId;
		SurveyVersionId ??= _context.SurveyVersionId;
		SurveyDefinitionId ??= _context.SurveyDefinitionId;
		_reorderErrorMessage = null;
	}

	private bool CanAddOptions()
	{
		return _context.SurveyQuestionId > 0 && _context.SupportsOptions && !_context.IsLocked;
	}

	private string GetHeaderDescription()
	{
		if (string.IsNullOrWhiteSpace(_context.QuestionPrompt))
		{
			return "View the options for the selected question.";
		}

		return $"View the answer choices for '{_context.QuestionPrompt}'.";
	}

	private string GetAddUrl()
	{
		var surveyQuestionId = SurveyQuestionId ?? 0;
		return GetOptionsEditorUrl($"/app/options/new?surveyQuestionId={surveyQuestionId}");
	}

	private string GetViewUrl(int optionId)
	{
		return GetOptionsEditorUrl($"/app/options/{optionId}");
	}

	private string GetQuestionsUrl()
	{
		var surveySectionId = SurveySectionId ?? _context.SurveySectionId;
		var surveyVersionId = SurveyVersionId ?? _context.SurveyVersionId;
		var surveyDefinitionId = SurveyDefinitionId ?? _context.SurveyDefinitionId;
		return surveyDefinitionId > 0
			? $"/app/questions?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&surveyDefinitionId={surveyDefinitionId}&pageSize={_pageSize}"
			: $"/app/questions?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&pageSize={_pageSize}";
	}

	private string GetQuestionEditUrl()
	{
		var surveyQuestionId = SurveyQuestionId ?? _context.SurveyQuestionId;
		var surveyVersionId = SurveyVersionId ?? _context.SurveyVersionId;
		var surveyDefinitionId = SurveyDefinitionId ?? _context.SurveyDefinitionId;
		var surveySectionId = SurveySectionId ?? _context.SurveySectionId;
		return surveyDefinitionId > 0
			? $"/app/questions/{surveyQuestionId}/edit?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&surveyDefinitionId={surveyDefinitionId}&pageSize={_pageSize}"
			: $"/app/questions/{surveyQuestionId}/edit?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&pageSize={_pageSize}";
	}

	private string GetOptionsEditorUrl(string baseUrl)
	{
		var surveySectionId = SurveySectionId ?? _context.SurveySectionId;
		var surveyVersionId = SurveyVersionId ?? _context.SurveyVersionId;
		var surveyDefinitionId = SurveyDefinitionId ?? _context.SurveyDefinitionId;
		return surveyDefinitionId > 0
			? $"{baseUrl}&surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&surveyDefinitionId={surveyDefinitionId}&pageSize={_pageSize}"
			: $"{baseUrl}&surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&pageSize={_pageSize}";
	}

	private bool CanDragRow(QuestionOptionListItem item)
	{
		return _canReorder && !_isSavingOrder && !item.IsLocked;
	}

	private void BeginDrag(DragEventArgs args, int optionId)
	{
		if (!_canReorder || _isSavingOrder)
		{
			return;
		}

		if (args.DataTransfer is not null)
		{
			args.DataTransfer.DropEffect = "move";
			args.DataTransfer.EffectAllowed = "move";
		}

		_draggedOptionId = optionId;
		_dropTargetOptionId = optionId;
		_reorderErrorMessage = null;
	}

	private void SetDropTarget(int optionId)
	{
		if (_draggedOptionId.HasValue && _draggedOptionId.Value != optionId)
		{
			_dropTargetOptionId = optionId;
		}
	}

	private async Task DropAsync(int optionId)
	{
		if (!_draggedOptionId.HasValue || !SurveyQuestionId.HasValue || _isSavingOrder)
		{
			return;
		}

		var sourceId = _draggedOptionId.Value;
		ClearDragState();
		if (sourceId == optionId)
		{
			return;
		}

		var reorderedItems = ReorderItems(sourceId, optionId);
		if (reorderedItems is null)
		{
			return;
		}

		var originalItems = _items.Select(CloneItem).ToArray();
		_items = reorderedItems.Select(CloneItem).ToArray();
		_isSavingOrder = true;
		_reorderErrorMessage = null;

		try
		{
			await AdministrationService.ReorderQuestionOptionsAsync(SurveyQuestionId.Value, reorderedItems.Select(item => item.Id).ToArray());
			ToastService.ShowSuccess("Option order updated.", "Saved");
		}
		catch (Exception ex)
		{
			_items = originalItems;
			_reorderErrorMessage = ex.Message;
			ToastService.ShowError(ex.Message, "Reorder failed");
		}
		finally
		{
			_isSavingOrder = false;
		}
	}

	private List<QuestionOptionListItem>? ReorderItems(int sourceId, int targetId)
	{
		var reorderedItems = _items.Select(CloneItem).ToList();
		var sourceIndex = reorderedItems.FindIndex(item => item.Id == sourceId);
		var targetIndex = reorderedItems.FindIndex(item => item.Id == targetId);
		if (sourceIndex < 0 || targetIndex < 0)
		{
			return null;
		}

		var sourceItem = reorderedItems[sourceIndex];
		reorderedItems.RemoveAt(sourceIndex);
		reorderedItems.Insert(targetIndex, sourceItem);

		for (var index = 0; index < reorderedItems.Count; index++)
		{
			reorderedItems[index].SortOrder = index + 1;
		}

		return reorderedItems;
	}

	private string GetRowClass(int optionId)
	{
		var classes = new List<string>();
		if (_draggedOptionId == optionId)
		{
			classes.Add("admin-table__row--dragging");
		}

		if (_dropTargetOptionId == optionId)
		{
			classes.Add("admin-table__row--drop-target");
		}

		if (_isSavingOrder)
		{
			classes.Add("admin-table__row--saving");
		}

		return string.Join(" ", classes);
	}

	private void ClearDragState()
	{
		_draggedOptionId = null;
		_dropTargetOptionId = null;
	}

	private static QuestionOptionListItem CloneItem(QuestionOptionListItem item)
	{
		return new QuestionOptionListItem
		{
			Id = item.Id,
			SurveyQuestionId = item.SurveyQuestionId,
			QuestionPrompt = item.QuestionPrompt,
			Label = item.Label,
			SortOrder = item.SortOrder,
			IsLocked = item.IsLocked
		};
	}
}
