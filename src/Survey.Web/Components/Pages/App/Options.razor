@page "/app/options"
@attribute [TenantAuthorize(TenantPermissionKeys.SurveysView)]
@inject ITenantAdministrationService AdministrationService

<PageTitle>Options</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Question Options</p>
			<h1>Options</h1>
			<p>@GetHeaderDescription()</p>
		</div>
		<div class="toolbar">
			<a class="btn btn-outline-primary" href="@GetQuestionsUrl()">Back to Questions</a>
			@if (_context.SurveyQuestionId > 0)
			{
				<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.SurveysEdit)">
					<Authorized>
						<a class="btn btn-outline-primary" href="@GetQuestionEditUrl()">Edit Question</a>
					</Authorized>
				</AuthorizeView>
			}
			@if (CanAddOptions())
			{
				<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.SurveysCreate)">
					<Authorized>
						<a class="btn btn-primary" href="@GetAddUrl()">Add Option</a>
					</Authorized>
				</AuthorizeView>
			}
		</div>
	</div>

	@if (!SurveyQuestionId.HasValue)
	{
		<div class="inline-banner">Choose a question before managing options.</div>
	}
	else if (!_context.SupportsOptions)
	{
		<div class="inline-banner">Options are only available for single-choice and multi-select questions.</div>
	}
	else
	{
		<div class="list-card">
			@if (_items.Count == 0)
			{
				<p class="empty-state">No options exist for this question yet.</p>
			}
			else
			{
				<table class="admin-table">
					<thead>
						<tr>
							<th>Label</th>
							<th>Order</th>
							<th>Locked</th>
							<th></th>
						</tr>
					</thead>
					<tbody>
						@foreach (var item in _items)
						{
							<tr>
								<td>@item.Label</td>
								<td>@item.SortOrder</td>
								<td>@(item.IsLocked ? "Yes" : "No")</td>
								<td>
									<div class="table-actions">
										<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.SurveysEdit)">
											<Authorized>
												<a class="btn btn-sm btn-outline-primary" href="@GetEditUrl(item.Id)">Edit</a>
											</Authorized>
										</AuthorizeView>
									</div>
								</td>
							</tr>
						}
					</tbody>
				</table>
			}
		</div>
	}
</div>

@code {
	[SupplyParameterFromQuery]
	public int? SurveyQuestionId { get; set; }

	[SupplyParameterFromQuery]
	public int? SurveySectionId { get; set; }

	[SupplyParameterFromQuery]
	public int? SurveyVersionId { get; set; }

	[SupplyParameterFromQuery]
	public int? SurveyDefinitionId { get; set; }

	private IReadOnlyList<QuestionOptionListItem> _items = Array.Empty<QuestionOptionListItem>();
	private QuestionOptionEditModel _context = new();

	protected override async Task OnParametersSetAsync()
	{
		if (!SurveyQuestionId.HasValue)
		{
			_context = new();
			_items = Array.Empty<QuestionOptionListItem>();
			return;
		}

		_context = await AdministrationService.GetQuestionOptionAsync(null, SurveyQuestionId.Value);
		_items = _context.SupportsOptions
			? await AdministrationService.GetQuestionOptionsAsync(SurveyQuestionId.Value)
			: Array.Empty<QuestionOptionListItem>();
		SurveySectionId ??= _context.SurveySectionId;
		SurveyVersionId ??= _context.SurveyVersionId;
		SurveyDefinitionId ??= _context.SurveyDefinitionId;
	}

	private bool CanAddOptions()
	{
		return _context.SurveyQuestionId > 0 && _context.SupportsOptions && !_context.IsLocked;
	}

	private string GetHeaderDescription()
	{
		if (string.IsNullOrWhiteSpace(_context.QuestionPrompt))
		{
			return "View the options for the selected question.";
		}

		return $"View the answer choices for '{_context.QuestionPrompt}'.";
	}

	private string GetAddUrl()
	{
		var surveyQuestionId = SurveyQuestionId ?? 0;
		return GetOptionsEditorUrl($"app/options/new?surveyQuestionId={surveyQuestionId}");
	}

	private string GetEditUrl(int optionId)
	{
		return GetOptionsEditorUrl($"app/options/{optionId}/edit");
	}

	private string GetQuestionsUrl()
	{
		var surveySectionId = SurveySectionId ?? _context.SurveySectionId;
		var surveyVersionId = SurveyVersionId ?? _context.SurveyVersionId;
		var surveyDefinitionId = SurveyDefinitionId ?? _context.SurveyDefinitionId;
		return surveyDefinitionId > 0
			? $"app/questions?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&surveyDefinitionId={surveyDefinitionId}"
			: $"app/questions?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}";
	}

	private string GetQuestionEditUrl()
	{
		var surveyQuestionId = SurveyQuestionId ?? _context.SurveyQuestionId;
		var surveyVersionId = SurveyVersionId ?? _context.SurveyVersionId;
		var surveyDefinitionId = SurveyDefinitionId ?? _context.SurveyDefinitionId;
		var surveySectionId = SurveySectionId ?? _context.SurveySectionId;
		return surveyDefinitionId > 0
			? $"app/questions/{surveyQuestionId}/edit?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&surveyDefinitionId={surveyDefinitionId}"
			: $"app/questions/{surveyQuestionId}/edit?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}";
	}

	private string GetOptionsEditorUrl(string baseUrl)
	{
		var surveySectionId = SurveySectionId ?? _context.SurveySectionId;
		var surveyVersionId = SurveyVersionId ?? _context.SurveyVersionId;
		var surveyDefinitionId = SurveyDefinitionId ?? _context.SurveyDefinitionId;
		return surveyDefinitionId > 0
			? $"{baseUrl}&surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&surveyDefinitionId={surveyDefinitionId}"
			: $"{baseUrl}&surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}";
	}
}
