@page "/app/areas"
@attribute [TenantAuthorize(TenantPermissionKeys.AreasView)]
@inject ITenantAdministrationService AdministrationService
@inject NavigationManager NavigationManager

<PageTitle>Areas</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Geographic Areas</p>
			<h1>Areas</h1>
			<p>@(string.IsNullOrWhiteSpace(_filterLabel) ? "View the named areas available for reporting and goals." : $"Showing areas that include {_filterLabel}.")</p>
		</div>
		<div class="toolbar">
			@if (CountyId.HasValue)
			{
				<a class="btn btn-outline-primary" href="/app/areas">View All</a>
			}
			<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.AreasCreate)">
				<Authorized>
					<a class="btn btn-primary" href="/app/areas/new">Add Area</a>
				</Authorized>
			</AuthorizeView>
		</div>
	</div>

	<div class="list-card">
		@if (!_hasLoadedInitialState)
		{
			<p class="empty-state">Loading...</p>
		}
		else if (_items.Count == 0)
		{
			<p class="empty-state">No areas have been created yet.</p>
		}
		else
		{
			<table class="admin-table">
				<thead>
					<tr>
						<th><SortableHeader Label="Name" SortKey="name" CurrentSort="@Sort" Href="@GetSortUrl("name")" /></th>
						<th><SortableHeader Label="Description" SortKey="description" CurrentSort="@Sort" Href="@GetSortUrl("description")" /></th>
						<th><SortableHeader Label="Counties" SortKey="counties" CurrentSort="@Sort" Href="@GetSortUrl("counties")" /></th>
						<th><SortableHeader Label="Goals" SortKey="goals" CurrentSort="@Sort" Href="@GetSortUrl("goals")" /></th>
						<th><SortableHeader Label="Updated" SortKey="updated" CurrentSort="@Sort" Href="@GetSortUrl("updated")" /></th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in _items)
					{
						<tr>
							<td>@item.Name</td>
							<td>@item.Description</td>
							<td>@item.CountyCount</td>
							<td>@item.GoalCount</td>
							<td>@item.UpdatedUtc.LocalDateTime.ToString("g")</td>
							<td>
								<div class="table-actions">
									<a class="btn btn-sm btn-outline-primary" href="/app/areas/@item.Id">View</a>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}

		<ListPager ShownCount="_items.Count"
				   TotalCount="_totalCount"
				   PageSize="_pageSize"
				   HasMore="_hasMore"
				   IsLoadingMore="_isLoadingMore"
				   PageSizeOptions="ListPagingDefaults.PageSizeOptions"
				   PageSizeChanged="OnPageSizeChangedAsync"
				   OnLoadMore="LoadMoreAsync" />
	</div>
</div>

@code {
	[SupplyParameterFromQuery]
	public int? CountyId { get; set; }

	[SupplyParameterFromQuery(Name = "pageSize")]
	public int? PageSize { get; set; }

	[SupplyParameterFromQuery(Name = "sort")]
	public string? Sort { get; set; }

	private IReadOnlyList<AreaListItem> _items = Array.Empty<AreaListItem>();
	private string? _filterLabel;
	private int _pageSize = PagedQuery.DefaultLimit;
	private int _totalCount;
	private bool _hasMore;
	private bool _isLoadingMore;
	private bool _hasLoadedInitialState;

	protected override async Task OnParametersSetAsync()
	{
		_pageSize = ListPagingDefaults.NormalizePageSize(PageSize);
		_hasLoadedInitialState = false;
		try
		{
			await LoadAsync();
		}
		finally
		{
			_hasLoadedInitialState = true;
		}
	}

	private async Task LoadAsync(bool append = false)
	{
		var result = await AdministrationService.GetAreasAsync(
			ListPagingDefaults.CreateRequest(_pageSize, append ? _items.Count : 0, Sort),
			CountyId);
		_items = append ? _items.Concat(result.Items).ToArray() : result.Items;
		_totalCount = result.TotalCount;
		_hasMore = result.HasMore;
		_filterLabel = _items.FirstOrDefault()?.CountyNameFilter;
	}

	private async Task LoadMoreAsync()
	{
		_isLoadingMore = true;
		try
		{
			await LoadAsync(append: true);
		}
		finally
		{
			_isLoadingMore = false;
		}
	}

	private Task OnPageSizeChangedAsync(int pageSize)
	{
		NavigationManager.NavigateTo(BuildUrl(CountyId, pageSize, Sort));
		return Task.CompletedTask;
	}

	private string GetSortUrl(string key)
	{
		return BuildUrl(CountyId, _pageSize, PagingSort.Toggle(Sort, key));
	}

	private static string BuildUrl(int? countyId, int pageSize, string? sort)
	{
		var queryParts = new List<string>
		{
			$"pageSize={pageSize}"
		};
		if (countyId.HasValue)
		{
			queryParts.Add($"countyId={countyId.Value}");
		}
		if (!string.IsNullOrWhiteSpace(sort))
		{
			queryParts.Add($"sort={Uri.EscapeDataString(sort)}");
		}

		return $"/app/areas?{string.Join("&", queryParts)}";
	}
}
