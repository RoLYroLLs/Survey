@page "/app/versions"
@attribute [TenantAuthorize(TenantPermissionKeys.SurveysView)]
@inject ITenantAdministrationService AdministrationService
@inject NavigationManager NavigationManager

<PageTitle>Versions</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Version Management</p>
<h1>Versions</h1>
			<p>@(ShowArchived
				? "Archived versions remain available for review and can be restored."
				: "Used versions lock automatically once assignments exist. Clone an existing version to continue editing.")</p>
		</div>
		<div class="toolbar">
			<a class="btn btn-outline-primary" href="@GetActiveUrl()">Active Versions</a>
			<a class="btn btn-outline-primary" href="@GetArchivedUrl()">Archived Versions</a>
			@if (!ShowArchived)
			{
				<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.SurveysCreate)">
					<Authorized>
						<a class="btn btn-primary" href="@GetAddUrl()">Add Version</a>
					</Authorized>
				</AuthorizeView>
			}
		</div>
	</div>

	@if (!string.IsNullOrWhiteSpace(_errorMessage))
	{
		<div class="inline-banner inline-banner--danger">@_errorMessage</div>
	}

	<div class="list-card">
		@if (_items.Count == 0)
		{
			<p class="empty-state">No versions match the current filter.</p>
		}
		else
		{
			<table class="admin-table">
				<thead>
					<tr>
						<th><SortableHeader Label="Survey" SortKey="survey" CurrentSort="@Sort" Href="@GetSortUrl("survey")" /></th>
						<th><SortableHeader Label="Version" SortKey="version" CurrentSort="@Sort" Href="@GetSortUrl("version")" /></th>
						<th><SortableHeader Label="Published" SortKey="published" CurrentSort="@Sort" Href="@GetSortUrl("published")" /></th>
						<th><SortableHeader Label="Archived" SortKey="archived" CurrentSort="@Sort" Href="@GetSortUrl("archived")" /></th>
						<th><SortableHeader Label="Locked" SortKey="locked" CurrentSort="@Sort" Href="@GetSortUrl("locked")" /></th>
						<th><SortableHeader Label="Sections" SortKey="sections" CurrentSort="@Sort" Href="@GetSortUrl("sections")" /></th>
						<th><SortableHeader Label="Assignments" SortKey="assignments" CurrentSort="@Sort" Href="@GetSortUrl("assignments")" /></th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in _items)
					{
						<tr>
							<td>@item.SurveyName</td>
							<td>@item.DisplayName</td>
							<td>@(item.IsPublished ? "Yes" : "No")</td>
							<td>@(item.IsArchived ? "Yes" : "No")</td>
							<td>@(item.IsLocked ? "Yes" : "No")</td>
							<td>@item.SectionCount</td>
							<td>@item.AssignmentCount</td>
							<td>
								<div class="table-actions">
									<a class="btn btn-sm btn-outline-primary" href="@GetViewUrl(item.Id, item.SurveyDefinitionId)">View</a>
									<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.SurveysCreate)">
										<Authorized>
											<button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => CloneAsync(item.Id)">Clone</button>
										</Authorized>
									</AuthorizeView>
									<a class="btn btn-sm btn-outline-primary" href="@($"app/sections?surveyVersionId={item.Id}&surveyDefinitionId={item.SurveyDefinitionId}")">Sections</a>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}

		<ListPager ShownCount="_items.Count"
				   TotalCount="_totalCount"
				   PageSize="_pageSize"
				   HasMore="_hasMore"
				   IsLoadingMore="_isLoadingMore"
				   PageSizeOptions="ListPagingDefaults.PageSizeOptions"
				   PageSizeChanged="OnPageSizeChangedAsync"
				   OnLoadMore="LoadMoreAsync" />
	</div>
</div>

@code {
	[SupplyParameterFromQuery]
	public int? SurveyDefinitionId { get; set; }

	[SupplyParameterFromQuery]
	public bool ShowArchived { get; set; }

	[SupplyParameterFromQuery(Name = "pageSize")]
	public int? PageSize { get; set; }

	[SupplyParameterFromQuery(Name = "sort")]
	public string? Sort { get; set; }

	private IReadOnlyList<SurveyVersionListItem> _items = Array.Empty<SurveyVersionListItem>();
	private string? _errorMessage;
	private int _pageSize = PagedQuery.DefaultLimit;
	private int _totalCount;
	private bool _hasMore;
	private bool _isLoadingMore;

	protected override async Task OnParametersSetAsync()
	{
		_pageSize = ListPagingDefaults.NormalizePageSize(PageSize);
		await LoadAsync();
		_errorMessage = null;
	}

	private string GetAddUrl()
	{
		return SurveyDefinitionId.HasValue
			? $"app/versions/new?surveyDefinitionId={SurveyDefinitionId.Value}&pageSize={_pageSize}"
			: $"app/versions/new?pageSize={_pageSize}";
	}

	private string GetActiveUrl()
	{
		return BuildListUrl(false, _pageSize, Sort);
	}

	private string GetArchivedUrl()
	{
		return BuildListUrl(true, _pageSize, Sort);
	}

	private string GetEditUrl(int versionId, int surveyDefinitionId)
	{
		var archived = ShowArchived.ToString().ToLowerInvariant();
		return $"app/versions/{versionId}/edit?surveyDefinitionId={surveyDefinitionId}&showArchived={archived}";
	}

	private string GetViewUrl(int versionId, int surveyDefinitionId)
	{
		var archived = ShowArchived.ToString().ToLowerInvariant();
		return $"app/versions/{versionId}?surveyDefinitionId={surveyDefinitionId}&showArchived={archived}&pageSize={_pageSize}";
	}

	private async Task CloneAsync(int versionId)
	{
		try
		{
			var newId = await AdministrationService.CloneSurveyVersionAsync(versionId);
			NavigationManager.NavigateTo($"app/versions/{newId}/edit");
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
	}

	private async Task LoadAsync(bool append = false)
	{
		var result = await AdministrationService.GetSurveyVersionsAsync(
			ListPagingDefaults.CreateRequest(_pageSize, append ? _items.Count : 0, Sort),
			SurveyDefinitionId,
			ShowArchived);
		_items = append ? _items.Concat(result.Items).ToArray() : result.Items;
		_totalCount = result.TotalCount;
		_hasMore = result.HasMore;
	}

	private async Task LoadMoreAsync()
	{
		_isLoadingMore = true;
		try
		{
			await LoadAsync(append: true);
		}
		finally
		{
			_isLoadingMore = false;
		}
	}

	private Task OnPageSizeChangedAsync(int pageSize)
	{
		NavigationManager.NavigateTo(BuildListUrl(ShowArchived, pageSize, Sort));
		return Task.CompletedTask;
	}

	private string GetSortUrl(string key)
	{
		return BuildListUrl(ShowArchived, _pageSize, PagingSort.Toggle(Sort, key));
	}

	private string BuildListUrl(bool showArchived, int pageSize, string? sort)
	{
		var queryParts = new List<string>
		{
			$"pageSize={pageSize}"
		};
		if (SurveyDefinitionId.HasValue)
		{
			queryParts.Add($"surveyDefinitionId={SurveyDefinitionId.Value}");
		}
		if (showArchived)
		{
			queryParts.Add("showArchived=true");
		}
		if (!string.IsNullOrWhiteSpace(sort))
		{
			queryParts.Add($"sort={Uri.EscapeDataString(sort)}");
		}

		return $"/app/versions?{string.Join("&", queryParts)}";
	}
}
