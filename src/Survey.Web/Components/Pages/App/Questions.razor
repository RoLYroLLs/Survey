@page "/app/questions"
@attribute [TenantAuthorize(TenantPermissionKeys.SurveysView)]
@inject ITenantAdministrationService AdministrationService
@inject ITenantPermissionEvaluator TenantPermissionEvaluator
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>Questions</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Question Builder</p>
			<h1>Questions</h1>
			<p>View the questions in the selected section and drag them into the right order.</p>
		</div>
		<div class="toolbar">
			<a class="btn btn-outline-primary" href="@GetSectionsUrl()">Back to Sections</a>
			<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.SurveysCreate)">
				<Authorized>
					<a class="btn btn-primary" href="@GetAddUrl()">Add Question</a>
				</Authorized>
			</AuthorizeView>
		</div>
	</div>

	@if (!SurveySectionId.HasValue)
	{
		<div class="inline-banner">Choose a survey section before managing questions.</div>
	}
	else
	{
		@if (!string.IsNullOrWhiteSpace(_reorderErrorMessage))
		{
			<div class="inline-banner inline-banner--danger">@_reorderErrorMessage</div>
		}

		@if (_canReorder)
		{
			<div class="inline-banner">Drag a row by its handle to reorder questions. Changes save automatically when you drop.</div>
		}

		<div class="list-card">
			@if (_items.Count == 0)
			{
				<p class="empty-state">No questions exist for this section yet.</p>
			}
			else
			{
				<table class="admin-table admin-table--reorderable">
					<thead>
						<tr>
							<th class="admin-table__drag-column"></th>
							<th>Prompt</th>
							<th>Type</th>
							<th>Required</th>
							<th>Order</th>
							<th>Options</th>
							<th></th>
						</tr>
					</thead>
					<tbody>
						@foreach (var item in _items)
						{
							<tr class="@GetRowClass(item.Id)"
								@ondragenter="@(() => SetDropTarget(item.Id))"
								@ondragover:preventDefault="true"
								@ondrop="@(() => DropAsync(item.Id))"
								@ondragend="ClearDragState">
								<td class="admin-table__drag-column">
									@if (CanDragRow(item))
									{
										<button class="reorder-handle"
												type="button"
												draggable="true"
												title="Drag to reorder question"
												aria-label="Drag to reorder question"
												@ondragstart="@(args => BeginDrag(args, item.Id))"
												@ondragend="ClearDragState">
											<span aria-hidden="true">::</span>
										</button>
									}
								</td>
								<td>@item.Prompt</td>
								<td>@item.Type</td>
								<td>@(item.IsRequired ? "Yes" : "No")</td>
								<td>@item.SortOrder</td>
								<td>@item.OptionCount</td>
								<td>
									<div class="table-actions">
										<a class="btn btn-sm btn-outline-primary" href="@GetViewUrl(item.Id)">View</a>
										@if (SupportsOptions(item.Type))
										{
											<a class="btn btn-sm btn-outline-primary" href="@GetOptionsUrl(item.Id)">Options</a>
										}
										else
										{
											<span class="status-pill status-pill--muted">No Options</span>
										}
									</div>
								</td>
							</tr>
						}
					</tbody>
				</table>
			}
		</div>
	}
</div>

@code {
	[SupplyParameterFromQuery]
	public int? SurveySectionId { get; set; }

	[SupplyParameterFromQuery]
	public int? SurveyVersionId { get; set; }

	[SupplyParameterFromQuery]
	public int? SurveyDefinitionId { get; set; }

	private IReadOnlyList<SurveyQuestionListItem> _items = Array.Empty<SurveyQuestionListItem>();
	private int _pageSize = PagedQuery.MaxLimit;
	private int _totalCount;
	private bool _canReorder;
	private bool _isSavingOrder;
	private int? _draggedQuestionId;
	private int? _dropTargetQuestionId;
	private string? _reorderErrorMessage;

	protected override async Task OnParametersSetAsync()
	{
		if (!SurveySectionId.HasValue)
		{
			_items = Array.Empty<SurveyQuestionListItem>();
			_totalCount = 0;
			_canReorder = false;
			return;
		}

		var result = await AdministrationService.GetSurveyQuestionsAsync(new PagedQuery
		{
			Limit = PagedQuery.MaxLimit
		}, SurveySectionId.Value);
		_items = result.Items;
		_totalCount = result.TotalCount;
		_canReorder = await TenantPermissionEvaluator.HasPermissionAsync(TenantPermissionKeys.SurveysEdit)
			&& _items.Count == _totalCount
			&& _items.Count > 1
			&& !_items.Any(item => item.IsLocked);
		_reorderErrorMessage = null;
	}

	private string GetAddUrl()
	{
		var surveySectionId = SurveySectionId ?? 0;
		var surveyVersionId = SurveyVersionId ?? 0;
		if (SurveyDefinitionId.HasValue)
		{
			return $"/app/questions/new?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&surveyDefinitionId={SurveyDefinitionId.Value}&pageSize={_pageSize}";
		}

		return SurveyVersionId.HasValue
			? $"/app/questions/new?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&pageSize={_pageSize}"
			: $"/app/questions/new?surveySectionId={surveySectionId}&pageSize={_pageSize}";
	}

	private string GetSectionsUrl()
	{
		var surveyVersionId = SurveyVersionId ?? 0;
		return SurveyDefinitionId.HasValue
			? $"/app/sections?surveyVersionId={surveyVersionId}&surveyDefinitionId={SurveyDefinitionId.Value}&pageSize={_pageSize}"
			: $"/app/sections?surveyVersionId={surveyVersionId}&pageSize={_pageSize}";
	}

	private string GetOptionsUrl(int surveyQuestionId)
	{
		var surveySectionId = SurveySectionId ?? 0;
		var surveyVersionId = SurveyVersionId ?? 0;
		return SurveyDefinitionId.HasValue
			? $"/app/options?surveyQuestionId={surveyQuestionId}&surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&surveyDefinitionId={SurveyDefinitionId.Value}&pageSize={_pageSize}"
			: $"/app/options?surveyQuestionId={surveyQuestionId}&surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&pageSize={_pageSize}";
	}

	private string GetViewUrl(int surveyQuestionId)
	{
		var surveySectionId = SurveySectionId ?? 0;
		var surveyVersionId = SurveyVersionId ?? 0;
		return SurveyDefinitionId.HasValue
			? $"/app/questions/{surveyQuestionId}?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&surveyDefinitionId={SurveyDefinitionId.Value}&pageSize={_pageSize}"
			: $"/app/questions/{surveyQuestionId}?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&pageSize={_pageSize}";
	}

	private static bool SupportsOptions(SurveyQuestionType questionType)
	{
		return questionType is SurveyQuestionType.SingleChoice or SurveyQuestionType.MultiSelect;
	}

	private bool CanDragRow(SurveyQuestionListItem item)
	{
		return _canReorder && !_isSavingOrder && !item.IsLocked;
	}

	private void BeginDrag(DragEventArgs args, int questionId)
	{
		if (!_canReorder || _isSavingOrder)
		{
			return;
		}

		if (args.DataTransfer is not null)
		{
			args.DataTransfer.DropEffect = "move";
			args.DataTransfer.EffectAllowed = "move";
		}

		_draggedQuestionId = questionId;
		_dropTargetQuestionId = questionId;
		_reorderErrorMessage = null;
	}

	private void SetDropTarget(int questionId)
	{
		if (_draggedQuestionId.HasValue && _draggedQuestionId.Value != questionId)
		{
			_dropTargetQuestionId = questionId;
		}
	}

	private async Task DropAsync(int questionId)
	{
		if (!_draggedQuestionId.HasValue || !SurveySectionId.HasValue || _isSavingOrder)
		{
			return;
		}

		var sourceId = _draggedQuestionId.Value;
		ClearDragState();
		if (sourceId == questionId)
		{
			return;
		}

		var reorderedItems = ReorderItems(sourceId, questionId);
		if (reorderedItems is null)
		{
			return;
		}

		var originalItems = _items.Select(CloneItem).ToArray();
		_items = reorderedItems.Select(CloneItem).ToArray();
		_isSavingOrder = true;
		_reorderErrorMessage = null;

		try
		{
			await AdministrationService.ReorderSurveyQuestionsAsync(SurveySectionId.Value, reorderedItems.Select(item => item.Id).ToArray());
			ToastService.ShowSuccess("Question order updated.", "Saved");
		}
		catch (Exception ex)
		{
			_items = originalItems;
			_reorderErrorMessage = ex.Message;
			ToastService.ShowError(ex.Message, "Reorder failed");
		}
		finally
		{
			_isSavingOrder = false;
		}
	}

	private List<SurveyQuestionListItem>? ReorderItems(int sourceId, int targetId)
	{
		var reorderedItems = _items.Select(CloneItem).ToList();
		var sourceIndex = reorderedItems.FindIndex(item => item.Id == sourceId);
		var targetIndex = reorderedItems.FindIndex(item => item.Id == targetId);
		if (sourceIndex < 0 || targetIndex < 0)
		{
			return null;
		}

		var sourceItem = reorderedItems[sourceIndex];
		reorderedItems.RemoveAt(sourceIndex);
		reorderedItems.Insert(targetIndex, sourceItem);

		for (var index = 0; index < reorderedItems.Count; index++)
		{
			reorderedItems[index].SortOrder = index + 1;
		}

		return reorderedItems;
	}

	private string GetRowClass(int questionId)
	{
		var classes = new List<string>();
		if (_draggedQuestionId == questionId)
		{
			classes.Add("admin-table__row--dragging");
		}

		if (_dropTargetQuestionId == questionId)
		{
			classes.Add("admin-table__row--drop-target");
		}

		if (_isSavingOrder)
		{
			classes.Add("admin-table__row--saving");
		}

		return string.Join(" ", classes);
	}

	private void ClearDragState()
	{
		_draggedQuestionId = null;
		_dropTargetQuestionId = null;
	}

	private static SurveyQuestionListItem CloneItem(SurveyQuestionListItem item)
	{
		return new SurveyQuestionListItem
		{
			Id = item.Id,
			SurveySectionId = item.SurveySectionId,
			SectionTitle = item.SectionTitle,
			Prompt = item.Prompt,
			Type = item.Type,
			IsRequired = item.IsRequired,
			SortOrder = item.SortOrder,
			OptionCount = item.OptionCount,
			IsLocked = item.IsLocked
		};
	}
}
