@page "/app/people"
@attribute [TenantAuthorize(TenantPermissionKeys.PeopleView)]
@inject ITenantAdministrationService AdministrationService
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>People</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Recipients</p>
			<h1>@(ShowArchived ? "Archived People" : "People")</h1>
			<p>@(ShowArchived
				? "Archived people remain available for reference and can be restored when needed."
				: "View the people in the system along with their main contact details and location counts.")</p>
		</div>
		<div class="toolbar">
			<a class="btn btn-outline-primary" href="@GetArchivedUrl()">@(ShowArchived ? "Back to People" : "Archived People")</a>
			@if (!ShowArchived)
			{
				<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.PeopleCreate)">
					<Authorized>
						<a class="btn btn-primary" href="/app/people/new">Add Person</a>
					</Authorized>
				</AuthorizeView>
			}
		</div>
	</div>

	<div class="list-card">
		@if (_items.Count == 0)
		{
			<p class="empty-state">No people have been added yet.</p>
		}
		else
		{
			<table class="admin-table">
				<thead>
					<tr>
						<th><SortableHeader Label="Name" SortKey="name" CurrentSort="@Sort" Href="@GetSortUrl("name")" /></th>
						<th><SortableHeader Label="Locations" SortKey="locations" CurrentSort="@Sort" Href="@GetSortUrl("locations")" /></th>
						<th><SortableHeader Label="ZIP" SortKey="zip" CurrentSort="@Sort" Href="@GetSortUrl("zip")" /></th>
						<th><SortableHeader Label="Email" SortKey="email" CurrentSort="@Sort" Href="@GetSortUrl("email")" /></th>
						<th><SortableHeader Label="Phone" SortKey="phone" CurrentSort="@Sort" Href="@GetSortUrl("phone")" /></th>
						<th><SortableHeader Label="Archived" SortKey="archived" CurrentSort="@Sort" Href="@GetSortUrl("archived")" /></th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in _items)
					{
						<tr>
							<td>@string.Join(" ", new[] { item.FirstName, item.MiddleName, item.LastName }.Where(part => !string.IsNullOrWhiteSpace(part)))</td>
							<td>@item.LocationCount</td>
							<td>@item.PostalCode</td>
							<td>@item.Email</td>
							<td>@item.PhoneNumber</td>
							<td>@(item.IsArchived ? "Yes" : "No")</td>
							<td>
								<div class="table-actions">
									<a class="btn btn-sm btn-outline-primary" href="@($"/app/people/{item.Id}{BuildArchivedQuery()}")">View</a>
									<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.AssignmentsView)">
										<Authorized>
											<a class="btn btn-sm btn-outline-primary" href="/app/people/@item.Id/assignments">Assignments</a>
										</Authorized>
									</AuthorizeView>
									<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.LocationsView)">
										<Authorized>
											<a class="btn btn-sm btn-outline-primary" href="/app/people/@item.Id/locations">Locations</a>
										</Authorized>
									</AuthorizeView>
									<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.PeopleEdit)">
										<Authorized>
											<button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => ToggleArchivedAsync(item)">
												@(item.IsArchived ? "Unarchive" : "Archive")
											</button>
										</Authorized>
									</AuthorizeView>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}

		<ListPager ShownCount="_items.Count"
				   TotalCount="_totalCount"
				   PageSize="_pageSize"
				   HasMore="_hasMore"
				   IsLoadingMore="_isLoadingMore"
				   PageSizeOptions="ListPagingDefaults.PageSizeOptions"
				   PageSizeChanged="OnPageSizeChangedAsync"
				   OnLoadMore="LoadMoreAsync" />
	</div>
</div>

@code {
	[SupplyParameterFromQuery(Name = "showArchived")]
	public bool ShowArchived { get; set; }

	[SupplyParameterFromQuery(Name = "pageSize")]
	public int? PageSize { get; set; }

	[SupplyParameterFromQuery(Name = "sort")]
	public string? Sort { get; set; }

	private IReadOnlyList<PersonListItem> _items = Array.Empty<PersonListItem>();
	private int _pageSize = PagedQuery.DefaultLimit;
	private int _totalCount;
	private bool _hasMore;
	private bool _isLoadingMore;

	protected override async Task OnParametersSetAsync()
	{
		_pageSize = ListPagingDefaults.NormalizePageSize(PageSize);
		await LoadAsync();
	}

	private string GetArchivedUrl()
	{
		return BuildUrl(!ShowArchived, _pageSize, Sort);
	}

	private string BuildArchivedQuery()
	{
		return ShowArchived ? "?showArchived=true" : string.Empty;
	}

	private async Task ToggleArchivedAsync(PersonListItem item)
	{
		try
		{
			var isArchived = !item.IsArchived;
			await AdministrationService.SetPersonArchivedAsync(item.Id, isArchived);
			ToastService.ShowSuccess(
				isArchived ? "Person archived successfully." : "Person restored successfully.",
				isArchived ? "Archived" : "Restored");
			await LoadAsync();
		}
		catch (Exception ex)
		{
			ToastService.ShowError(ex.Message, "Update failed");
		}
	}

	private async Task LoadAsync(bool append = false)
	{
		var result = await AdministrationService.GetPeopleAsync(
			ListPagingDefaults.CreateRequest(_pageSize, append ? _items.Count : 0, Sort),
			ShowArchived);
		_items = append ? _items.Concat(result.Items).ToArray() : result.Items;
		_totalCount = result.TotalCount;
		_hasMore = result.HasMore;
	}

	private async Task LoadMoreAsync()
	{
		_isLoadingMore = true;
		try
		{
			await LoadAsync(append: true);
		}
		finally
		{
			_isLoadingMore = false;
		}
	}

	private Task OnPageSizeChangedAsync(int pageSize)
	{
		NavigationManager.NavigateTo(BuildUrl(ShowArchived, pageSize, Sort));
		return Task.CompletedTask;
	}

	private string GetSortUrl(string key)
	{
		return BuildUrl(ShowArchived, _pageSize, PagingSort.Toggle(Sort, key));
	}

	private static string BuildUrl(bool showArchived, int pageSize, string? sort)
	{
		var queryParts = new List<string>
		{
			$"pageSize={pageSize}"
		};
		if (showArchived)
		{
			queryParts.Add("showArchived=true");
		}
		if (!string.IsNullOrWhiteSpace(sort))
		{
			queryParts.Add($"sort={Uri.EscapeDataString(sort)}");
		}

		return $"/app/people?{string.Join("&", queryParts)}";
	}
}
