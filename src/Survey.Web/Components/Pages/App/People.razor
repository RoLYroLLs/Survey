@page "/app/people"
@attribute [TenantAuthorize(TenantPermissionKeys.PeopleView)]
@inject ITenantAdministrationService AdministrationService
@inject ToastService ToastService

<PageTitle>People</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Recipients</p>
			<h1>@(ShowArchived ? "Archived People" : "People")</h1>
			<p>@(ShowArchived
				? "Archived people remain available for reference and can be restored when needed."
				: "View the people in the system along with their main contact details and location counts.")</p>
		</div>
		<div class="toolbar">
			<a class="btn btn-outline-primary" href="@GetArchivedUrl()">@(ShowArchived ? "Back to People" : "Archived People")</a>
			@if (!ShowArchived)
			{
				<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.PeopleCreate)">
					<Authorized>
						<a class="btn btn-primary" href="/app/people/new">Add Person</a>
					</Authorized>
				</AuthorizeView>
			}
		</div>
	</div>

	<div class="list-card">
		@if (_items.Count == 0)
		{
			<p class="empty-state">No people have been added yet.</p>
		}
		else
		{
			<table class="admin-table">
				<thead>
					<tr>
						<th>Name</th>
						<th>Locations</th>
						<th>ZIP</th>
						<th>Email</th>
						<th>Phone</th>
						<th>Archived</th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in _items)
					{
						<tr>
							<td>@string.Join(" ", new[] { item.FirstName, item.MiddleName, item.LastName }.Where(part => !string.IsNullOrWhiteSpace(part)))</td>
							<td>@item.LocationCount</td>
							<td>@item.PostalCode</td>
							<td>@item.Email</td>
							<td>@item.PhoneNumber</td>
							<td>@(item.IsArchived ? "Yes" : "No")</td>
							<td>
								<div class="table-actions">
									<a class="btn btn-sm btn-outline-primary" href="@($"/app/people/{item.Id}{BuildArchivedQuery()}")">View</a>
									<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.AssignmentsView)">
										<Authorized>
											<a class="btn btn-sm btn-outline-primary" href="/app/people/@item.Id/assignments">Assignments</a>
										</Authorized>
									</AuthorizeView>
									<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.LocationsView)">
										<Authorized>
											<a class="btn btn-sm btn-outline-primary" href="/app/people/@item.Id/locations">Locations</a>
										</Authorized>
									</AuthorizeView>
									<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.PeopleEdit)">
										<Authorized>
											<button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => ToggleArchivedAsync(item)">
												@(item.IsArchived ? "Unarchive" : "Archive")
											</button>
										</Authorized>
									</AuthorizeView>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}
	</div>
</div>

@code {
	[SupplyParameterFromQuery(Name = "showArchived")]
	public bool ShowArchived { get; set; }

	private IReadOnlyList<PersonListItem> _items = Array.Empty<PersonListItem>();

	protected override async Task OnParametersSetAsync()
	{
		_items = await AdministrationService.GetPeopleAsync(ShowArchived);
	}

	private string GetArchivedUrl()
	{
		return ShowArchived ? "/app/people" : "/app/people?showArchived=true";
	}

	private string BuildArchivedQuery()
	{
		return ShowArchived ? "?showArchived=true" : string.Empty;
	}

	private async Task ToggleArchivedAsync(PersonListItem item)
	{
		try
		{
			var isArchived = !item.IsArchived;
			await AdministrationService.SetPersonArchivedAsync(item.Id, isArchived);
			ToastService.ShowSuccess(
				isArchived ? "Person archived successfully." : "Person restored successfully.",
				isArchived ? "Archived" : "Restored");
			_items = await AdministrationService.GetPeopleAsync(ShowArchived);
		}
		catch (Exception ex)
		{
			ToastService.ShowError(ex.Message, "Update failed");
		}
	}
}
