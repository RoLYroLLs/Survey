@page "/app/goals"
@attribute [TenantAuthorize(TenantPermissionKeys.GoalsView)]
@inject ITenantAdministrationService AdministrationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Goals</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Response Targets</p>
			<h1>Goals</h1>
			<p>View the response goals that have been defined.</p>
		</div>
		<div class="toolbar">
			<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.GoalsCreate)">
				<Authorized>
					<a class="btn btn-primary" href="/app/goals/new">Add Goal</a>
				</Authorized>
			</AuthorizeView>
		</div>
	</div>

	@if (!string.IsNullOrWhiteSpace(_errorMessage))
	{
		<div class="inline-banner inline-banner--danger">@_errorMessage</div>
	}

	<div class="list-card">
		@if (_items.Count == 0)
		{
			<p class="empty-state">No goals have been created yet.</p>
		}
		else
		{
			<table class="admin-table">
				<thead>
					<tr>
						<th><SortableHeader Label="Name" SortKey="name" CurrentSort="@Sort" Href="@GetSortUrl("name")" /></th>
						<th><SortableHeader Label="Area" SortKey="area" CurrentSort="@Sort" Href="@GetSortUrl("area")" /></th>
						<th><SortableHeader Label="Survey" SortKey="survey" CurrentSort="@Sort" Href="@GetSortUrl("survey")" /></th>
						<th><SortableHeader Label="Window" SortKey="window" CurrentSort="@Sort" Href="@GetSortUrl("window")" /></th>
						<th><SortableHeader Label="Progress" SortKey="progress" CurrentSort="@Sort" Href="@GetSortUrl("progress")" /></th>
						<th><SortableHeader Label="Dashboard" SortKey="dashboard" CurrentSort="@Sort" Href="@GetSortUrl("dashboard")" /></th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in _items)
					{
						<tr>
							<td>@item.Name</td>
							<td>@(string.IsNullOrWhiteSpace(item.AreaName) ? "All Areas" : item.AreaName)</td>
							<td>@(string.IsNullOrWhiteSpace(item.SurveyName) ? "All Surveys" : item.SurveyName)</td>
							<td>@item.StartDate.ToString("d") - @item.EndDate.ToString("d")</td>
							<td>@item.CompletedResponses / @item.TargetResponseCount (@item.ProgressPercent.ToString("0.0")%)</td>
							<td>
								<button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => ToggleFavoriteAsync(item.Id)">
									@(item.IsFavorite ? "Favorited" : "Favorite")
								</button>
							</td>
							<td>
								<div class="table-actions">
									<a class="btn btn-sm btn-outline-primary" href="/app/goals/@item.Id">View</a>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}

		<ListPager ShownCount="_items.Count"
				   TotalCount="_totalCount"
				   PageSize="_pageSize"
				   HasMore="_hasMore"
				   IsLoadingMore="_isLoadingMore"
				   PageSizeOptions="ListPagingDefaults.PageSizeOptions"
				   PageSizeChanged="OnPageSizeChangedAsync"
				   OnLoadMore="LoadMoreAsync" />
	</div>
</div>

@code {
	[SupplyParameterFromQuery(Name = "pageSize")]
	public int? PageSize { get; set; }

	[SupplyParameterFromQuery(Name = "sort")]
	public string? Sort { get; set; }

	private IReadOnlyList<GoalListItem> _items = Array.Empty<GoalListItem>();
	private string? _currentUserId;
	private string? _errorMessage;
	private int _pageSize = PagedQuery.DefaultLimit;
	private int _totalCount;
	private bool _hasMore;
	private bool _isLoadingMore;

	protected override async Task OnInitializedAsync()
	{
		var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
		_currentUserId = authenticationState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
	}

	protected override async Task OnParametersSetAsync()
	{
		_pageSize = ListPagingDefaults.NormalizePageSize(PageSize);
		await LoadGoalsAsync();
	}

	private async Task ToggleFavoriteAsync(int goalId)
	{
		if (string.IsNullOrWhiteSpace(_currentUserId))
		{
			_errorMessage = "The signed-in user could not be resolved.";
			return;
		}

		try
		{
			_errorMessage = null;
			await AdministrationService.ToggleFavoriteGoalAsync(goalId, _currentUserId);
			await LoadGoalsAsync();
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
	}

	private async Task LoadGoalsAsync(bool append = false)
	{
		var result = await AdministrationService.GetGoalsAsync(
			ListPagingDefaults.CreateRequest(_pageSize, append ? _items.Count : 0, Sort),
			_currentUserId);
		_items = append ? _items.Concat(result.Items).ToArray() : result.Items;
		_totalCount = result.TotalCount;
		_hasMore = result.HasMore;
	}

	private async Task LoadMoreAsync()
	{
		_isLoadingMore = true;
		try
		{
			await LoadGoalsAsync(append: true);
		}
		finally
		{
			_isLoadingMore = false;
		}
	}

	private Task OnPageSizeChangedAsync(int pageSize)
	{
		NavigationManager.NavigateTo(BuildUrl(pageSize, Sort));
		return Task.CompletedTask;
	}

	private string GetSortUrl(string key)
	{
		return BuildUrl(_pageSize, PagingSort.Toggle(Sort, key));
	}

	private static string BuildUrl(int pageSize, string? sort)
	{
		var queryParts = new List<string>
		{
			$"pageSize={pageSize}"
		};
		if (!string.IsNullOrWhiteSpace(sort))
		{
			queryParts.Add($"sort={Uri.EscapeDataString(sort)}");
		}

		return $"/app/goals?{string.Join("&", queryParts)}";
	}
}
