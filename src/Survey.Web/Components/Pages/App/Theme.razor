@page "/app/theme"
@attribute [TenantAuthorize]
@inject ITenantAdministrationService AdministrationService
@inject ITenantContextAccessor TenantContextAccessor
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>Theme</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Tenant Settings</p>
			<h1>Theme</h1>
			<p>Choose the global platform-managed theme used across this tenant.</p>
		</div>
	</div>

	<div class="form-card">
		<div class="page-header">
			<div>
				<h2>Color System</h2>
				<p>Owners and admins can select the theme used by everyone in this tenant.</p>
			</div>
			@if (_model.UpdatedUtc.HasValue)
			{
				<span class="status-pill status-pill--muted">Updated @_model.UpdatedUtc.Value.LocalDateTime.ToString("g")</span>
			}
		</div>

		@if (!_model.CanManageTheme)
		{
			<p class="empty-state">Theme management is not available for this tenant membership.</p>
		}
		else
		{
			<div class="theme-preset-grid">
				@foreach (var option in _model.PresetOptions)
				{
					var isSelected = string.Equals(_model.ThemePresetKey, option.Key, StringComparison.OrdinalIgnoreCase);
					<button class="theme-preset-card @(isSelected ? "theme-preset-card--selected" : null)"
							type="button"
							disabled="@_isSaving"
							aria-pressed="@isSelected"
							@onclick="() => SaveAsync(option.Key)">
						<div class="theme-preset-card__top">
							<div>
								<h3>@option.Name</h3>
								<p>@option.Description</p>
							</div>
							<span class="theme-preset-card__indicator" aria-hidden="true">@(isSelected ? "Live" : "Apply")</span>
						</div>
						<span class="theme-preset-card__swatch" style="@option.PreviewStyle"></span>
						<div class="theme-preset-card__chips">
							<span class="theme-preset-card__chip">Primary @option.PrimaryColor</span>
							<span class="theme-preset-card__chip">Accent @option.AccentColor</span>
							<span class="theme-preset-card__chip">Background @option.BackgroundColor</span>
						</div>
					</button>
				}
			</div>
		}
	</div>
</div>

@code {
	private SiteSettingsEditModel _model = new();
	private bool _isSaving;

	protected override async Task OnParametersSetAsync()
	{
		var accessContext = await TenantContextAccessor.GetCurrentAsync();
		if (accessContext.TenantRole is not TenantRole.Owner and not TenantRole.Admin)
		{
			NavigationManager.NavigateTo("/Account/AccessDenied", true);
			return;
		}

		_model = await AdministrationService.GetSiteSettingsAsync();
	}

	private async Task SaveAsync(string themePresetKey)
	{
		if (_isSaving || !_model.CanManageTheme || string.Equals(_model.ThemePresetKey, themePresetKey, StringComparison.OrdinalIgnoreCase))
		{
			return;
		}

		try
		{
			_isSaving = true;
			var saveModel = new SiteSettingsEditModel
			{
				TenantName = _model.TenantName,
				ThemePresetKey = themePresetKey
			};
			await AdministrationService.SaveSiteSettingsAsync(saveModel);
			ToastService.ShowSuccess("Tenant theme was updated.", "Saved");
			_model = await AdministrationService.GetSiteSettingsAsync();
			NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
		}
		catch (Exception ex)
		{
			ToastService.ShowError(ex.Message, "Save failed");
		}
		finally
		{
			_isSaving = false;
		}
	}
}
