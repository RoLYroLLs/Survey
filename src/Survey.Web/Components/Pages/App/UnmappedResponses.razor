@page "/app/reports/unmapped-responses"
@attribute [TenantAuthorize(TenantPermissionKeys.ResponsesView)]
@inject ITenantAdministrationService AdministrationService
@inject NavigationManager NavigationManager

<PageTitle>Unmapped Responses</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Reporting</p>
			<h1>Unmapped Responses</h1>
			<p>@DescriptionText</p>
		</div>
		<div class="toolbar">
			@if (!IsMissingFilter)
			{
				<AuthorizeView Policy="@SurveyAuthorizationPolicies.PlatformPermission(PlatformPermissionKeys.GeographyView)">
					<Authorized>
						<a class="btn btn-outline-primary" href="/admin/zip-mappings">Review ZIP Mappings</a>
					</Authorized>
				</AuthorizeView>
			}
			<a class="btn btn-outline-primary" href="/app/reports">Back to Reports</a>
		</div>
	</div>

	<div class="list-card">
		@if (!_hasLoadedInitialState)
		{
			<p class="empty-state">Loading...</p>
		}
		else if (_items.Count == 0)
		{
			<p class="empty-state">No unmapped responses match this ZIP filter.</p>
		}
		else
		{
			<table class="admin-table">
				<thead>
					<tr>
						<th><SortableHeader Label="Respondent" SortKey="respondent" CurrentSort="@Sort" Href="@GetSortUrl("respondent")" /></th>
						<th><SortableHeader Label="Person / Location" SortKey="personlocation" CurrentSort="@Sort" Href="@GetSortUrl("personlocation")" /></th>
						<th><SortableHeader Label="ZIP / County" SortKey="zipcounty" CurrentSort="@Sort" Href="@GetSortUrl("zipcounty")" /></th>
						<th><SortableHeader Label="Survey" SortKey="survey" CurrentSort="@Sort" Href="@GetSortUrl("survey")" /></th>
						<th><SortableHeader Label="Submitted By" SortKey="submittedby" CurrentSort="@Sort" Href="@GetSortUrl("submittedby")" /></th>
						<th><SortableHeader Label="Submitted" SortKey="submitted" CurrentSort="@Sort" Href="@GetSortUrl("submitted")" /></th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in _items)
					{
						<tr>
							<td>@item.RespondentName</td>
							<td>@item.PersonName<br /><small>@item.LocationName</small></td>
							<td>@(string.IsNullOrWhiteSpace(item.PostalCode) ? "Missing" : item.PostalCode)<br /><small>@(string.IsNullOrWhiteSpace(item.CountyName) ? "Unmapped" : item.CountyName)</small></td>
							<td>@item.SurveyName<br /><small>@item.VersionName</small></td>
							<td>@item.SubmittedByLabel</td>
							<td>@item.SubmittedUtc.LocalDateTime.ToString("g")</td>
							<td>
								<div class="table-actions">
									<a class="btn btn-sm btn-outline-primary" href="/app/responses/@item.Id">View</a>
									<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.PeopleEdit)">
										<Authorized>
											<a class="btn btn-sm btn-outline-primary" href="/app/people/@item.PersonId/edit">Edit Person</a>
										</Authorized>
									</AuthorizeView>
									<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.LocationsEdit)">
										<Authorized>
											<a class="btn btn-sm btn-outline-primary" href="/app/people/@item.PersonId/locations/@item.LocationId/edit">Edit Location</a>
										</Authorized>
									</AuthorizeView>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}

		<ListPager ShownCount="_items.Count"
				   TotalCount="_totalCount"
				   PageSize="_pageSize"
				   HasMore="_hasMore"
				   IsLoadingMore="_isLoadingMore"
				   PageSizeOptions="ListPagingDefaults.PageSizeOptions"
				   PageSizeChanged="OnPageSizeChangedAsync"
				   OnLoadMore="LoadMoreAsync" />
	</div>
</div>

@code {
	[SupplyParameterFromQuery(Name = "postalCode")]
	public string? PostalCode { get; set; }

	[SupplyParameterFromQuery(Name = "pageSize")]
	public int? PageSize { get; set; }

	[SupplyParameterFromQuery(Name = "sort")]
	public string? Sort { get; set; }

	private IReadOnlyList<SurveyResponseListItem> _items = Array.Empty<SurveyResponseListItem>();
	private int _pageSize = PagedQuery.DefaultLimit;
	private int _totalCount;
	private bool _hasMore;
	private bool _isLoadingMore;
	private bool _hasLoadedInitialState;

	private bool IsMissingFilter => string.Equals(PostalCode, "Missing", StringComparison.OrdinalIgnoreCase);

	private string DescriptionText => IsMissingFilter
		? "These responses are missing a postal code entirely, so they cannot be mapped into a county."
		: $"These responses use ZIP {(string.IsNullOrWhiteSpace(PostalCode) ? "Missing" : PostalCode)}, which is not currently mapping into a county.";

	protected override async Task OnParametersSetAsync()
	{
		var filter = string.IsNullOrWhiteSpace(PostalCode) ? "Missing" : PostalCode.Trim();
		_pageSize = ListPagingDefaults.NormalizePageSize(PageSize);
		_hasLoadedInitialState = false;
		try
		{
			await LoadAsync(filter);
		}
		finally
		{
			_hasLoadedInitialState = true;
		}
	}

	private async Task LoadAsync(string filter, bool append = false)
	{
		var result = await AdministrationService.GetUnmappedResponsesAsync(
			ListPagingDefaults.CreateRequest(_pageSize, append ? _items.Count : 0, Sort),
			filter);
		_items = append ? _items.Concat(result.Items).ToArray() : result.Items;
		_totalCount = result.TotalCount;
		_hasMore = result.HasMore;
	}

	private async Task LoadMoreAsync()
	{
		var filter = string.IsNullOrWhiteSpace(PostalCode) ? "Missing" : PostalCode.Trim();
		_isLoadingMore = true;
		try
		{
			await LoadAsync(filter, append: true);
		}
		finally
		{
			_isLoadingMore = false;
		}
	}

	private Task OnPageSizeChangedAsync(int pageSize)
	{
		var filter = string.IsNullOrWhiteSpace(PostalCode) ? "Missing" : PostalCode.Trim();
		NavigationManager.NavigateTo(BuildUrl(filter, pageSize, Sort));
		return Task.CompletedTask;
	}

	private string GetSortUrl(string key)
	{
		var filter = string.IsNullOrWhiteSpace(PostalCode) ? "Missing" : PostalCode.Trim();
		return BuildUrl(filter, _pageSize, PagingSort.Toggle(Sort, key));
	}

	private static string BuildUrl(string filter, int pageSize, string? sort)
	{
		var queryParts = new List<string>
		{
			$"postalCode={Uri.EscapeDataString(filter)}",
			$"pageSize={pageSize}"
		};
		if (!string.IsNullOrWhiteSpace(sort))
		{
			queryParts.Add($"sort={Uri.EscapeDataString(sort)}");
		}

		return $"/app/reports/unmapped-responses?{string.Join("&", queryParts)}";
	}
}
