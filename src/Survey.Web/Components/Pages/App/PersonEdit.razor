@page "/app/people/new"
@page "/app/people/{Id:int}"
@page "/app/people/{Id:int}/edit"
@implements IDisposable
@attribute [TenantAuthorize]
@inject ITenantAdministrationService AdministrationService
@inject ITenantPermissionEvaluator TenantPermissionEvaluator
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>@GetPageTitle()</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Recipient</p>
			<h1>@GetPageTitle()</h1>
			<p>View or update this person's profile, addresses, and contact methods.</p>
		</div>
	</div>

	<div class="form-card">
		@if (IsViewMode)
		{
			<div class="page-stack">
				<div class="assignment-detail-list">
					<div class="assignment-detail-row">
						<strong>Archived</strong>
						<span>@(_model.IsArchived ? "Yes" : "No")</span>
					</div>
					<div class="assignment-detail-row">
						<strong>Best Time to Contact</strong>
						<span>@DisplayOrDash(GetContactOptionLabel(ContactOptionCatalog.BestTimeOptions, _model.BestTimeToContact))</span>
					</div>
					<div class="assignment-detail-row">
						<strong>Preferred Contact Method</strong>
						<span>@DisplayOrDash(GetContactOptionLabel(ContactOptionCatalog.PreferredContactMethodOptions, _model.PreferredContactMethod))</span>
					</div>
				</div>

				<div class="card-grid">
					<section class="content-card">
						<div class="page-header">
							<div>
								<h2 class="content-card__title-sm">Address</h2>
							</div>
						</div>
						<div class="address-block">
							@foreach (var line in FormatAddress(_model.PhysicalAddress))
							{
								<div>@line</div>
							}
						</div>
					</section>

					<section class="content-card">
						<div class="page-header">
							<div>
								<h2 class="content-card__title-sm">Mailing Address</h2>
							</div>
						</div>
						<div class="address-block">
							@foreach (var line in FormatAddress(_model.MailingAddress))
							{
								<div>@line</div>
							}
						</div>
					</section>
				</div>

				<div class="card-grid">
					<section class="content-card">
						<div class="page-header">
							<div>
								<h2 class="content-card__title-sm">Phone Numbers</h2>
							</div>
						</div>
						@if (_model.Phones.Count == 0)
						{
							<p class="empty-state">No phone numbers.</p>
						}
						else
						{
							<div class="contact-detail-list">
								@foreach (var phone in _model.Phones)
								{
									<div class="contact-detail-item">
										<strong>@GetContactOptionLabel(ContactOptionCatalog.PhoneTypeOptions, phone.Label)</strong>
										<span>@phone.PhoneNumber@(phone.IsPrimary ? " (Primary)" : string.Empty)</span>
									</div>
								}
							</div>
						}
					</section>

					<section class="content-card">
						<div class="page-header">
							<div>
								<h2 class="content-card__title-sm">Email Addresses</h2>
							</div>
						</div>
						@if (_model.Emails.Count == 0)
						{
							<p class="empty-state">No email addresses.</p>
						}
						else
						{
							<div class="contact-detail-list">
								@foreach (var email in _model.Emails)
								{
									<div class="contact-detail-item">
										<strong>@GetContactOptionLabel(ContactOptionCatalog.EmailTypeOptions, email.Label)</strong>
										<span>@email.EmailAddress@(email.IsPrimary ? " (Primary)" : string.Empty)</span>
									</div>
								}
							</div>
						}
					</section>
				</div>

				@if (Id.HasValue)
				{
					<div class="list-card mt-4">
						<div class="page-header">
							<div>
								<h2 class="content-card__title-sm">Locations</h2>
								<p>View the locations saved for this person.</p>
							</div>
							<div class="toolbar">
								<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.AssignmentsView)">
									<Authorized>
										<a class="btn btn-outline-primary" href="/app/people/@Id/assignments">View Assignments</a>
									</Authorized>
								</AuthorizeView>
								<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.LocationsView)">
									<Authorized>
										<a class="btn btn-outline-primary" href="/app/people/@Id/locations">Manage Locations</a>
									</Authorized>
								</AuthorizeView>
							</div>
						</div>

						@if (_model.Locations.Count == 0)
						{
							<p class="empty-state">No locations have been added for this person yet.</p>
						}
						else
						{
							<table class="admin-table">
								<thead>
									<tr>
										<th>Nickname</th>
										<th>ZIP</th>
										<th>Email</th>
										<th>Phone</th>
										<th>Assignments</th>
										<th></th>
									</tr>
								</thead>
								<tbody>
									@foreach (var location in _model.Locations)
									{
										<tr>
											<td>@location.Nickname</td>
											<td>@location.PostalCode</td>
											<td>@location.Email</td>
											<td>@location.PhoneNumber</td>
											<td>@location.AssignmentCount</td>
											<td>
												<div class="table-actions">
													<a class="btn btn-sm btn-outline-primary" href="/app/people/@Id/locations/@location.Id">View</a>
													<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.LocationsDelete)">
														<Authorized>
															@if (location.AssignmentCount == 0)
															{
																<button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => RemoveLocationAsync(location.Id)">Remove</button>
															}
															else
															{
																<button class="btn btn-sm btn-muted-disabled" type="button" disabled>Remove</button>
															}
														</Authorized>
													</AuthorizeView>
												</div>
											</td>
										</tr>
									}
								</tbody>
							</table>
						}
					</div>
				}

				<div class="form-footer">
					<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.PeopleEdit)">
						<Authorized>
							<button class="btn btn-outline-primary" type="button" @onclick="ToggleArchivedAsync">
								@(_model.IsArchived ? "Unarchive" : "Archive")
							</button>
							<a class="btn btn-primary" href="@($"/app/people/{Id}/edit{BuildArchivedQuery()}")">Edit Person</a>
						</Authorized>
					</AuthorizeView>
					<a class="btn btn-outline-primary" href="@GetBackUrl()">Back to People</a>
				</div>
			</div>
		}
		else
		{
			<EditForm Model="_model" OnValidSubmit="SaveAsync" OnInvalidSubmit="HandleInvalidSubmit">
				<DataAnnotationsValidator />
				<ValidationSummary class="alert alert-danger form-validation-summary" />
				<div class="form-grid">
					<div class="field-stack">
						<label>First Name</label>
						<InputText class="form-control" @bind-Value="_model.FirstName" />
						<ValidationMessage For="@(() => _model.FirstName)" />
					</div>
					<div class="field-stack">
						<label>Middle Name</label>
						<InputText class="form-control" @bind-Value="_model.MiddleName" />
					</div>
					<div class="field-stack">
						<label>Last Name</label>
						<InputText class="form-control" @bind-Value="_model.LastName" />
						<ValidationMessage For="@(() => _model.LastName)" />
					</div>
					<div class="field-stack">
						<label>Best Time to Contact</label>
						<SearchableSelect class="form-control"
										  @bind-Value="_model.BestTimeToContact"
										  Options="ContactOptionCatalog.BestTimeOptions"
										  IncludeEmptyOption="true"
										  EmptyOptionLabel="Select a time" />
					</div>
					<div class="field-stack">
						<label>Preferred Contact Method</label>
						<SearchableSelect class="form-control"
										  @bind-Value="_model.PreferredContactMethod"
										  Options="ContactOptionCatalog.PreferredContactMethodOptions"
										  IncludeEmptyOption="true"
										  EmptyOptionLabel="Select a method" />
					</div>
				</div>

				<div class="card-grid mt-4">
					<section class="content-card">
						<div class="page-header">
							<div>
								<h2>Address</h2>
								<p>Enter the main address for this person.</p>
							</div>
							<div class="toolbar">
								<button class="btn btn-sm btn-outline-primary" type="button" @onclick="CopyMailingToPhysical">Same as Mailing</button>
							</div>
						</div>
						@AddressFields(_model.PhysicalAddress, true, false)
					</section>

					<section class="content-card">
						<div class="page-header">
							<div>
								<h2>Mailing Address</h2>
								<p>Enter the mailing address for this person.</p>
							</div>
							<div class="toolbar">
								<button class="btn btn-sm btn-outline-primary" type="button" @onclick="CopyPhysicalToMailing">Same as Profile Address</button>
							</div>
						</div>
						@AddressFields(_model.MailingAddress, false, true)
					</section>
				</div>

				<div class="card-grid mt-4">
					<section class="content-card">
						<div class="page-header">
							<div>
								<h2>Phone Numbers</h2>
								<p>View or update this person's phone numbers.</p>
							</div>
							<div class="toolbar">
								<button class="btn btn-sm btn-outline-primary" type="button" @onclick="AddPhone">Add Phone</button>
							</div>
						</div>
						<ValidationMessage For="@(() => _model.ContactMethodsValidationMessage)" />
						@for (var index = 0; index < _model.Phones.Count; index++)
						{
							var currentIndex = index;
							var phone = _model.Phones[index];
							<div class="form-grid mb-3">
								<div class="field-stack">
									<label>Type</label>
									<SearchableSelect class="form-control"
													  @bind-Value="phone.Label"
													  Options="ContactOptionCatalog.PhoneTypeOptions" />
								</div>
								<div class="field-stack">
									<label>Phone</label>
									<InputText class="form-control" @bind-Value="phone.PhoneNumber" />
								</div>
								<div class="field-stack">
									<label>Actions</label>
									<div class="toolbar">
										<label class="form-check mb-0">
											<InputCheckbox class="form-check-input" Value="phone.IsPrimary" ValueChanged="checkedValue => SetPrimaryPhone(currentIndex, checkedValue)" ValueExpression="@(() => phone.IsPrimary)" />
											<span>Primary</span>
										</label>
										<button class="btn btn-outline-primary" type="button" @onclick="() => RemovePhone(currentIndex)">Remove</button>
									</div>
								</div>
							</div>
						}
					</section>

					<section class="content-card">
						<div class="page-header">
							<div>
								<h2>Email Addresses</h2>
								<p>View or update this person's email addresses.</p>
							</div>
							<div class="toolbar">
								<button class="btn btn-sm btn-outline-primary" type="button" @onclick="AddEmail">Add Email</button>
							</div>
						</div>
						@for (var index = 0; index < _model.Emails.Count; index++)
						{
							var currentIndex = index;
							var email = _model.Emails[index];
							<div class="form-grid mb-3">
								<div class="field-stack">
									<label>Type</label>
									<SearchableSelect class="form-control"
													  @bind-Value="email.Label"
													  Options="ContactOptionCatalog.EmailTypeOptions" />
								</div>
								<div class="field-stack">
									<label>Email</label>
									<InputText class="form-control" @bind-Value="email.EmailAddress" />
								</div>
								<div class="field-stack">
									<label>Actions</label>
									<div class="toolbar">
										<label class="form-check mb-0">
											<InputCheckbox class="form-check-input" Value="email.IsPrimary" ValueChanged="checkedValue => SetPrimaryEmail(currentIndex, checkedValue)" ValueExpression="@(() => email.IsPrimary)" />
											<span>Primary</span>
										</label>
										<button class="btn btn-outline-primary" type="button" @onclick="() => RemoveEmail(currentIndex)">Remove</button>
									</div>
								</div>
							</div>
						}
					</section>
				</div>

				<div class="form-footer">
					<button class="btn btn-primary" type="submit">Save Person</button>
					<a class="btn btn-outline-primary" href="@(Id.HasValue ? $"/app/people/{Id.Value}{BuildArchivedQuery()}" : GetBackUrl())">Cancel</a>
				</div>
			</EditForm>
		}
	</div>
</div>

@code {
	[Parameter]
	public int? Id { get; set; }

	[SupplyParameterFromQuery(Name = "showArchived")]
	public bool ShowArchived { get; set; }

	private PersonEditModel _model = new();
	private bool IsViewMode => Id.HasValue && !NavigationManager.Uri.Contains("/edit", StringComparison.OrdinalIgnoreCase);

	protected override void OnInitialized()
	{
		NavigationManager.LocationChanged += OnLocationChanged;
	}

	protected override async Task OnParametersSetAsync()
	{
		if (!await EnsurePageAccessAsync())
		{
			return;
		}

		_model = await AdministrationService.GetPersonAsync(Id);
	}

	private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
	{
		_ = InvokeAsync(StateHasChanged);
	}

	private RenderFragment AddressFields(AddressInputModel address, bool physical, bool mailing) => @<div class="form-grid">
		<div class="field-stack form-grid--single">
			<FieldLabel Text="Country" Required="@(physical || mailing)" />
			<SearchableSelect class="form-control"
							  @bind-Value="address.CountryId"
							  AfterValueChanged="() => OnCountryChangedAsync(address)"
							  Options="address.CountryOptions"
							  IncludeEmptyOption="true"
							  EmptyOptionLabel="Select a country"
							  EmptyOptionValue="0" />
			<ValidationMessage For="@(() => address.CountryId)" />
		</div>
		<div class="field-stack">
			<FieldLabel Text="State / Territory" Required="@(physical || mailing)" />
			<SearchableSelect class="form-control"
							  @bind-Value="address.StateProvinceId"
							  AfterValueChanged="() => OnStateChangedAsync(address)"
							  Options="address.StateProvinceOptions"
							  IncludeEmptyOption="true"
							  EmptyOptionLabel="Select a state or territory"
							  EmptyOptionValue="0"
							  Disabled="@(address.CountryId <= 0)" />
			<ValidationMessage For="@(() => address.StateProvinceId)" />
		</div>
		<div class="field-stack">
			<FieldLabel Text="County" Required="@(physical || mailing)" />
			<SearchableSelect class="form-control"
							  @bind-Value="address.CountyId"
							  Options="address.CountyOptions"
							  IncludeEmptyOption="true"
							  EmptyOptionLabel="Select a county"
							  Disabled="@(address.StateProvinceId <= 0)" />
			<ValidationMessage For="@(() => address.CountyId)" />
		</div>
		<div class="field-stack form-grid--single">
			<FieldLabel Text="Address Line 1" Required="@(physical || mailing)" />
			<InputText class="form-control" @bind-Value="address.AddressLine1" disabled="@(!address.CountyId.HasValue)" />
			<ValidationMessage For="@(() => address.AddressLine1)" />
		</div>
		<div class="field-stack form-grid--single">
			<label>Address Line 2</label>
			<InputText class="form-control" @bind-Value="address.AddressLine2" disabled="@(!address.CountyId.HasValue)" />
		</div>
		<div class="field-stack">
			<FieldLabel Text="City" Required="@(physical || mailing)" />
			<InputText class="form-control" @bind-Value="address.City" disabled="@(!address.CountyId.HasValue)" />
			<ValidationMessage For="@(() => address.City)" />
		</div>
		<div class="field-stack">
			<FieldLabel Text="Postal Code" Required="@(physical || mailing)" />
			<InputText class="form-control" @bind-Value="address.PostalCode" disabled="@(!address.CountyId.HasValue)" />
			<ValidationMessage For="@(() => address.PostalCode)" />
		</div>
	</div>;

	private async Task SaveAsync()
	{
		try
		{
			var personId = await AdministrationService.SavePersonAsync(_model);
			ToastService.ShowSuccess("Person saved successfully.", "Saved");
			NavigationManager.NavigateTo($"/app/people/{personId}{BuildArchivedQuery()}");
		}
		catch (Exception ex)
		{
			ToastService.ShowError(ex.Message, "Save failed");
		}
	}

	private void HandleInvalidSubmit()
	{
		ToastService.ShowWarning("Enter the required information before saving.", "Missing information");
	}

	private async Task RemoveLocationAsync(int locationId)
	{
		try
		{
			await AdministrationService.DeleteLocationAsync(locationId);
			_model = await AdministrationService.GetPersonAsync(Id);
			ToastService.ShowSuccess("Location removed successfully.", "Removed");
		}
		catch (Exception ex)
		{
			ToastService.ShowError(ex.Message, "Remove failed");
		}
	}

	private async Task ToggleArchivedAsync()
	{
		if (!Id.HasValue)
		{
			return;
		}

		try
		{
			var isArchived = !_model.IsArchived;
			await AdministrationService.SetPersonArchivedAsync(Id.Value, isArchived);
			_model.IsArchived = isArchived;
			ToastService.ShowSuccess(
				isArchived ? "Person archived successfully." : "Person restored successfully.",
				isArchived ? "Archived" : "Restored");
		}
		catch (Exception ex)
		{
			ToastService.ShowError(ex.Message, "Update failed");
		}
	}

	private string GetPageTitle()
	{
		if (IsViewMode)
		{
			return "Person";
		}

		return Id.HasValue ? "Edit Person" : "New Person";
	}

	private string GetBackUrl()
	{
		return ShowArchived ? "/app/people?showArchived=true" : "/app/people";
	}

	private string BuildArchivedQuery()
	{
		return ShowArchived ? "?showArchived=true" : string.Empty;
	}

	private async Task OnCountryChangedAsync(AddressInputModel address)
	{
		address.StateProvinceId = 0;
		address.CountyId = null;
		address.StateProvinceOptions = address.CountryId > 0
			? await AdministrationService.GetTenantStateProvinceSelectOptionsAsync(address.CountryId)
			: Array.Empty<SelectOption>();
		address.CountyOptions = Array.Empty<SelectOption>();
	}

	private async Task OnStateChangedAsync(AddressInputModel address)
	{
		address.CountyId = null;
		address.CountyOptions = address.StateProvinceId > 0
			? await AdministrationService.GetTenantCountySelectOptionsAsync(address.StateProvinceId)
			: Array.Empty<SelectOption>();
	}

	private void CopyPhysicalToMailing()
	{
		_model.MailingAddress = CloneAddress(_model.PhysicalAddress);
	}

	private void CopyMailingToPhysical()
	{
		_model.PhysicalAddress = CloneAddress(_model.MailingAddress);
	}

	private void AddPhone()
	{
		_model.Phones.Add(new PhoneContactEditModel
		{
			Label = ContactOptionCatalog.PhoneTypes.Home,
			IsPrimary = _model.Phones.Count == 0,
			SortOrder = (_model.Phones.Count + 1) * 10
		});
	}

	private void RemovePhone(int index)
	{
		if (index >= 0 && index < _model.Phones.Count)
		{
			var wasPrimary = _model.Phones[index].IsPrimary;
			_model.Phones.RemoveAt(index);
			if (wasPrimary && _model.Phones.Count > 0)
			{
				_model.Phones[0].IsPrimary = true;
			}
		}
	}

	private void AddEmail()
	{
		_model.Emails.Add(new EmailContactEditModel
		{
			Label = ContactOptionCatalog.EmailTypes.Home,
			IsPrimary = _model.Emails.Count == 0,
			SortOrder = (_model.Emails.Count + 1) * 10
		});
	}

	private void RemoveEmail(int index)
	{
		if (index >= 0 && index < _model.Emails.Count)
		{
			var wasPrimary = _model.Emails[index].IsPrimary;
			_model.Emails.RemoveAt(index);
			if (wasPrimary && _model.Emails.Count > 0)
			{
				_model.Emails[0].IsPrimary = true;
			}
		}
	}

	private static AddressInputModel CloneAddress(AddressInputModel source)
	{
		return new AddressInputModel
		{
			AddressLine1 = source.AddressLine1,
			AddressLine2 = source.AddressLine2,
			City = source.City,
			CountryId = source.CountryId,
			StateProvinceId = source.StateProvinceId,
			CountyId = source.CountyId,
			PostalCode = source.PostalCode,
			CountryOptions = source.CountryOptions,
			StateProvinceOptions = source.StateProvinceOptions,
			CountyOptions = source.CountyOptions
		};
	}

	private void SetPrimaryPhone(int index, bool isPrimary)
	{
		if (index < 0 || index >= _model.Phones.Count)
		{
			return;
		}

		if (!isPrimary && _model.Phones[index].IsPrimary)
		{
			return;
		}

		for (var itemIndex = 0; itemIndex < _model.Phones.Count; itemIndex++)
		{
			_model.Phones[itemIndex].IsPrimary = itemIndex == index;
		}
	}

	private void SetPrimaryEmail(int index, bool isPrimary)
	{
		if (index < 0 || index >= _model.Emails.Count)
		{
			return;
		}

		if (!isPrimary && _model.Emails[index].IsPrimary)
		{
			return;
		}

		for (var itemIndex = 0; itemIndex < _model.Emails.Count; itemIndex++)
		{
			_model.Emails[itemIndex].IsPrimary = itemIndex == index;
		}
	}

	private static string DisplayOrDash(string? value)
	{
		return string.IsNullOrWhiteSpace(value) ? "-" : value;
	}

	private static string GetContactOptionLabel(IEnumerable<SelectOption> options, string? value)
	{
		return options.FirstOrDefault(option => string.Equals(option.Value, value, StringComparison.OrdinalIgnoreCase))?.Label
			?? DisplayOrDash(value);
	}

	private string GetFullName()
	{
		return string.Join(" ", new[] { _model.FirstName, _model.MiddleName, _model.LastName }.Where(part => !string.IsNullOrWhiteSpace(part)));
	}

	private static IReadOnlyList<string> FormatAddress(AddressInputModel address)
	{
		var lines = new List<string>();

		if (!string.IsNullOrWhiteSpace(address.AddressLine1))
		{
			lines.Add(address.AddressLine1);
		}

		if (!string.IsNullOrWhiteSpace(address.AddressLine2))
		{
			lines.Add(address.AddressLine2);
		}

		var localityParts = new List<string>();
		if (!string.IsNullOrWhiteSpace(address.City))
		{
			localityParts.Add(address.City);
		}

		var state = ExtractStateCode(address.StateProvinceOptions.FirstOrDefault(option => option.Value == address.StateProvinceId.ToString())?.Label);
		var postal = address.PostalCode;
		var statePostal = string.Join(" ", new[] { state, postal }.Where(part => !string.IsNullOrWhiteSpace(part)));
		if (!string.IsNullOrWhiteSpace(statePostal))
		{
			localityParts.Add(statePostal);
		}

		if (localityParts.Count > 0)
		{
			lines.Add(string.Join(", ", localityParts));
		}

		var country = ExtractCountryName(address.CountryOptions.FirstOrDefault(option => option.Value == address.CountryId.ToString())?.Label);
		if (!string.IsNullOrWhiteSpace(country))
		{
			lines.Add(country);
		}

		if (lines.Count == 0)
		{
			lines.Add("-");
		}

		return lines;
	}

	private static string? ExtractStateCode(string? stateLabel)
	{
		if (string.IsNullOrWhiteSpace(stateLabel))
		{
			return null;
		}

		var openParenIndex = stateLabel.LastIndexOf('(');
		var closeParenIndex = stateLabel.LastIndexOf(')');
		if (openParenIndex >= 0 && closeParenIndex > openParenIndex)
		{
			return stateLabel.Substring(openParenIndex + 1, closeParenIndex - openParenIndex - 1).Trim();
		}

		return stateLabel;
	}

	private static string? ExtractCountryName(string? countryLabel)
	{
		if (string.IsNullOrWhiteSpace(countryLabel))
		{
			return null;
		}

		var suffixStart = countryLabel.LastIndexOf(" (", StringComparison.Ordinal);
		if (suffixStart > 0 && countryLabel.EndsWith(")", StringComparison.Ordinal))
		{
			return countryLabel.Substring(0, suffixStart).Trim();
		}

		return countryLabel;
	}

	private async Task<bool> EnsurePageAccessAsync()
	{
		var permissionKey = IsViewMode
			? TenantPermissionKeys.PeopleView
			: Id.HasValue
				? TenantPermissionKeys.PeopleEdit
				: TenantPermissionKeys.PeopleCreate;
		if (await TenantPermissionEvaluator.HasPermissionAsync(permissionKey))
		{
			return true;
		}

		NavigationManager.NavigateTo("/Account/AccessDenied", true);
		return false;
	}

	public void Dispose()
	{
		NavigationManager.LocationChanged -= OnLocationChanged;
	}
}
