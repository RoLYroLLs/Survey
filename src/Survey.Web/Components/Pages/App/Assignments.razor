@page "/app/assignments"
@attribute [TenantAuthorize(TenantPermissionKeys.AssignmentsView)]
@inject ITenantAdministrationService AdministrationService
@inject NavigationManager NavigationManager
@inject ToastService ToastService
@using Microsoft.AspNetCore.Components

<PageTitle>Assignments</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Survey Delivery</p>
<h1>Assignments</h1>
			<p>@(ShowArchived
				? "View archived survey assignments."
				: "View the survey assignments that have been created.")</p>
		</div>
		<div class="toolbar toolbar--assignments">
			<div class="field-stack field-stack--compact mb-0">
				<SearchableSelect class="form-select"
								  @bind-Value="Status"
								  AfterValueChanged="OnStatusChangedAsync"
								  Options="_statusOptions"
								  IncludeEmptyOption="true"
								  EmptyOptionLabel="All statuses"
								  ClosedEmptyLabel="Status" />
			</div>
			<a class="btn btn-outline-primary" href="@GetArchivedUrl()">@(ShowArchived ? "Back to Assignments" : "Archived Assignments")</a>
			@if (!ShowArchived)
			{
				<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.AssignmentsCreate)">
					<Authorized>
						<a class="btn btn-primary" href="/app/assignments/new">Add Assignment</a>
					</Authorized>
				</AuthorizeView>
			}
		</div>
	</div>

	<div class="list-card">
		@if (!_hasLoadedInitialState)
		{
			<p class="empty-state">Loading...</p>
		}
		else if (_items.Count == 0)
		{
			<p class="empty-state">No assignments have been issued yet.</p>
		}
		else
		{
			<table class="admin-table">
				<thead>
					<tr>
						<th><SortableHeader Label="Person" SortKey="person" CurrentSort="@Sort" Href="@GetSortUrl("person")" /></th>
						<th><SortableHeader Label="Location" SortKey="location" CurrentSort="@Sort" Href="@GetSortUrl("location")" /></th>
						<th><SortableHeader Label="Survey" SortKey="survey" CurrentSort="@Sort" Href="@GetSortUrl("survey")" /></th>
						<th><SortableHeader Label="Expires" SortKey="expires" CurrentSort="@Sort" Href="@GetSortUrl("expires")" /></th>
						<th><SortableHeader Label="Archived" SortKey="archived" CurrentSort="@Sort" Href="@GetSortUrl("archived")" /></th>
						<th><SortableHeader Label="Status" SortKey="status" CurrentSort="@Sort" Href="@GetSortUrl("status")" /></th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in _items)
					{
						<tr>
							<td>@item.PersonName</td>
							<td>@item.LocationName</td>
							<td>@item.SurveyName<br /><small>@item.VersionName</small></td>
							<td>@(item.ExpiresAtUtc?.LocalDateTime.ToString("g") ?? "Never")</td>
							<td>@(item.IsArchived ? "Yes" : "No")</td>
							<td>
								@if (item.IsCompleted)
								{
									<span class="status-pill status-pill--muted">Completed</span>
								}
								else if (item.IsArchived)
								{
									<span class="status-pill status-pill--muted">Archived</span>
								}
								else if (item.IsExpired)
								{
									<span class="status-pill status-pill--danger">Expired</span>
								}
								else
								{
									<span class="status-pill">Active</span>
								}
							</td>
							<td>
								<div class="table-actions">
									<a class="btn btn-sm btn-outline-primary" href="@GetAssignmentUrl(item.Id)">View</a>
									<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.AssignmentsFill)">
										<Authorized>
											@if (item.IsFillable)
											{
												<a class="btn btn-sm btn-outline-primary" href="/app/assignments/@item.Id/fill">Fill</a>
											}
											else
											{
												<button class="btn btn-sm btn-muted-disabled" type="button" disabled>Fill</button>
											}
										</Authorized>
									</AuthorizeView>
									<AuthorizeView Policy="@SurveyAuthorizationPolicies.TenantPermission(TenantPermissionKeys.AssignmentsArchive)">
										<Authorized>
											<button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => ToggleArchiveAsync(item)">
												@(item.IsArchived ? "Unarchive" : "Archive")
											</button>
										</Authorized>
									</AuthorizeView>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}

		<ListPager ShownCount="_items.Count"
				   TotalCount="_totalCount"
				   PageSize="_pageSize"
				   HasMore="_hasMore"
				   IsLoadingMore="_isLoadingMore"
				   PageSizeOptions="ListPagingDefaults.PageSizeOptions"
				   PageSizeChanged="OnPageSizeChangedAsync"
				   OnLoadMore="LoadMoreAsync" />
	</div>
</div>

@code {
	[SupplyParameterFromQuery]
	public bool ShowArchived { get; set; }

	[SupplyParameterFromQuery(Name = "status")]
	public string? Status { get; set; }

	[SupplyParameterFromQuery(Name = "pageSize")]
	public int? PageSize { get; set; }

	[SupplyParameterFromQuery(Name = "sort")]
	public string? Sort { get; set; }

	private IReadOnlyList<SurveyAssignmentListItem> _items = Array.Empty<SurveyAssignmentListItem>();
	private int _pageSize = PagedQuery.DefaultLimit;
	private int _totalCount;
	private bool _hasMore;
	private bool _isLoadingMore;
	private bool _hasLoadedInitialState;
	private static readonly IReadOnlyList<SelectOption> _statusOptions =
	[
		new() { Value = "active", Label = "Active" },
		new() { Value = "completed", Label = "Completed" },
		new() { Value = "expired", Label = "Expired" }
	];

	protected override async Task OnParametersSetAsync()
	{
		_pageSize = ListPagingDefaults.NormalizePageSize(PageSize);
		_hasLoadedInitialState = false;
		try
		{
			await LoadAsync();
		}
		finally
		{
			_hasLoadedInitialState = true;
		}
	}

	private string GetAssignmentUrl(int assignmentId)
	{
		var queryParts = new List<string>();
		if (ShowArchived)
		{
			queryParts.Add("showArchived=true");
		}

		if (!string.IsNullOrWhiteSpace(Status))
		{
			queryParts.Add($"status={Uri.EscapeDataString(Status)}");
		}

		return queryParts.Count == 0
			? $"/app/assignments/{assignmentId}"
			: $"/app/assignments/{assignmentId}?{string.Join("&", queryParts)}";
	}

	private string GetArchivedUrl()
	{
		return ShowArchived
			? BuildAssignmentsUrl(false, Status, _pageSize, Sort)
			: BuildAssignmentsUrl(true, Status, _pageSize, Sort);
	}

	private Task OnStatusChangedAsync()
	{
		NavigationManager.NavigateTo(BuildAssignmentsUrl(ShowArchived, Status, _pageSize, Sort));
		return Task.CompletedTask;
	}

	private async Task ToggleArchiveAsync(SurveyAssignmentListItem item)
	{
		try
		{
			var isArchived = !item.IsArchived;
			await AdministrationService.SetAssignmentArchivedAsync(item.Id, isArchived);
			ToastService.ShowSuccess(
				isArchived ? "Assignment archived successfully." : "Assignment restored successfully.",
				isArchived ? "Archived" : "Restored");
			await LoadAsync();
		}
		catch (Exception ex)
		{
			ToastService.ShowError(ex.Message, "Archive failed");
		}
	}

	private async Task LoadAsync(bool append = false)
	{
		var result = await AdministrationService.GetAssignmentsAsync(
			ListPagingDefaults.CreateRequest(_pageSize, append ? _items.Count : 0, Sort),
			archivedOnly: ShowArchived,
			statusFilter: Status);
		_items = append ? _items.Concat(result.Items).ToArray() : result.Items;
		_totalCount = result.TotalCount;
		_hasMore = result.HasMore;
	}

	private async Task LoadMoreAsync()
	{
		_isLoadingMore = true;
		try
		{
			await LoadAsync(append: true);
		}
		finally
		{
			_isLoadingMore = false;
		}
	}

	private Task OnPageSizeChangedAsync(int pageSize)
	{
		NavigationManager.NavigateTo(BuildAssignmentsUrl(ShowArchived, Status, pageSize, Sort));
		return Task.CompletedTask;
	}

	private string GetSortUrl(string key)
	{
		return BuildAssignmentsUrl(ShowArchived, Status, _pageSize, PagingSort.Toggle(Sort, key));
	}

	private static string BuildAssignmentsUrl(bool showArchived, string? status, int pageSize, string? sort)
	{
		var queryParts = new List<string>
		{
			$"pageSize={pageSize}"
		};
		if (showArchived)
		{
			queryParts.Add("showArchived=true");
		}

		if (!string.IsNullOrWhiteSpace(status))
		{
			queryParts.Add($"status={Uri.EscapeDataString(status)}");
		}
		if (!string.IsNullOrWhiteSpace(sort))
		{
			queryParts.Add($"sort={Uri.EscapeDataString(sort)}");
		}

		return $"/app/assignments?{string.Join("&", queryParts)}";
	}
}
