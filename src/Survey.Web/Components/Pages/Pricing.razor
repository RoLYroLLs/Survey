@page "/pricing"
@layout Layout.PublicLayout
<PageTitle>Pricing</PageTitle>

<div class="marketing-page marketing-page--pricing">
	<section class="marketing-section marketing-section--hero-lite">
		<div class="marketing-section__intro">
			<p class="eyebrow">Pricing page</p>
			<h1>Simple tiers for outreach teams of different sizes</h1>
			<p>This sample pricing page shows how Survey can be positioned for small teams, scaling departments, and enterprise-wide operations.</p>
		</div>
	</section>

	<section class="marketing-tier-grid">
		<article class="marketing-tier-card">
			<p class="marketing-tier-card__eyebrow">Starter</p>
			<h2>$79<span>/month</span></h2>
			<p>For one team that needs to launch surveys quickly without complex oversight.</p>
			<ul class="feature-list">
				<li>1 tenant</li>
				<li>Up to 3 admins</li>
				<li>1,500 active people</li>
				<li>Core survey builder, assignments, and responses</li>
				<li>Email support</li>
			</ul>
			<a class="btn btn-outline-primary" href="/Account/Register">@GetStarterCtaLabel()</a>
		</article>
		<article class="marketing-tier-card marketing-tier-card--featured">
			<div class="marketing-price-card__badge">Best for growing teams</div>
			<p class="marketing-tier-card__eyebrow">Growth</p>
			<h2>$249<span>/month</span></h2>
			<p>For departments running multiple campaigns and measuring progress against goals.</p>
			<ul class="feature-list">
				<li>3 tenants included</li>
				<li>Unlimited tenant users</li>
				<li>10,000 active people</li>
				<li>Areas, goals, reporting, and tenant invitations</li>
				<li>Priority support</li>
			</ul>
			<a class="btn btn-primary" href="/Account/Register">@GetGrowthCtaLabel()</a>
		</article>
		<article class="marketing-tier-card">
			<p class="marketing-tier-card__eyebrow">Enterprise</p>
			<h2>Custom</h2>
			<p>For organizations managing multiple programs, platform admins, and stricter governance needs.</p>
			<ul class="feature-list">
				<li>Unlimited tenants</li>
				<li>Platform-managed themes</li>
				<li>Expanded onboarding and rollout support</li>
				<li>Advanced governance and audit guidance</li>
				<li>Dedicated implementation planning</li>
			</ul>
			<a class="btn btn-outline-primary" href="/Account/Register">@GetEnterpriseCtaLabel()</a>
		</article>
	</section>

	<section class="marketing-section">
		<div class="marketing-section__intro">
			<p class="eyebrow">What changes by tier</p>
			<h2>A quick comparison</h2>
		</div>
		<div class="list-card marketing-comparison-card">
			<table class="admin-table">
				<thead>
					<tr>
						<th>Capability</th>
						<th>Starter</th>
						<th>Growth</th>
						<th>Enterprise</th>
					</tr>
				</thead>
				<tbody>
					<tr>
						<td>Tenants</td>
						<td>1</td>
						<td>3 included</td>
						<td>Unlimited</td>
					</tr>
					<tr>
						<td>People capacity</td>
						<td>1,500</td>
						<td>10,000</td>
						<td>Custom</td>
					</tr>
					<tr>
						<td>Assignments and responses</td>
						<td>Yes</td>
						<td>Yes</td>
						<td>Yes</td>
					</tr>
					<tr>
						<td>Areas and goals</td>
						<td>Basic</td>
						<td>Advanced</td>
						<td>Advanced</td>
					</tr>
					<tr>
						<td>Platform admin tools</td>
						<td>No</td>
						<td>Limited</td>
						<td>Full</td>
					</tr>
					<tr>
						<td>Theme library</td>
						<td>Shared presets</td>
						<td>Shared presets</td>
						<td>Custom managed themes</td>
					</tr>
				</tbody>
			</table>
		</div>
	</section>
</div>

@code {
	private string GetStarterCtaLabel()
	{
		return "Start with Starter";
	}

	private string GetGrowthCtaLabel()
	{
		return "Choose Growth";
	}

	private string GetEnterpriseCtaLabel()
	{
		return "Talk to Sales";
	}
}
