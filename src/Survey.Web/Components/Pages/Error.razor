@page "/Error"
@attribute [AllowAnonymous]
@inject NavigationManager NavigationManager

<PageTitle>Something Went Wrong</PageTitle>

<div class="not-found-page">
	<div class="status-card narrow-card">
		<p class="eyebrow">Something Went Wrong</p>
		<h1>We couldn't finish that request.</h1>
		<p class="mb-3">Please try again in a moment. If the problem continues, contact support.</p>
		<button class="btn btn-outline-primary" type="button" @onclick="GoHome">Return Home</button>
	</div>
</div>

@code {
	private void GoHome()
	{
		NavigationManager.NavigateTo("/");
	}
}
