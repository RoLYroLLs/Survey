@page "/admin/system/errors/setup"
@attribute [PlatformAuthorize(PlatformPermissionKeys.SettingsManage)]

<PageTitle>Setup Error Preview</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">System Error</p>
			<h1>Setup Error Preview</h1>
			<p>This is the centered setup-style error treatment for failures that should stay inside the onboarding flow.</p>
		</div>
	</div>

	<div class="system-preview-stage system-preview-stage--center">
		<div class="status-card narrow-card seed-progress-card">
			<p class="eyebrow">Initial Setup</p>
			<h1>We couldn't finish setup.</h1>
			<div class="inline-banner inline-banner--danger mb-3">The setup process hit a problem. The details were logged automatically.</div>
			<p class="mb-0">Please try again in a moment. If the problem continues, contact support.</p>
		</div>
	</div>
</div>
