@page "/admin/questions"
@attribute [Authorize(Roles = RoleNames.Admin)]
@inject ISurveyAdministrationService AdministrationService

<PageTitle>Questions</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Question Builder</p>
			<h1>Questions</h1>
			<p>View the questions in the selected section.</p>
		</div>
		<div class="toolbar">
			<a class="btn btn-outline-primary" href="@GetSectionsUrl()">Back to Sections</a>
			<a class="btn btn-primary" href="@GetAddUrl()">Add Question</a>
		</div>
	</div>

	@if (!SurveySectionId.HasValue)
	{
		<div class="inline-banner">Choose a survey section before managing questions.</div>
	}
	else
	{
		<div class="list-card">
			@if (_items.Count == 0)
			{
				<p class="empty-state">No questions exist for this section yet.</p>
			}
			else
			{
				<table class="admin-table">
					<thead>
						<tr>
							<th>Prompt</th>
							<th>Type</th>
							<th>Required</th>
							<th>Order</th>
							<th>Options</th>
							<th></th>
						</tr>
					</thead>
					<tbody>
						@foreach (var item in _items)
						{
							<tr>
								<td>@item.Prompt</td>
								<td>@item.Type</td>
								<td>@(item.IsRequired ? "Yes" : "No")</td>
								<td>@item.SortOrder</td>
								<td>@item.OptionCount</td>
								<td>
										<div class="table-actions">
											<a class="btn btn-sm btn-outline-primary" href="@GetEditUrl(item.Id)">Edit</a>
											@if (SupportsOptions(item.Type))
											{
												<a class="btn btn-sm btn-outline-primary" href="@GetOptionsUrl(item.Id)">Options</a>
										}
										else
										{
											<span class="status-pill status-pill--muted">No Options</span>
										}
									</div>
								</td>
							</tr>
						}
					</tbody>
				</table>
			}
		</div>
	}
</div>

@code {
	[SupplyParameterFromQuery]
	public int? SurveySectionId { get; set; }

	[SupplyParameterFromQuery]
	public int? SurveyVersionId { get; set; }

	[SupplyParameterFromQuery]
	public int? SurveyDefinitionId { get; set; }

	private IReadOnlyList<SurveyQuestionListItem> _items = Array.Empty<SurveyQuestionListItem>();

	protected override async Task OnParametersSetAsync()
	{
		_items = SurveySectionId.HasValue
			? await AdministrationService.GetSurveyQuestionsAsync(SurveySectionId.Value)
			: Array.Empty<SurveyQuestionListItem>();
	}

	private string GetAddUrl()
	{
		var surveySectionId = SurveySectionId ?? 0;
		var surveyVersionId = SurveyVersionId ?? 0;
		if (SurveyDefinitionId.HasValue)
		{
			return $"admin/questions/new?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&surveyDefinitionId={SurveyDefinitionId.Value}";
		}

		return SurveyVersionId.HasValue
			? $"admin/questions/new?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}"
			: $"admin/questions/new?surveySectionId={surveySectionId}";
	}

	private string GetSectionsUrl()
	{
		var surveyVersionId = SurveyVersionId ?? 0;
		return SurveyDefinitionId.HasValue
			? $"admin/sections?surveyVersionId={surveyVersionId}&surveyDefinitionId={SurveyDefinitionId.Value}"
			: $"admin/sections?surveyVersionId={surveyVersionId}";
	}

	private string GetOptionsUrl(int surveyQuestionId)
	{
		var surveySectionId = SurveySectionId ?? 0;
		var surveyVersionId = SurveyVersionId ?? 0;
		return SurveyDefinitionId.HasValue
			? $"admin/options?surveyQuestionId={surveyQuestionId}&surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&surveyDefinitionId={SurveyDefinitionId.Value}"
			: $"admin/options?surveyQuestionId={surveyQuestionId}&surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}";
	}

	private string GetEditUrl(int surveyQuestionId)
	{
		var surveySectionId = SurveySectionId ?? 0;
		var surveyVersionId = SurveyVersionId ?? 0;
		return SurveyDefinitionId.HasValue
			? $"admin/questions/{surveyQuestionId}/edit?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&surveyDefinitionId={SurveyDefinitionId.Value}"
			: $"admin/questions/{surveyQuestionId}/edit?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}";
	}

	private static bool SupportsOptions(SurveyQuestionType questionType)
	{
		return questionType is SurveyQuestionType.SingleChoice or SurveyQuestionType.MultiSelect;
	}
}
