@page "/admin/questions/new"
@page "/admin/questions/{Id:int}/edit"
@attribute [Authorize(Roles = RoleNames.Admin)]
@inject ISurveyAdministrationService AdministrationService
@inject NavigationManager NavigationManager

<PageTitle>@(Id.HasValue ? "Edit Question" : "Add Question")</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Survey Question</p>
			<h1>@(Id.HasValue ? "Edit Question" : "Add Question")</h1>
			<p>Question options are managed on a separate page for choice-based questions.</p>
		</div>
	</div>

	<div class="form-card narrow-card">
		@if (_model.IsLocked)
		{
			<div class="inline-banner mb-3">This question belongs to a locked survey version.</div>
		}

		@if (!string.IsNullOrWhiteSpace(_errorMessage))
		{
			<div class="inline-banner inline-banner--danger mb-3">@_errorMessage</div>
		}

		<EditForm Model="_model" OnValidSubmit="SaveAsync">
			<DataAnnotationsValidator />
			<div class="form-grid form-grid--single">
				<div class="field-stack">
					<label>Section</label>
					<InputSelect class="form-select" @bind-Value="_model.SurveySectionId" disabled="@_model.Id.HasValue">
						@foreach (var option in _model.SurveySectionOptions)
						{
							<option value="@option.Value">@option.Label</option>
						}
					</InputSelect>
				</div>
				<div class="field-stack">
					<label>Prompt</label>
					<InputTextArea class="form-control" rows="4" @bind-Value="_model.Prompt" disabled="@_model.IsLocked" />
					<ValidationMessage For="@(() => _model.Prompt)" />
				</div>
				<div class="field-stack">
					<label>Help Text</label>
					<InputTextArea class="form-control" rows="3" @bind-Value="_model.HelpText" disabled="@_model.IsLocked" />
				</div>
				<div class="field-stack">
					<label>Type</label>
					<InputSelect class="form-select" @bind-Value="_model.Type" disabled="@_model.IsLocked">
						@foreach (var questionType in Enum.GetValues<SurveyQuestionType>())
						{
							<option value="@questionType">@questionType</option>
						}
					</InputSelect>
				</div>
				<div class="field-stack">
					<label>Required</label>
					<InputCheckbox class="form-check-input" @bind-Value="_model.IsRequired" disabled="@_model.IsLocked" />
				</div>
				<div class="field-stack">
					<label>Sort Order</label>
					<InputNumber class="form-control" @bind-Value="_model.SortOrder" disabled="@_model.IsLocked" />
				</div>
			</div>

			<div class="form-footer">
				<button class="btn btn-primary" type="submit" disabled="@_model.IsLocked">Save Question</button>
				@if (_model.Id.HasValue && SupportsOptions())
				{
					<a class="btn btn-outline-primary" href="@GetOptionsUrl(_model.Id.Value)">Manage Options</a>
				}
				<a class="btn btn-outline-primary" href="@GetQuestionsUrl()">Back to Questions</a>
			</div>
		</EditForm>
	</div>
</div>

@code {
	[Parameter]
	public int? Id { get; set; }

	[SupplyParameterFromQuery]
	public int? SurveySectionId { get; set; }

	[SupplyParameterFromQuery]
	public int? SurveyVersionId { get; set; }

	[SupplyParameterFromQuery]
	public int? SurveyDefinitionId { get; set; }

	private SurveyQuestionEditModel _model = new();
	private string? _errorMessage;

	protected override async Task OnParametersSetAsync()
	{
		_model = await AdministrationService.GetSurveyQuestionAsync(Id, SurveySectionId);
		_errorMessage = null;
	}

	private async Task SaveAsync()
	{
		try
		{
			var savedId = await AdministrationService.SaveSurveyQuestionAsync(_model);
			if (SupportsOptions())
			{
				NavigationManager.NavigateTo(GetOptionsUrl(savedId));
			}
			else
			{
				NavigationManager.NavigateTo(GetQuestionsUrl());
			}
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
	}

	private bool SupportsOptions()
	{
		return _model.Type is SurveyQuestionType.SingleChoice or SurveyQuestionType.MultiSelect;
	}

	private string GetQuestionsUrl()
	{
		var surveySectionId = _model.SurveySectionId > 0 ? _model.SurveySectionId : SurveySectionId ?? 0;
		var surveyVersionId = _model.SurveyVersionId > 0 ? _model.SurveyVersionId : SurveyVersionId ?? 0;
		var surveyDefinitionId = _model.SurveyDefinitionId > 0 ? _model.SurveyDefinitionId : SurveyDefinitionId ?? 0;
		return surveyDefinitionId > 0
			? $"admin/questions?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&surveyDefinitionId={surveyDefinitionId}"
			: $"admin/questions?surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}";
	}

	private string GetOptionsUrl(int surveyQuestionId)
	{
		var surveySectionId = _model.SurveySectionId > 0 ? _model.SurveySectionId : SurveySectionId ?? 0;
		var surveyVersionId = _model.SurveyVersionId > 0 ? _model.SurveyVersionId : SurveyVersionId ?? 0;
		var surveyDefinitionId = _model.SurveyDefinitionId > 0 ? _model.SurveyDefinitionId : SurveyDefinitionId ?? 0;
		return surveyDefinitionId > 0
			? $"admin/options?surveyQuestionId={surveyQuestionId}&surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}&surveyDefinitionId={surveyDefinitionId}"
			: $"admin/options?surveyQuestionId={surveyQuestionId}&surveySectionId={surveySectionId}&surveyVersionId={surveyVersionId}";
	}
}
