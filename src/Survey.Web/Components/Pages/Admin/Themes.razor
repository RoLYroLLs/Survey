@page "/admin/themes"
@attribute [PlatformAuthorize(PlatformPermissionKeys.SettingsManage)]
@inject IPlatformAdministrationService AdministrationService
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>Themes</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Platform Settings</p>
			<h1>Themes</h1>
			<p>Create and manage the global theme library that tenant owners can choose from.</p>
		</div>
		<div class="toolbar">
			<a class="btn btn-outline-primary" href="/admin/theme/radius-preview">View Radius Preview</a>
			<a class="btn btn-primary" href="/admin/themes/new">Add Theme</a>
		</div>
	</div>

	<div class="list-card">
		@if (!string.IsNullOrWhiteSpace(_errorMessage))
		{
			<div class="inline-banner inline-banner--danger mb-3">@_errorMessage</div>
		}

		<div class="page-header">
			<div>
				<h2>Global Themes</h2>
				<p>Search by theme name, key, or description.</p>
			</div>
			<div class="toolbar">
				<input class="form-control" placeholder="Search themes" @bind="_searchText" />
				<button class="btn btn-outline-primary" type="button" @onclick="ApplySearch">Search</button>
				<button class="btn btn-outline-primary" type="button" @onclick="ClearSearch">Clear</button>
			</div>
		</div>

		@if (_items.Count == 0)
		{
			<p class="empty-state">No global themes matched the current search.</p>
		}
		else
		{
			<table class="admin-table">
				<thead>
					<tr>
						<th><SortableHeader Label="Name" SortKey="name" CurrentSort="@Sort" Href="@GetSortUrl("name")" /></th>
						<th><SortableHeader Label="Key" SortKey="key" CurrentSort="@Sort" Href="@GetSortUrl("key")" /></th>
						<th>Description</th>
						<th><SortableHeader Label="Status" SortKey="status" CurrentSort="@Sort" Href="@GetSortUrl("status")" /></th>
						<th>Preview</th>
						<th><SortableHeader Label="Updated" SortKey="updated" CurrentSort="@Sort" Href="@GetSortUrl("updated")" /></th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in _items)
					{
						<tr>
							<td>@item.Name</td>
							<td><code>@item.Key</code></td>
							<td>@item.Description</td>
							<td>
								<span class="@GetStatusCssClass(item)">@GetStatusLabel(item)</span>
							</td>
							<td>
								<span class="theme-preset-card__swatch" style="@BuildPreviewStyle(item)"></span>
							</td>
							<td>@item.UpdatedUtc.LocalDateTime.ToString("g")</td>
							<td>
								<div class="table-actions">
									<a class="btn btn-sm btn-outline-primary" href="/admin/themes/@item.Id">Edit</a>
									@if (item.IsArchived)
									{
										<button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => RestoreAsync(item.Id)">Restore</button>
									}
									else if (item.IsEnabled)
									{
										<button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => DisableAsync(item.Id)">Disable</button>
										<button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => ArchiveAsync(item.Id)">Archive</button>
									}
									else
									{
										<button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => EnableAsync(item.Id)">Enable</button>
										<button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => ArchiveAsync(item.Id)">Archive</button>
									}
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}

		<ListPager ShownCount="_items.Count"
				   TotalCount="_totalCount"
				   PageSize="_pageSize"
				   HasMore="_hasMore"
				   IsLoadingMore="_isLoadingMore"
				   PageSizeOptions="ListPagingDefaults.PageSizeOptions"
				   PageSizeChanged="OnPageSizeChangedAsync"
				   OnLoadMore="LoadMoreAsync" />
	</div>
</div>

@code {
	[SupplyParameterFromQuery]
	public string? Search { get; set; }

	[SupplyParameterFromQuery(Name = "pageSize")]
	public int? PageSize { get; set; }

	[SupplyParameterFromQuery(Name = "sort")]
	public string? Sort { get; set; }

	private IReadOnlyList<PlatformThemeListItem> _items = Array.Empty<PlatformThemeListItem>();
	private string _searchText = string.Empty;
	private int _pageSize = PagedQuery.DefaultLimit;
	private int _totalCount;
	private bool _hasMore;
	private bool _isLoadingMore;
	private string? _errorMessage;

	protected override async Task OnParametersSetAsync()
	{
		_searchText = Search ?? string.Empty;
		_pageSize = ListPagingDefaults.NormalizePageSize(PageSize);
		_errorMessage = null;
		await LoadAsync();
	}

	private void ApplySearch()
	{
		NavigationManager.NavigateTo(BuildUrl(_searchText, _pageSize, Sort));
	}

	private void ClearSearch()
	{
		_searchText = string.Empty;
		NavigationManager.NavigateTo(BuildUrl(null, _pageSize, Sort));
	}

	private async Task LoadAsync(bool append = false)
	{
		var result = await AdministrationService.GetPlatformThemesAsync(
			ListPagingDefaults.CreateRequest(_pageSize, append ? _items.Count : 0, Sort),
			Search);
		_items = append ? _items.Concat(result.Items).ToArray() : result.Items;
		_totalCount = result.TotalCount;
		_hasMore = result.HasMore;
	}

	private async Task LoadMoreAsync()
	{
		_isLoadingMore = true;
		try
		{
			await LoadAsync(append: true);
		}
		finally
		{
			_isLoadingMore = false;
		}
	}

	private Task OnPageSizeChangedAsync(int pageSize)
	{
		NavigationManager.NavigateTo(BuildUrl(Search, pageSize, Sort));
		return Task.CompletedTask;
	}

	private string GetSortUrl(string key)
	{
		return BuildUrl(Search, _pageSize, PagingSort.Toggle(Sort, key));
	}

	private static string BuildPreviewStyle(PlatformThemeListItem item)
	{
		return $"background: linear-gradient(135deg, {item.PrimaryColor}, {item.AccentColor});";
	}

	private async Task EnableAsync(int id)
	{
		await ExecuteThemeActionAsync(
			() => AdministrationService.SetPlatformThemeEnabledAsync(id, true),
			"Theme enabled successfully.");
	}

	private async Task DisableAsync(int id)
	{
		await ExecuteThemeActionAsync(
			() => AdministrationService.SetPlatformThemeEnabledAsync(id, false),
			"Theme disabled successfully.");
	}

	private async Task ArchiveAsync(int id)
	{
		await ExecuteThemeActionAsync(
			() => AdministrationService.SetPlatformThemeArchivedAsync(id, true),
			"Theme archived successfully.");
	}

	private async Task RestoreAsync(int id)
	{
		await ExecuteThemeActionAsync(
			() => AdministrationService.SetPlatformThemeArchivedAsync(id, false),
			"Theme restored successfully.");
	}

	private async Task ExecuteThemeActionAsync(Func<Task> action, string successMessage)
	{
		try
		{
			await action();
			_errorMessage = null;
			ToastService.ShowSuccess(successMessage, "Theme updated");
			await LoadAsync();
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
			ToastService.ShowError(ex.Message, "Theme update failed");
		}
	}

	private static string GetStatusLabel(PlatformThemeListItem item)
	{
		if (item.IsArchived)
		{
			return "Archived";
		}

		return item.IsEnabled ? "Active" : "Disabled";
	}

	private static string GetStatusCssClass(PlatformThemeListItem item)
	{
		if (item.IsArchived)
		{
			return "status-pill status-pill--danger";
		}

		return item.IsEnabled ? "status-pill" : "status-pill status-pill--muted";
	}

	private static string BuildUrl(string? search, int pageSize, string? sort)
	{
		var queryParts = new List<string>
		{
			$"pageSize={pageSize}"
		};
		if (!string.IsNullOrWhiteSpace(search))
		{
			queryParts.Add($"search={Uri.EscapeDataString(search)}");
		}
		if (!string.IsNullOrWhiteSpace(sort))
		{
			queryParts.Add($"sort={Uri.EscapeDataString(sort)}");
		}

		return $"/admin/themes?{string.Join("&", queryParts)}";
	}
}
