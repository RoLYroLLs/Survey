@page "/admin"
@attribute [PlatformAuthorize]
@inject Microsoft.Extensions.Options.IOptions<global::Survey.Infrastructure.Configuration.BackgroundJobsOptions> BackgroundJobsOptionsAccessor

<PageTitle>Admin</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Platform</p>
			<h1>Admin</h1>
			<p>Manage platform users, tenant oversight, audit trails, and shared reference data.</p>
		</div>
	</div>

	<div class="card-grid">
		<AuthorizeView Policy="@SurveyAuthorizationPolicies.PlatformPermission(PlatformPermissionKeys.UsersView)">
			<Authorized>
				<section class="content-card">
					<h2>Users</h2>
					<p>Manage platform-level user access and administration.</p>
					<a class="btn btn-outline-primary" href="/admin/users">Open Users</a>
				</section>
			</Authorized>
		</AuthorizeView>
		<AuthorizeView Policy="@SurveyAuthorizationPolicies.PlatformPermission(PlatformPermissionKeys.TenantsView)">
			<Authorized>
				<section class="content-card">
					<h2>Tenants</h2>
					<p>Review tenant directories, membership counts, and tenant-wide usage.</p>
					<div class="toolbar">
						<a class="btn btn-outline-primary" href="/admin/tenants">Open Tenants</a>
						<AuthorizeView Policy="@SurveyAuthorizationPolicies.PlatformPermission(PlatformPermissionKeys.TenantsManage)">
							<Authorized Context="tenantCreateAccess">
								<a class="btn btn-outline-primary" href="/admin/tenants/new">Create Tenant</a>
							</Authorized>
						</AuthorizeView>
					</div>
				</section>
			</Authorized>
		</AuthorizeView>
		<AuthorizeView Policy="@SurveyAuthorizationPolicies.PlatformPermission(PlatformPermissionKeys.AuditView)">
			<Authorized>
				<section class="content-card">
					<h2>Audit</h2>
					<p>Review platform and tenant security-sensitive activity and denied access attempts.</p>
					<a class="btn btn-outline-primary" href="/admin/audit">Open Audit</a>
				</section>
			</Authorized>
		</AuthorizeView>
		<AuthorizeView Policy="@SurveyAuthorizationPolicies.PlatformPermission(PlatformPermissionKeys.JobsView)">
			<Authorized>
				<section class="content-card">
					<h2>Jobs</h2>
					<p>Review durable background operations for setup seeding and queued email dispatch.</p>
					<div class="toolbar">
						<a class="btn btn-outline-primary" href="/admin/jobs">Open Jobs</a>
						<a class="btn btn-outline-primary" href="/admin/emails">Open Emails</a>
						<AuthorizeView Policy="@SurveyAuthorizationPolicies.PlatformPermission(PlatformPermissionKeys.JobsManage)">
							<Authorized Context="jobsManageAccess">
								@if (BackgroundJobsOptionsAccessor.Value.Enabled)
								{
									<a class="btn btn-outline-primary" href="@BackgroundJobsOptionsAccessor.Value.DashboardPath">Open Hangfire</a>
								}
							</Authorized>
						</AuthorizeView>
					</div>
				</section>
			</Authorized>
		</AuthorizeView>
		<AuthorizeView Policy="@SurveyAuthorizationPolicies.PlatformPermission(PlatformPermissionKeys.SettingsManage)">
			<Authorized>
				<section class="content-card">
					<h2>Themes</h2>
					<p>Manage the global theme library that controls tenant-facing app appearance.</p>
					<a class="btn btn-outline-primary" href="/admin/themes">Open Themes</a>
				</section>
			</Authorized>
		</AuthorizeView>
		<AuthorizeView Policy="@SurveyAuthorizationPolicies.PlatformPermission(PlatformPermissionKeys.GeographyView)">
			<Authorized>
				<section class="content-card">
					<h2>Countries</h2>
					<p>Maintain the global geography reference catalog.</p>
					<a class="btn btn-outline-primary" href="/admin/countries">Open Countries</a>
				</section>
				<section class="content-card">
					<h2>States / Territories</h2>
					<p>Review and manage state and territory reference records.</p>
					<a class="btn btn-outline-primary" href="/admin/state-provinces">Open States / Territories</a>
				</section>
				<section class="content-card">
					<h2>Counties</h2>
					<p>Manage county reference records and their platform imports.</p>
					<a class="btn btn-outline-primary" href="/admin/counties">Open Counties</a>
				</section>
				<section class="content-card">
					<h2>Addresses</h2>
					<p>Review shared address records and cross-reference usage.</p>
					<a class="btn btn-outline-primary" href="/admin/addresses">Open Addresses</a>
				</section>
				<section class="content-card">
					<h2>ZIP Mappings</h2>
					<p>Maintain ZIP-to-county mapping data used by reporting and area grouping.</p>
					<a class="btn btn-outline-primary" href="/admin/zip-mappings">Open ZIP Mappings</a>
				</section>
			</Authorized>
		</AuthorizeView>
	</div>
</div>
