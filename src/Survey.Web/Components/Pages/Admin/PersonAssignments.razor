@page "/admin/people/{PersonId:int}/assignments"
@attribute [Authorize(Roles = RoleNames.Admin)]
@inject ISurveyAdministrationService AdministrationService
@inject NavigationManager NavigationManager
@using Microsoft.AspNetCore.Components

<PageTitle>Person Assignments</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Recipient Assignments</p>
			<h1>@(ShowArchived ? $"Archived Assignments for {_personName}" : $"Assignments for {_personName}")</h1>
			<p>@(ShowArchived
				? "View this person's archived assignments across all saved locations."
				: "View this person's assignments across all saved locations.")</p>
		</div>
		<div class="toolbar">
			<div class="field-stack mb-0">
				<label>Status</label>
				<SearchableSelect class="form-select"
								  @bind-Value="Status"
								  AfterValueChanged="OnStatusChangedAsync"
								  Options="_statusOptions"
								  IncludeEmptyOption="true"
								  EmptyOptionLabel="All" />
			</div>
			<a class="btn btn-outline-primary" href="@GetArchivedUrl()">Archived Assignments</a>
			<a class="btn btn-outline-primary" href="/admin/people/@PersonId">Back to Person</a>
			<a class="btn btn-outline-primary" href="@GetAllAssignmentsUrl()">View All Assignments</a>
		</div>
	</div>

	<div class="list-card">
		@if (_items.Count == 0)
		{
			<p class="empty-state">This person does not have any assignments yet.</p>
		}
		else
		{
			<table class="admin-table">
				<thead>
					<tr>
						<th>Location</th>
						<th>Survey</th>
						<th>Expires</th>
						<th>Archived</th>
						<th>Status</th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in _items)
					{
						<tr>
							<td>@item.LocationName</td>
							<td>@item.SurveyName<br /><small>@item.VersionName</small></td>
							<td>@(item.ExpiresAtUtc?.LocalDateTime.ToString("g") ?? "Never")</td>
							<td>@(item.IsArchived ? "Yes" : "No")</td>
							<td>
								@if (item.IsCompleted)
								{
									<span class="status-pill status-pill--muted">Completed</span>
								}
								else if (item.IsArchived)
								{
									<span class="status-pill status-pill--muted">Archived</span>
								}
								else if (item.IsExpired)
								{
									<span class="status-pill status-pill--danger">Expired</span>
								}
								else
								{
									<span class="status-pill">Active</span>
								}
							</td>
							<td>
								<div class="table-actions">
									<a class="btn btn-sm btn-outline-primary" href="@GetAssignmentUrl(item.Id)">View</a>
									@if (item.IsFillable)
									{
										<a class="btn btn-sm btn-outline-primary" href="/admin/assignments/@item.Id/fill">Fill</a>
									}
									else
									{
										<button class="btn btn-sm btn-muted-disabled" type="button" disabled>Fill</button>
									}
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}
	</div>
</div>

@code {
	[Parameter]
	public int PersonId { get; set; }

	[SupplyParameterFromQuery]
	public bool ShowArchived { get; set; }

	[SupplyParameterFromQuery(Name = "status")]
	public string? Status { get; set; }

	private IReadOnlyList<SurveyAssignmentListItem> _items = Array.Empty<SurveyAssignmentListItem>();
	private string _personName = "Person";
	private static readonly IReadOnlyList<SelectOption> _statusOptions =
	[
		new() { Value = "active", Label = "Active" },
		new() { Value = "completed", Label = "Completed" },
		new() { Value = "expired", Label = "Expired" }
	];

	protected override async Task OnParametersSetAsync()
	{
		var person = await AdministrationService.GetPersonAsync(PersonId);
		_personName = string.Join(" ", new[] { person.FirstName, person.MiddleName, person.LastName }.Where(part => !string.IsNullOrWhiteSpace(part)));
		_items = await AdministrationService.GetAssignmentsAsync(PersonId, ShowArchived, Status);
	}

	private string GetAssignmentUrl(int assignmentId)
	{
		var queryParts = new List<string> { $"personId={PersonId}" };
		if (ShowArchived)
		{
			queryParts.Add("showArchived=true");
		}

		if (!string.IsNullOrWhiteSpace(Status))
		{
			queryParts.Add($"status={Uri.EscapeDataString(Status)}");
		}

		return $"/admin/assignments/{assignmentId}?{string.Join("&", queryParts)}";
	}

	private string GetArchivedUrl()
	{
		return ShowArchived
			? BuildAssignmentsUrl(false, Status)
			: BuildAssignmentsUrl(true, Status);
	}

	private string GetAllAssignmentsUrl()
	{
		var queryParts = new List<string>();
		if (ShowArchived)
		{
			queryParts.Add("showArchived=true");
		}

		if (!string.IsNullOrWhiteSpace(Status))
		{
			queryParts.Add($"status={Uri.EscapeDataString(Status)}");
		}

		return queryParts.Count == 0
			? "/admin/assignments"
			: $"/admin/assignments?{string.Join("&", queryParts)}";
	}

	private Task OnStatusChangedAsync()
	{
		NavigationManager.NavigateTo(BuildAssignmentsUrl(ShowArchived, Status));
		return Task.CompletedTask;
	}

	private string BuildAssignmentsUrl(bool showArchived, string? status)
	{
		var queryParts = new List<string>();
		if (showArchived)
		{
			queryParts.Add("showArchived=true");
		}

		if (!string.IsNullOrWhiteSpace(status))
		{
			queryParts.Add($"status={Uri.EscapeDataString(status)}");
		}

		return queryParts.Count == 0
			? $"/admin/people/{PersonId}/assignments"
			: $"/admin/people/{PersonId}/assignments?{string.Join("&", queryParts)}";
	}
}
