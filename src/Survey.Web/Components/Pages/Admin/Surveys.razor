@page "/admin/surveys"
@attribute [Authorize(Roles = RoleNames.Admin)]
@inject ISurveyAdministrationService AdministrationService

<PageTitle>Surveys</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Survey Definitions</p>
			<h1>@(ShowArchived ? "Archived Surveys" : "Surveys")</h1>
			<p>@(ShowArchived
				? "Archived surveys stay available for reference and can be restored when needed."
				: "Each survey can have multiple immutable versions once assignments begin.")</p>
		</div>
		<div class="toolbar">
			<a class="btn btn-outline-primary" href="@GetActiveUrl()">Active Surveys</a>
			<a class="btn btn-outline-primary" href="@GetArchivedUrl()">Archived Surveys</a>
			@if (!ShowArchived)
			{
				<a class="btn btn-primary" href="admin/surveys/new">Add Survey</a>
			}
		</div>
	</div>

	<div class="list-card">
		@if (_items.Count == 0)
		{
			<p class="empty-state">No surveys have been created yet.</p>
		}
		else
		{
			<table class="admin-table">
				<thead>
					<tr>
						<th>Name</th>
						<th>Description</th>
						<th>Versions</th>
						<th>Archived</th>
						<th>Updated</th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in _items)
					{
						<tr>
							<td>@item.Name</td>
							<td>@item.Description</td>
							<td>@item.VersionCount</td>
							<td>@(item.IsArchived ? "Yes" : "No")</td>
							<td>@item.UpdatedUtc.LocalDateTime.ToString("g")</td>
							<td>
								<div class="table-actions">
									<a class="btn btn-sm btn-outline-primary" href="@($"admin/surveys/{item.Id}?showArchived={ShowArchived.ToString().ToLowerInvariant()}")">View</a>
									<a class="btn btn-sm btn-outline-primary" href="@($"admin/versions?surveyDefinitionId={item.Id}&showArchived={ShowArchived.ToString().ToLowerInvariant()}")">Versions</a>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}
	</div>
</div>

@code {
	[SupplyParameterFromQuery]
	public bool ShowArchived { get; set; }

	private IReadOnlyList<SurveyDefinitionListItem> _items = Array.Empty<SurveyDefinitionListItem>();

	protected override async Task OnParametersSetAsync()
	{
		_items = await AdministrationService.GetSurveyDefinitionsAsync(ShowArchived);
	}

	private static string GetActiveUrl()
	{
		return "admin/surveys";
	}

	private static string GetArchivedUrl()
	{
		return "admin/surveys?showArchived=true";
	}
}
