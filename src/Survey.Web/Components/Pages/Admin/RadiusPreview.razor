@page "/admin/theme/radius-preview"
@attribute [PlatformAuthorize(PlatformPermissionKeys.GeographyView)]

<PageTitle>Radius Preview</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Settings</p>
			<h1>Radius Preview</h1>
			<p>View the shared UI pieces that currently use their own corner radius values.</p>
		</div>
		<div class="toolbar">
			<a class="btn btn-outline-primary" href="/app/theme">Back to Theme</a>
		</div>
	</div>

	<section class="list-card">
		<div class="page-header">
			<div>
				<h2>Cards</h2>
				<p>Preview the main card surfaces used throughout the app shell.</p>
			</div>
		</div>
		<div class="card-grid">
			<div class="hero-card radius-preview-card">
				<p class="radius-preview-code">.hero-card</p>
				<h2>Hero Card</h2>
				<p class="helper-copy">Large intro surface.</p>
			</div>
			<div class="content-card radius-preview-card">
				<p class="radius-preview-code">.content-card</p>
				<h2 class="content-card__title-sm">Content Card</h2>
				<p class="helper-copy">Standard content section.</p>
			</div>
			<div class="list-card radius-preview-card">
				<p class="radius-preview-code">.list-card</p>
				<h2 class="content-card__title-sm">List Card</h2>
				<p class="helper-copy">Used for tables and lists.</p>
			</div>
			<div class="form-card radius-preview-card">
				<p class="radius-preview-code">.form-card</p>
				<h2 class="content-card__title-sm">Form Card</h2>
				<p class="helper-copy">Used for edit and view forms.</p>
			</div>
			<div class="status-card radius-preview-card">
				<p class="radius-preview-code">.status-card</p>
				<h2 class="content-card__title-sm">Status Card</h2>
				<p class="helper-copy">Used for summaries and callouts.</p>
			</div>
			<div class="metric-card radius-preview-card">
				<p class="radius-preview-code">.metric-card</p>
				<p class="metric-card__label">Metric Card</p>
				<p class="metric-card__value">42</p>
			</div>
		</div>
	</section>

	<section class="list-card">
		<div class="page-header">
			<div>
				<h2>Forms</h2>
				<p>Preview shared input and form-related radii.</p>
			</div>
		</div>
		<div class="card-grid">
			<div class="content-card radius-preview-card">
				<p class="radius-preview-code">.form-control / .form-select</p>
				<div class="page-stack">
					<input class="form-control" value="Text input" />
					<SearchableSelect class="form-select"
									  @bind-Value="_previewSelectValue"
									  Options="_previewSelectOptions" />
					<textarea class="form-control" rows="3">Textarea field</textarea>
				</div>
			</div>
			<div class="content-card radius-preview-card">
				<p class="radius-preview-code">.secret-input__toggle:focus-visible</p>
				<div class="secret-input">
					<input class="form-control" value="Secret field" />
					<button class="secret-input__toggle" type="button" aria-label="Toggle secret">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"></path>
							<circle cx="12" cy="12" r="3"></circle>
						</svg>
					</button>
				</div>
				<p class="helper-copy">The focus ring pill is on the toggle button.</p>
			</div>
		</div>
	</section>

	<section class="list-card">
		<div class="page-header">
			<div>
				<h2>Pills And Alerts</h2>
				<p>Preview the small pill and banner surfaces.</p>
			</div>
		</div>
		<div class="card-grid">
			<div class="content-card radius-preview-card">
				<p class="radius-preview-code">.status-pill</p>
				<div class="toolbar">
					<span class="status-pill">Active</span>
					<span class="status-pill status-pill--muted">Completed</span>
					<span class="status-pill status-pill--danger">Expired</span>
				</div>
			</div>
			<div class="content-card radius-preview-card">
				<p class="radius-preview-code">.alert</p>
				<div class="page-stack">
					<div class="alert alert-success" role="alert">Success alert</div>
					<div class="alert alert-warning" role="alert">Warning alert</div>
					<div class="alert alert-danger" role="alert">Error alert</div>
				</div>
			</div>
			<div class="content-card radius-preview-card">
				<p class="radius-preview-code">.inline-banner</p>
				<div class="page-stack">
					<div class="inline-banner">Standard inline banner</div>
					<div class="inline-banner inline-banner--danger">Danger inline banner</div>
				</div>
			</div>
			<div class="content-card radius-preview-card">
				<p class="radius-preview-code">.detail-chip</p>
				<div class="detail-chip-list">
					<div class="detail-chip">Miami-Dade, FL</div>
					<div class="detail-chip">Broward, FL</div>
					<div class="detail-chip">Palm Beach, FL</div>
				</div>
			</div>
		</div>
	</section>

	<section class="list-card">
		<div class="page-header">
			<div>
				<h2>Survey UI</h2>
				<p>Preview the survey-specific rounded elements.</p>
			</div>
		</div>
		<div class="card-grid">
			<div class="content-card radius-preview-card">
				<p class="radius-preview-code">.survey-stepper__item</p>
				<div class="survey-stepper">
					<span class="survey-stepper__item active">Contact</span>
					<span class="survey-stepper__item">Questions</span>
					<span class="survey-stepper__item">Review</span>
				</div>
			</div>
			<div class="content-card radius-preview-card">
				<p class="radius-preview-code">.question-card</p>
				<div class="question-card">
					<p class="question-card__prompt">How satisfied are you?</p>
					<p class="question-card__help">Choose one option below.</p>
					<div class="option-stack">
						<label class="option-row"><input type="radio" name="preview-question" /> Yes</label>
						<label class="option-row"><input type="radio" name="preview-question" /> No</label>
					</div>
				</div>
			</div>
			<div class="content-card radius-preview-card">
				<p class="radius-preview-code">.checkbox-card</p>
				<label class="checkbox-card">
					<input type="checkbox" checked />
					<span>Palm Beach, FL</span>
					<small>29 ZIPs</small>
				</label>
			</div>
		</div>
	</section>

	<section class="list-card">
		<div class="page-header">
			<div>
				<h2>Toasts</h2>
				<p>Preview the toast shell and its icon and close button radii.</p>
			</div>
		</div>
		<div class="toast-preview-stack">
			<div class="toast-notification toast-notification--success toast-notification--preview" role="status">
				<div class="toast-notification__accent" aria-hidden="true"></div>
				<div class="toast-notification__icon" aria-hidden="true">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="9"></circle>
						<path d="M8.5 12.5 11 15l4.5-5"></path>
					</svg>
				</div>
				<div class="toast-notification__content">
					<strong>Saved</strong>
					<span>Location saved successfully.</span>
				</div>
				<button class="toast-notification__close" type="button" aria-label="Close notification">&times;</button>
			</div>
			<div class="toast-notification toast-notification--warning toast-notification--preview" role="status">
				<div class="toast-notification__accent" aria-hidden="true"></div>
				<div class="toast-notification__icon" aria-hidden="true">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="9"></circle>
						<path d="M12 7.5v5.5"></path>
						<path d="M12 16.5h.01"></path>
					</svg>
				</div>
				<div class="toast-notification__content">
					<strong>Warning</strong>
					<span>Please review the highlighted field.</span>
				</div>
				<button class="toast-notification__close" type="button" aria-label="Close notification">&times;</button>
			</div>
			<div class="toast-notification toast-notification--error toast-notification--preview" role="status">
				<div class="toast-notification__accent" aria-hidden="true"></div>
				<div class="toast-notification__icon" aria-hidden="true">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="9"></circle>
						<path d="m9 9 6 6"></path>
						<path d="m15 9-6 6"></path>
					</svg>
				</div>
				<div class="toast-notification__content">
					<strong>Error</strong>
					<span>An error occurred while saving changes.</span>
				</div>
				<button class="toast-notification__close" type="button" aria-label="Close notification">&times;</button>
			</div>
		</div>
	</section>

	<section class="list-card">
		<div class="page-header">
			<div>
				<h2>Theme Preset Cards</h2>
				<p>Preview the theme-selection card radii and chips.</p>
			</div>
		</div>
		<div class="theme-preset-grid">
			<button class="theme-preset-card theme-preset-card--selected" type="button">
				<div class="theme-preset-card__top">
					<div>
						<h3>Preview Theme</h3>
						<p>Sample preset card layout.</p>
					</div>
					<span class="theme-preset-card__indicator">Live</span>
				</div>
				<span class="theme-preset-card__swatch" style="background: linear-gradient(135deg, #0d8f81, #15394a);"></span>
				<div class="theme-preset-card__chips">
					<span class="theme-preset-card__chip">Primary #0d8f81</span>
					<span class="theme-preset-card__chip">Accent #15394a</span>
					<span class="theme-preset-card__chip">Background #eef4f2</span>
				</div>
			</button>
		</div>
	</section>
</div>

@code {
	private string _previewSelectValue = "dropdown";
	private static readonly IReadOnlyList<SelectOption> _previewSelectOptions =
	[
		new() { Value = "dropdown", Label = "Dropdown select" },
		new() { Value = "preview", Label = "Preview option" }
	];
}
