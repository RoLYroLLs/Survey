@page "/admin/responses"
@attribute [Authorize(Roles = RoleNames.Admin)]
@inject ISurveyAdministrationService AdministrationService

<PageTitle>Responses</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Submissions</p>
			<h1>Responses</h1>
			<p>Every response stores the submitted contact snapshot and the audit trail for self-service or employee-assisted completion.</p>
		</div>
	</div>

	<div class="list-card">
		@if (_items.Count == 0)
		{
			<p class="empty-state">No surveys have been submitted yet.</p>
		}
		else
		{
			<table class="admin-table">
				<thead>
					<tr>
						<th>Respondent</th>
						<th>ZIP / County</th>
						<th>Survey</th>
						<th>Submitted By</th>
						<th>Submitted</th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in _items)
					{
						<tr>
							<td>@item.RespondentName</td>
							<td>@item.PostalCode<br /><small>@item.CountyName</small></td>
							<td>@item.SurveyName<br /><small>@item.VersionName</small></td>
							<td>@item.SubmittedByLabel</td>
							<td>@item.SubmittedUtc.LocalDateTime.ToString("g")</td>
							<td>
								<div class="table-actions">
									<a class="btn btn-sm btn-outline-primary" href="admin/responses/@item.Id">View</a>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}
	</div>
</div>

@code {
	private IReadOnlyList<SurveyResponseListItem> _items = Array.Empty<SurveyResponseListItem>();

	protected override async Task OnInitializedAsync()
	{
		_items = await AdministrationService.GetResponsesAsync();
	}
}
