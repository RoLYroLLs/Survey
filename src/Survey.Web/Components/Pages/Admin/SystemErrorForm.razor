@page "/admin/system/errors/form"
@attribute [PlatformAuthorize(PlatformPermissionKeys.SettingsManage)]

<PageTitle>Form Error Preview</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">System Error</p>
			<h1>Form Error Preview</h1>
			<p>This shows the standard inline failure treatment used when a save or validation step fails inside a form.</p>
		</div>
	</div>

	<div class="system-preview-stage">
		<div class="form-card narrow-card">
			<div class="page-stack">
				<div>
					<p class="eyebrow">Preview Form</p>
					<h2>Section Details</h2>
				</div>
				<div class="inline-banner inline-banner--danger">We couldn't save your changes. The problem was logged automatically.</div>
				<div class="field-stack">
					<FieldLabel Text="Title" Required />
					<input class="form-control" value="Household Questions" />
				</div>
				<div class="field-stack">
					<FieldLabel Text="Sort Order" Required />
					<input class="form-control" value="3" />
				</div>
				<div class="form-footer">
					<button class="btn btn-primary" type="button">Save</button>
					<button class="btn btn-outline-primary" type="button">Cancel</button>
				</div>
			</div>
		</div>
	</div>
</div>
