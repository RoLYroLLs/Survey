@page "/admin/state-provinces/new"
@page "/admin/state-provinces/{Id:int}"
@page "/admin/state-provinces/{Id:int}/edit"
@implements IDisposable
@attribute [Authorize(Roles = RoleNames.Admin)]
@inject ISurveyAdministrationService AdministrationService
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>@GetPageTitle()</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Geography</p>
			<h1>@GetPageTitle()</h1>
			<p>View or update a state or territory record.</p>
		</div>
	</div>

	<div class="form-card narrow-card">
		@if (!string.IsNullOrWhiteSpace(_errorMessage))
		{
			<div class="inline-banner inline-banner--danger mb-3">@_errorMessage</div>
		}

		@if (IsViewMode)
		{
			<div class="page-stack">
				<div class="assignment-detail-list">
					<div class="assignment-detail-row">
						<strong>Country</strong>
						<span>@GetSelectedOptionLabel(_model.CountryOptions, _model.CountryId)</span>
					</div>
					<div class="assignment-detail-row">
						<strong>Name</strong>
						<span>@DisplayOrDash(_model.Name)</span>
					</div>
					<div class="assignment-detail-row">
						<strong>Code</strong>
						<span>@DisplayOrDash(_model.Code)</span>
					</div>
					<div class="assignment-detail-row">
						<strong>Type</strong>
						<span>@DisplayOrDash(_model.SubdivisionType)</span>
					</div>
				</div>

				<div class="form-footer">
					<a class="btn btn-primary" href="/admin/state-provinces/@Id/edit">Edit State / Territory</a>
					<a class="btn btn-outline-primary" href="admin/state-provinces">Back to States / Territories</a>
				</div>
			</div>
		}
		else
		{
			<EditForm Model="_model" OnValidSubmit="SaveAsync">
				<DataAnnotationsValidator />
				<div class="form-grid form-grid--single">
					<div class="field-stack">
						<FieldLabel Text="Country" Required />
						<SearchableSelect class="form-control"
										  @bind-Value="_model.CountryId"
										  Options="_model.CountryOptions"
										  IncludeEmptyOption="true"
										  EmptyOptionLabel="Select a country"
										  EmptyOptionValue="0" />
						<ValidationMessage For="@(() => _model.CountryId)" />
					</div>
					<div class="field-stack">
						<FieldLabel Text="Name" Required />
						<InputText class="form-control" @bind-Value="_model.Name" />
						<ValidationMessage For="@(() => _model.Name)" />
					</div>
					<div class="field-stack">
						<FieldLabel Text="Code" Required />
						<InputText class="form-control" @bind-Value="_model.Code" />
						<ValidationMessage For="@(() => _model.Code)" />
					</div>
					<div class="field-stack">
						<FieldLabel Text="Type" Required />
						<InputText class="form-control" @bind-Value="_model.SubdivisionType" />
						<ValidationMessage For="@(() => _model.SubdivisionType)" />
					</div>
				</div>

				<div class="form-footer">
					<button class="btn btn-primary" type="submit">Save State / Territory</button>
					<a class="btn btn-outline-primary" href="@(Id.HasValue ? $"/admin/state-provinces/{Id.Value}" : "admin/state-provinces")">Cancel</a>
				</div>
			</EditForm>
		}
	</div>
</div>

@code {
	[Parameter]
	public int? Id { get; set; }

	private StateProvinceEditModel _model = new();
	private string? _errorMessage;
	private bool IsViewMode => Id.HasValue && !NavigationManager.Uri.Contains("/edit", StringComparison.OrdinalIgnoreCase);

	protected override void OnInitialized()
	{
		NavigationManager.LocationChanged += OnLocationChanged;
	}

	protected override async Task OnParametersSetAsync()
	{
		_model = await AdministrationService.GetStateProvinceAsync(Id, null);
		_errorMessage = null;
	}

	private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
	{
		_ = InvokeAsync(StateHasChanged);
	}

	private async Task SaveAsync()
	{
		try
		{
			var savedId = await AdministrationService.SaveStateProvinceAsync(_model);
			_errorMessage = null;
			ToastService.ShowSuccess("State or territory saved successfully.", "Saved");
			NavigationManager.NavigateTo($"admin/state-provinces/{savedId}");
		}
		catch (Exception ex)
		{
			_errorMessage = null;
			ToastService.ShowError(ex.Message, "Save failed");
		}
	}

	private string GetPageTitle()
	{
		if (IsViewMode)
		{
			return "View State / Territory";
		}

		return Id.HasValue ? "Edit State / Territory" : "Add State / Territory";
	}

	private static string DisplayOrDash(string? value)
	{
		return string.IsNullOrWhiteSpace(value) ? "-" : value;
	}

	private static string GetSelectedOptionLabel(IEnumerable<SelectOption> options, int value)
	{
		return options.FirstOrDefault(option => option.Value == value.ToString())?.Label ?? "-";
	}

	public void Dispose()
	{
		NavigationManager.LocationChanged -= OnLocationChanged;
	}
}
