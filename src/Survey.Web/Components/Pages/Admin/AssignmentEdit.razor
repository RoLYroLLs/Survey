@page "/admin/assignments/new"
@page "/admin/assignments/{Id:int}/edit"
@attribute [Authorize(Roles = RoleNames.Admin)]
@inject ISurveyAdministrationService AdministrationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>@(Id.HasValue ? "Edit Assignment" : "Add Assignment")</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Survey Assignment</p>
			<h1>@(Id.HasValue ? "Edit Assignment" : "Add Assignment")</h1>
			<p>Assignments connect one person to one published survey version and generate the public survey URL.</p>
		</div>
	</div>

	<div class="form-card narrow-card">
		@if (_model.IsCompleted)
		{
			<div class="inline-banner mb-3">This assignment already has a completed response and can no longer be changed.</div>
		}

		@if (!string.IsNullOrWhiteSpace(_errorMessage))
		{
			<div class="inline-banner inline-banner--danger mb-3">@_errorMessage</div>
		}

		<EditForm Model="_model" OnValidSubmit="SaveAsync">
			<DataAnnotationsValidator />
			<div class="form-grid form-grid--single">
				<div class="field-stack">
					<label>Person</label>
					<InputSelect class="form-select" @bind-Value="_model.PersonId" disabled="@_model.Id.HasValue">
						@foreach (var option in _model.PersonOptions)
						{
							<option value="@option.Value">@option.Label</option>
						}
					</InputSelect>
				</div>
				<div class="field-stack">
					<label>Published Survey Version</label>
					<InputSelect class="form-select" @bind-Value="_model.SurveyVersionId" disabled="@_model.Id.HasValue">
						@foreach (var option in _model.SurveyVersionOptions)
						{
							<option value="@option.Value">@option.Label</option>
						}
					</InputSelect>
				</div>
				<div class="field-stack">
					<label>Public Token</label>
					<InputText class="form-control" @bind-Value="_model.PublicToken" disabled="@_model.IsCompleted" />
				</div>
				<div class="field-stack">
					<label>Expires (UTC)</label>
					<InputDate class="form-control" @bind-Value="_expiresDate" disabled="@_model.IsCompleted" />
				</div>
			</div>

			<div class="form-footer">
				<button class="btn btn-primary" type="submit" disabled="@_model.IsCompleted">Save Assignment</button>
				@if (_model.Id.HasValue)
				{
					<a class="btn btn-outline-primary" href="@($"/survey/{_model.PublicToken}")">Open Public Link</a>
				}
				<a class="btn btn-outline-primary" href="admin/assignments">Back to Assignments</a>
			</div>
		</EditForm>
	</div>
</div>

@code {
	[Parameter]
	public int? Id { get; set; }

	private SurveyAssignmentEditModel _model = new();
	private string? _errorMessage;
	private DateTime? _expiresDate;

	protected override async Task OnParametersSetAsync()
	{
		_model = await AdministrationService.GetAssignmentAsync(Id);
		_expiresDate = _model.ExpiresAtUtc?.UtcDateTime.Date;
		_errorMessage = null;
	}

	private async Task SaveAsync()
	{
		try
		{
			_model.ExpiresAtUtc = _expiresDate.HasValue
				? new DateTimeOffset(DateTime.SpecifyKind(_expiresDate.Value, DateTimeKind.Utc))
				: null;

			var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
			var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
			await AdministrationService.SaveAssignmentAsync(_model, userId);
			NavigationManager.NavigateTo("admin/assignments");
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
	}
}
