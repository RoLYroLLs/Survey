@page "/admin/state-provinces"
@attribute [PlatformAuthorize(PlatformPermissionKeys.GeographyView)]
@inject IPlatformAdministrationService AdministrationService
@inject NavigationManager NavigationManager

<PageTitle>States / Territories</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Geography</p>
			<h1>States / Territories</h1>
			<p>@(string.IsNullOrWhiteSpace(_filterLabel) ? "View the states and territories in the reference list." : $"Showing states and territories for {_filterLabel}.")</p>
		</div>
		<div class="toolbar">
			@if (CountryId.HasValue)
			{
				<a class="btn btn-outline-primary" href="admin/state-provinces">View All</a>
			}
			<a class="btn btn-outline-primary" href="/admin/import-samples/state-provinces">Download Sample Excel</a>
			<AuthorizeView Policy="@SurveyAuthorizationPolicies.PlatformPermission(PlatformPermissionKeys.GeographyManage)">
				<Authorized>
					<a class="btn btn-outline-primary" href="admin/state-provinces/import">Import CSV</a>
					<a class="btn btn-primary" href="admin/state-provinces/new">Add State / Territory</a>
				</Authorized>
			</AuthorizeView>
		</div>
	</div>

	<div class="list-card">
		<div class="page-header">
			<div>
				<h2>State / Territory Rows</h2>
				<p>Search by country, name, code, or subdivision type.</p>
			</div>
			<div class="toolbar">
				<input class="form-control" placeholder="Search states / territories" @bind="_searchText" />
				<button class="btn btn-outline-primary" type="button" @onclick="ApplySearch">Search</button>
				<button class="btn btn-outline-primary" type="button" @onclick="ClearSearch">Clear</button>
			</div>
		</div>

		@if (!_hasLoadedInitialState)
		{
			<p class="empty-state">Loading...</p>
		}
		else if (_items.Count == 0)
		{
			<p class="empty-state">No states or territories matched the current search.</p>
		}
		else
		{
			<table class="admin-table">
				<thead>
					<tr>
						<th><SortableHeader Label="Country" SortKey="country" CurrentSort="@Sort" Href="@GetSortUrl("country")" /></th>
						<th><SortableHeader Label="Name" SortKey="name" CurrentSort="@Sort" Href="@GetSortUrl("name")" /></th>
						<th><SortableHeader Label="Code" SortKey="code" CurrentSort="@Sort" Href="@GetSortUrl("code")" /></th>
						<th><SortableHeader Label="Type" SortKey="type" CurrentSort="@Sort" Href="@GetSortUrl("type")" /></th>
						<th><SortableHeader Label="Counties" SortKey="counties" CurrentSort="@Sort" Href="@GetSortUrl("counties")" /></th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in _items)
					{
						<tr>
							<td>@item.CountryName</td>
							<td>@item.Name</td>
							<td>@item.Code</td>
							<td>@item.SubdivisionType</td>
							<td>@item.CountyCount</td>
							<td>
								<div class="table-actions">
									<a class="btn btn-sm btn-outline-primary" href="admin/counties?stateProvinceId=@item.Id">Counties</a>
								<a class="btn btn-sm btn-outline-primary" href="admin/state-provinces/@item.Id">View</a>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}

		<ListPager ShownCount="_items.Count"
				   TotalCount="_totalCount"
				   PageSize="_pageSize"
				   HasMore="_hasMore"
				   IsLoadingMore="_isLoadingMore"
				   PageSizeOptions="ListPagingDefaults.PageSizeOptions"
				   PageSizeChanged="OnPageSizeChangedAsync"
				   OnLoadMore="LoadMoreAsync" />
	</div>
</div>

@code {
	[SupplyParameterFromQuery]
	public int? CountryId { get; set; }

	[SupplyParameterFromQuery]
	public string? Search { get; set; }

	[SupplyParameterFromQuery(Name = "pageSize")]
	public int? PageSize { get; set; }

	[SupplyParameterFromQuery(Name = "sort")]
	public string? Sort { get; set; }

	private IReadOnlyList<StateProvinceListItem> _items = Array.Empty<StateProvinceListItem>();
	private string? _filterLabel;
	private string _searchText = string.Empty;
	private int _pageSize = PagedQuery.DefaultLimit;
	private int _totalCount;
	private bool _hasMore;
	private bool _isLoadingMore;
	private bool _hasLoadedInitialState;

	protected override async Task OnParametersSetAsync()
	{
		_searchText = Search ?? string.Empty;
		_pageSize = ListPagingDefaults.NormalizePageSize(PageSize);
		_hasLoadedInitialState = false;
		try
		{
			await LoadAsync();
		}
		finally
		{
			_hasLoadedInitialState = true;
		}
	}

	private void ApplySearch()
	{
		NavigationManager.NavigateTo(BuildUrl(_searchText, _pageSize, Sort));
	}

	private void ClearSearch()
	{
		_searchText = string.Empty;
		NavigationManager.NavigateTo(BuildUrl(null, _pageSize, Sort));
	}

	private async Task LoadAsync(bool append = false)
	{
		var result = await AdministrationService.GetStateProvincesAsync(
			ListPagingDefaults.CreateRequest(_pageSize, append ? _items.Count : 0, Sort),
			CountryId,
			Search);
		_items = append ? _items.Concat(result.Items).ToArray() : result.Items;
		_totalCount = result.TotalCount;
		_hasMore = result.HasMore;
		_filterLabel = _items.FirstOrDefault()?.CountryFilterName;
	}

	private async Task LoadMoreAsync()
	{
		_isLoadingMore = true;
		try
		{
			await LoadAsync(append: true);
		}
		finally
		{
			_isLoadingMore = false;
		}
	}

	private Task OnPageSizeChangedAsync(int pageSize)
	{
		NavigationManager.NavigateTo(BuildUrl(Search, pageSize, Sort));
		return Task.CompletedTask;
	}

	private string GetSortUrl(string key)
	{
		return BuildUrl(Search, _pageSize, PagingSort.Toggle(Sort, key));
	}

	private string BuildUrl(string? search, int pageSize, string? sort)
	{
		var queryParts = new List<string>
		{
			$"pageSize={pageSize}"
		};
		if (CountryId.HasValue)
		{
			queryParts.Add($"countryId={CountryId.Value}");
		}
		if (!string.IsNullOrWhiteSpace(search))
		{
			queryParts.Add($"search={Uri.EscapeDataString(search)}");
		}
		if (!string.IsNullOrWhiteSpace(sort))
		{
			queryParts.Add($"sort={Uri.EscapeDataString(sort)}");
		}

		return $"/admin/state-provinces?{string.Join("&", queryParts)}";
	}
}
