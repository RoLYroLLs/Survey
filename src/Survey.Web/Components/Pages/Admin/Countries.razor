@page "/admin/countries"
@attribute [PlatformAuthorize(PlatformPermissionKeys.GeographyView)]
@inject IPlatformAdministrationService AdministrationService
@inject NavigationManager NavigationManager

<PageTitle>Countries</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Geography</p>
			<h1>Countries</h1>
			<p>View the countries available in the reference list.</p>
		</div>
		<div class="toolbar">
			<a class="btn btn-outline-primary" href="/admin/import-samples/countries">Download Sample Excel</a>
			<AuthorizeView Policy="@SurveyAuthorizationPolicies.PlatformPermission(PlatformPermissionKeys.GeographyManage)">
				<Authorized>
					<a class="btn btn-outline-primary" href="admin/countries/import">Import CSV</a>
					<a class="btn btn-primary" href="admin/countries/new">Add Country</a>
				</Authorized>
			</AuthorizeView>
		</div>
	</div>

	<div class="list-card">
		<div class="page-header">
			<div>
				<h2>Country Rows</h2>
				<p>Search by country name or ISO code.</p>
			</div>
			<div class="toolbar">
				<input class="form-control" placeholder="Search countries" @bind="_searchText" />
				<button class="btn btn-outline-primary" type="button" @onclick="ApplySearch">Search</button>
				<button class="btn btn-outline-primary" type="button" @onclick="ClearSearch">Clear</button>
			</div>
		</div>

		@if (_items.Count == 0)
		{
			<p class="empty-state">No countries matched the current search.</p>
		}
		else
		{
			<table class="admin-table">
				<thead>
					<tr>
						<th><SortableHeader Label="Name" SortKey="name" CurrentSort="@Sort" Href="@GetSortUrl("name")" /></th>
						<th><SortableHeader Label="ISO2" SortKey="iso2" CurrentSort="@Sort" Href="@GetSortUrl("iso2")" /></th>
						<th><SortableHeader Label="ISO3" SortKey="iso3" CurrentSort="@Sort" Href="@GetSortUrl("iso3")" /></th>
						<th><SortableHeader Label="States / Territories" SortKey="states" CurrentSort="@Sort" Href="@GetSortUrl("states")" /></th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in _items)
					{
						<tr>
							<td>@item.Name</td>
							<td>@item.Iso2Code</td>
							<td>@item.Iso3Code</td>
							<td>@item.StateProvinceCount</td>
							<td>
								<div class="table-actions">
									<a class="btn btn-sm btn-outline-primary" href="admin/state-provinces?countryId=@item.Id">States</a>
								<a class="btn btn-sm btn-outline-primary" href="admin/countries/@item.Id">View</a>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}

		<ListPager ShownCount="_items.Count"
				   TotalCount="_totalCount"
				   PageSize="_pageSize"
				   HasMore="_hasMore"
				   IsLoadingMore="_isLoadingMore"
				   PageSizeOptions="ListPagingDefaults.PageSizeOptions"
				   PageSizeChanged="OnPageSizeChangedAsync"
				   OnLoadMore="LoadMoreAsync" />
	</div>
</div>

@code {
	[SupplyParameterFromQuery]
	public string? Search { get; set; }

	[SupplyParameterFromQuery(Name = "pageSize")]
	public int? PageSize { get; set; }

	[SupplyParameterFromQuery(Name = "sort")]
	public string? Sort { get; set; }

	private IReadOnlyList<CountryListItem> _items = Array.Empty<CountryListItem>();
	private string _searchText = string.Empty;
	private int _pageSize = PagedQuery.DefaultLimit;
	private int _totalCount;
	private bool _hasMore;
	private bool _isLoadingMore;

	protected override async Task OnParametersSetAsync()
	{
		_searchText = Search ?? string.Empty;
		_pageSize = ListPagingDefaults.NormalizePageSize(PageSize);
		await LoadAsync();
	}

	private void ApplySearch()
	{
		NavigationManager.NavigateTo(BuildUrl(_searchText, _pageSize, Sort));
	}

	private void ClearSearch()
	{
		_searchText = string.Empty;
		NavigationManager.NavigateTo(BuildUrl(null, _pageSize, Sort));
	}

	private async Task LoadAsync(bool append = false)
	{
		var result = await AdministrationService.GetCountriesAsync(
			ListPagingDefaults.CreateRequest(_pageSize, append ? _items.Count : 0, Sort),
			Search);
		_items = append ? _items.Concat(result.Items).ToArray() : result.Items;
		_totalCount = result.TotalCount;
		_hasMore = result.HasMore;
	}

	private async Task LoadMoreAsync()
	{
		_isLoadingMore = true;
		try
		{
			await LoadAsync(append: true);
		}
		finally
		{
			_isLoadingMore = false;
		}
	}

	private Task OnPageSizeChangedAsync(int pageSize)
	{
		NavigationManager.NavigateTo(BuildUrl(Search, pageSize, Sort));
		return Task.CompletedTask;
	}

	private string GetSortUrl(string key)
	{
		return BuildUrl(Search, _pageSize, PagingSort.Toggle(Sort, key));
	}

	private static string BuildUrl(string? search, int pageSize, string? sort)
	{
		var queryParts = new List<string>
		{
			$"pageSize={pageSize}"
		};
		if (!string.IsNullOrWhiteSpace(search))
		{
			queryParts.Add($"search={Uri.EscapeDataString(search)}");
		}
		if (!string.IsNullOrWhiteSpace(sort))
		{
			queryParts.Add($"sort={Uri.EscapeDataString(sort)}");
		}

		return $"/admin/countries?{string.Join("&", queryParts)}";
	}
}
