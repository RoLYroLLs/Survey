@page "/admin/tenants"
@attribute [PlatformAuthorize(PlatformPermissionKeys.TenantsView)]
@inject IPlatformAdministrationService AdministrationService
@inject NavigationManager NavigationManager

<PageTitle>Tenants</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Platform Oversight</p>
			<h1>Tenants</h1>
			<p>Review tenant membership health, pending invitations, and overall usage.</p>
		</div>
			<div class="toolbar">
			<AuthorizeView Policy="@SurveyAuthorizationPolicies.PlatformPermission(PlatformPermissionKeys.TenantsManage)">
				<Authorized>
					<a class="btn btn-primary" href="/admin/tenants/new">Create Tenant</a>
				</Authorized>
			</AuthorizeView>
		</div>
	</div>

	<div class="list-card">
		<div class="page-header">
			<div>
				<h2>Tenant Directory</h2>
				<p>Search by tenant name or slug.</p>
			</div>
			<div class="toolbar">
				<input class="form-control" placeholder="Search tenants" @bind="_searchText" />
				<button class="btn btn-outline-primary" type="button" @onclick="ApplySearch">Search</button>
				<button class="btn btn-outline-primary" type="button" @onclick="ClearSearch">Clear</button>
			</div>
		</div>

		@if (!_hasLoadedInitialState)
		{
			<p class="empty-state">Loading...</p>
		}
		else if (_items.Count == 0)
		{
			<p class="empty-state">No tenants matched the current search.</p>
		}
		else
		{
			<table class="admin-table">
				<thead>
					<tr>
						<th><SortableHeader Label="Tenant" SortKey="tenant" CurrentSort="@Sort" Href="@GetSortUrl("tenant")" /></th>
						<th><SortableHeader Label="Members" SortKey="members" CurrentSort="@Sort" Href="@GetSortUrl("members")" /></th>
						<th><SortableHeader Label="Enabled" SortKey="enabled" CurrentSort="@Sort" Href="@GetSortUrl("enabled")" /></th>
						<th><SortableHeader Label="Owner" SortKey="owner" CurrentSort="@Sort" Href="@GetSortUrl("owner")" /></th>
						<th><SortableHeader Label="Pending Invites" SortKey="pendinginvites" CurrentSort="@Sort" Href="@GetSortUrl("pendinginvites")" /></th>
						<th><SortableHeader Label="Updated" SortKey="updated" CurrentSort="@Sort" Href="@GetSortUrl("updated")" /></th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in _items)
					{
						<tr>
							<td>
								<div>@item.Name</div>
								<div class="text-muted">@item.Slug</div>
							</td>
							<td>@item.MembershipCount</td>
							<td>@item.EnabledMembershipCount</td>
							<td>
								<div>@(string.IsNullOrWhiteSpace(item.OwnerDisplayName) ? "-" : item.OwnerDisplayName)</div>
								@if (!string.IsNullOrWhiteSpace(item.OwnerEmail))
								{
									<div class="text-muted">@item.OwnerEmail</div>
								}
							</td>
							<td>@item.PendingInvitationCount</td>
							<td>@item.UpdatedUtc.LocalDateTime.ToString("g")</td>
							<td>
								<div class="table-actions">
									<AuthorizeView Policy="@SurveyAuthorizationPolicies.PlatformPermission(PlatformPermissionKeys.TenantsOversight)">
										<Authorized>
											<a class="btn btn-sm btn-outline-primary" href="/admin/tenants/@item.Id">View</a>
										</Authorized>
									</AuthorizeView>
									<AuthorizeView Policy="@SurveyAuthorizationPolicies.PlatformPermission(PlatformPermissionKeys.TenantsManage)">
										<Authorized>
											<a class="btn btn-sm btn-outline-primary" href="/admin/tenants/@item.Id/edit">Edit</a>
										</Authorized>
									</AuthorizeView>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}

		<ListPager ShownCount="_items.Count"
				   TotalCount="_totalCount"
				   PageSize="_pageSize"
				   HasMore="_hasMore"
				   IsLoadingMore="_isLoadingMore"
				   PageSizeOptions="ListPagingDefaults.PageSizeOptions"
				   PageSizeChanged="OnPageSizeChangedAsync"
				   OnLoadMore="LoadMoreAsync" />
	</div>
</div>

@code {
	[SupplyParameterFromQuery]
	public string? Search { get; set; }

	[SupplyParameterFromQuery(Name = "pageSize")]
	public int? PageSize { get; set; }

	[SupplyParameterFromQuery(Name = "sort")]
	public string? Sort { get; set; }

	private IReadOnlyList<PlatformTenantListItem> _items = Array.Empty<PlatformTenantListItem>();
	private string _searchText = string.Empty;
	private int _pageSize = PagedQuery.DefaultLimit;
	private int _totalCount;
	private bool _hasMore;
	private bool _isLoadingMore;
	private bool _hasLoadedInitialState;

	protected override async Task OnParametersSetAsync()
	{
		_searchText = Search ?? string.Empty;
		_pageSize = ListPagingDefaults.NormalizePageSize(PageSize);
		_hasLoadedInitialState = false;
		try
		{
			await LoadAsync();
		}
		finally
		{
			_hasLoadedInitialState = true;
		}
	}

	private void ApplySearch()
	{
		NavigationManager.NavigateTo(BuildUrl(_searchText, _pageSize, Sort));
	}

	private void ClearSearch()
	{
		_searchText = string.Empty;
		NavigationManager.NavigateTo(BuildUrl(null, _pageSize, Sort));
	}

	private async Task LoadAsync(bool append = false)
	{
		var result = await AdministrationService.GetPlatformTenantsAsync(
			ListPagingDefaults.CreateRequest(_pageSize, append ? _items.Count : 0, Sort),
			Search);
		_items = append ? _items.Concat(result.Items).ToArray() : result.Items;
		_totalCount = result.TotalCount;
		_hasMore = result.HasMore;
	}

	private async Task LoadMoreAsync()
	{
		_isLoadingMore = true;
		try
		{
			await LoadAsync(append: true);
		}
		finally
		{
			_isLoadingMore = false;
		}
	}

	private Task OnPageSizeChangedAsync(int pageSize)
	{
		NavigationManager.NavigateTo(BuildUrl(Search, pageSize, Sort));
		return Task.CompletedTask;
	}

	private string GetSortUrl(string key)
	{
		return BuildUrl(Search, _pageSize, PagingSort.Toggle(Sort, key));
	}

	private static string BuildUrl(string? search, int pageSize, string? sort)
	{
		var queryParts = new List<string>
		{
			$"pageSize={pageSize}"
		};
		if (!string.IsNullOrWhiteSpace(search))
		{
			queryParts.Add($"search={Uri.EscapeDataString(search)}");
		}
		if (!string.IsNullOrWhiteSpace(sort))
		{
			queryParts.Add($"sort={Uri.EscapeDataString(sort)}");
		}

		return $"/admin/tenants?{string.Join("&", queryParts)}";
	}
}
