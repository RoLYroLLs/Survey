@page "/admin/themes/new"
@page "/admin/themes/{Id:int}"
@attribute [PlatformAuthorize(PlatformPermissionKeys.SettingsManage)]
@inject IPlatformAdministrationService AdministrationService
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>@GetPageTitle()</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Platform Theme</p>
			<h1>@GetPageTitle()</h1>
			<p>Manage a global theme that tenant owners can apply inside their own tenant.</p>
		</div>
		@if (!_model.IsNew)
		{
			<div class="toolbar">
				@if (_model.IsArchived)
				{
					<button class="btn btn-outline-primary" type="button" @onclick="RestoreAsync">Restore</button>
				}
				else if (_model.IsEnabled)
				{
					<button class="btn btn-outline-primary" type="button" disabled="@(!_canReplaceTheme)" @onclick="DisableAsync">@(_model.RequiresReplacement ? "Disable and Replace" : "Disable")</button>
					<button class="btn btn-outline-primary" type="button" @onclick="ArchiveAsync">Archive</button>
				}
				else
				{
					<button class="btn btn-outline-primary" type="button" @onclick="EnableAsync">Enable</button>
					<button class="btn btn-outline-primary" type="button" @onclick="ArchiveAsync">Archive</button>
				}
				<button class="btn btn-outline-primary" type="button" disabled="@(!_canReplaceTheme)" @onclick="DeleteAsync">@(_model.RequiresReplacement ? "Delete and Replace" : "Delete")</button>
			</div>
		}
	</div>

	<div class="form-card">
		@if (!string.IsNullOrWhiteSpace(_errorMessage))
		{
			<div class="inline-banner inline-banner--danger mb-3">@_errorMessage</div>
		}

		@if (!_model.IsNew && _model.RequiresReplacement)
		{
			<div class="alert alert-warning mb-3">
				@if (_model.ReplacementThemeOptions.Count == 0)
				{
					<span>Create another active theme before disabling or deleting this one. It is currently in use.</span>
				}
				else
				{
					<span>Choose a replacement theme before disabling or deleting this theme. It is currently used by</span>
					@if (_model.IsDefaultTheme)
					{
						<strong> the site default</strong>
						@if (_model.TenantUsageCount > 0)
						{
							<span> and </span>
						}
					}
					@if (_model.TenantUsageCount > 0)
					{
						<strong>@_model.TenantUsageCount tenant(s)</strong>
					}
					<span>.</span>
				}
			</div>
		}

		<EditForm Model="_model" OnValidSubmit="SaveAsync">
			<DataAnnotationsValidator />

			<div class="form-grid">
				<div class="field-stack">
					<FieldLabel Text="Theme Key" Required />
					@if (_model.IsNew)
					{
						<InputText class="form-control" @bind-Value="_model.Key" />
					}
					else
					{
						<input class="form-control" value="@_model.Key" disabled />
					}
					<ValidationMessage For="@(() => _model.Key)" />
				</div>
				<div class="field-stack">
					<FieldLabel Text="Theme Name" Required />
					<InputText class="form-control" @bind-Value="_model.Name" />
					<ValidationMessage For="@(() => _model.Name)" />
				</div>
				<div class="field-stack">
					<FieldLabel Text="Primary Color" Required />
					<InputText class="form-control" @bind-Value="_model.PrimaryColor" />
					<ValidationMessage For="@(() => _model.PrimaryColor)" />
				</div>
				<div class="field-stack">
					<FieldLabel Text="Accent Color" Required />
					<InputText class="form-control" @bind-Value="_model.AccentColor" />
					<ValidationMessage For="@(() => _model.AccentColor)" />
				</div>
				<div class="field-stack">
					<FieldLabel Text="Background Color" Required />
					<InputText class="form-control" @bind-Value="_model.BackgroundColor" />
					<ValidationMessage For="@(() => _model.BackgroundColor)" />
				</div>
				<div class="field-stack">
					<label>Preview</label>
					<span class="theme-preset-card__swatch" style="@BuildPreviewStyle()"></span>
				</div>
			</div>

			<div class="field-stack mt-4">
				<FieldLabel Text="Description" Required />
				<InputTextArea class="form-control" @bind-Value="_model.Description" />
				<ValidationMessage For="@(() => _model.Description)" />
			</div>

			<div class="field-stack mt-4">
				<FieldLabel Text="CSS Variables Block" Required />
				<InputTextArea class="form-control platform-theme-css" @bind-Value="_model.CssVariablesBlock" />
				<ValidationMessage For="@(() => _model.CssVariablesBlock)" />
				<div class="helper-copy">Paste a full <code>:root</code> CSS variable block. These values drive the full tenant shell, cards, buttons, and top bar.</div>
			</div>

			@if (!_model.IsNew && _model.RequiresReplacement)
			{
				<div class="field-stack mt-4">
					<FieldLabel Text="Replacement Theme" Required />
					<InputSelect class="form-select" @bind-Value="_model.ReplacementThemeId">
						<option value="">Select a replacement theme</option>
						@foreach (var option in _model.ReplacementThemeOptions)
						{
							<option value="@option.Value">@option.Label</option>
						}
					</InputSelect>
					<div class="helper-copy">
						This replacement will be applied automatically to the current default theme reference and any tenant currently using this theme.
						@if (_model.IsDefaultTheme)
						{
							<span> Because this theme is the current default, the replacement you choose here will become the new default.</span>
						}
					</div>
				</div>
			}

			@if (_model.UpdatedUtc.HasValue)
			{
				<div class="helper-copy mt-3">
					Status: <strong>@GetStatusLabel()</strong>
					@if (_model.IsDefaultTheme)
					{
						<br />
						<span>Default theme: <strong>Yes</strong></span>
					}
					@if (_model.TenantUsageCount > 0)
					{
						<br />
						<span>Assigned to <strong>@_model.TenantUsageCount</strong> tenant(s)</span>
					}
					<br />
					Last updated @_model.UpdatedUtc.Value.LocalDateTime.ToString("g")
				</div>
			}

			<div class="form-footer">
				<button class="btn btn-primary" type="submit">Save Theme</button>
				<a class="btn btn-outline-primary" href="/admin/themes">Back to Themes</a>
			</div>
		</EditForm>
	</div>
</div>

@code {
	[Parameter]
	public int? Id { get; set; }

	private PlatformThemeEditModel _model = new();
	private string? _errorMessage;
	private bool _canReplaceTheme = true;

	protected override async Task OnParametersSetAsync()
	{
		_model = await AdministrationService.GetPlatformThemeAsync(Id);
		if (_model.RequiresReplacement
			&& !_model.ReplacementThemeId.HasValue
			&& _model.ReplacementThemeOptions.Count > 0
			&& int.TryParse(_model.ReplacementThemeOptions[0].Value, out var replacementThemeId))
		{
			_model.ReplacementThemeId = replacementThemeId;
		}

		_canReplaceTheme = !_model.RequiresReplacement || _model.ReplacementThemeOptions.Count > 0;
		_errorMessage = null;
	}

	private async Task SaveAsync()
	{
		try
		{
			var savedId = await AdministrationService.SavePlatformThemeAsync(_model);
			_errorMessage = null;
			ToastService.ShowSuccess("Theme saved successfully.", "Saved");
			NavigationManager.NavigateTo($"/admin/themes/{savedId}", true);
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
	}

	private async Task EnableAsync()
	{
		if (!_model.Id.HasValue)
		{
			return;
		}

		try
		{
			await AdministrationService.SetPlatformThemeEnabledAsync(_model.Id.Value, true);
			ToastService.ShowSuccess("Theme enabled successfully.", "Theme updated");
			await ReloadAsync();
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
	}

	private async Task DisableAsync()
	{
		if (!_model.Id.HasValue)
		{
			return;
		}

		try
		{
			await AdministrationService.SetPlatformThemeEnabledAsync(_model.Id.Value, false, _model.ReplacementThemeId);
			ToastService.ShowSuccess("Theme disabled successfully.", "Theme updated");
			await ReloadAsync();
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
	}

	private async Task ArchiveAsync()
	{
		if (!_model.Id.HasValue)
		{
			return;
		}

		try
		{
			await AdministrationService.SetPlatformThemeArchivedAsync(_model.Id.Value, true);
			ToastService.ShowSuccess("Theme archived successfully.", "Theme updated");
			await ReloadAsync();
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
	}

	private async Task RestoreAsync()
	{
		if (!_model.Id.HasValue)
		{
			return;
		}

		try
		{
			await AdministrationService.SetPlatformThemeArchivedAsync(_model.Id.Value, false);
			ToastService.ShowSuccess("Theme restored successfully.", "Theme updated");
			await ReloadAsync();
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
	}

	private async Task DeleteAsync()
	{
		if (!_model.Id.HasValue)
		{
			return;
		}

		try
		{
			await AdministrationService.DeletePlatformThemeAsync(_model.Id.Value, _model.ReplacementThemeId);
			ToastService.ShowSuccess("Theme deleted successfully.", "Theme removed");
			NavigationManager.NavigateTo("/admin/themes", true);
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
	}

	private string GetPageTitle()
	{
		return _model.IsNew ? "New Theme" : "Edit Theme";
	}

	private string BuildPreviewStyle()
	{
		return $"background: linear-gradient(135deg, {_model.PrimaryColor}, {_model.AccentColor});";
	}

	private async Task ReloadAsync()
	{
		_model = await AdministrationService.GetPlatformThemeAsync(Id);
		if (_model.RequiresReplacement
			&& !_model.ReplacementThemeId.HasValue
			&& _model.ReplacementThemeOptions.Count > 0
			&& int.TryParse(_model.ReplacementThemeOptions[0].Value, out var replacementThemeId))
		{
			_model.ReplacementThemeId = replacementThemeId;
		}

		_canReplaceTheme = !_model.RequiresReplacement || _model.ReplacementThemeOptions.Count > 0;
		_errorMessage = null;
	}

	private string GetStatusLabel()
	{
		if (_model.IsArchived)
		{
			return "Archived";
		}

		return _model.IsEnabled ? "Active" : "Disabled";
	}
}
