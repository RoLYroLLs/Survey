@page "/admin/surveys/new"
@page "/admin/surveys/{Id:int}/edit"
@attribute [Authorize(Roles = RoleNames.Admin)]
@inject ISurveyAdministrationService AdministrationService
@inject NavigationManager NavigationManager

<PageTitle>@(Id.HasValue ? "Edit Survey" : "Add Survey")</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Survey Definition</p>
			<h1>@(Id.HasValue ? "Edit Survey" : "Add Survey")</h1>
			<p>Define the root survey record. Versions, sections, and questions are managed separately.</p>
		</div>
	</div>

	<div class="form-card narrow-card">
		@if (!string.IsNullOrWhiteSpace(_errorMessage))
		{
			<div class="inline-banner inline-banner--danger mb-3">@_errorMessage</div>
		}

		<EditForm Model="_model" OnValidSubmit="SaveAsync">
			<DataAnnotationsValidator />
			<div class="form-grid form-grid--single">
				<div class="field-stack">
					<label>Name</label>
					<InputText class="form-control" @bind-Value="_model.Name" />
					<ValidationMessage For="@(() => _model.Name)" />
				</div>
				<div class="field-stack">
					<label>Description</label>
					<InputTextArea class="form-control" rows="5" @bind-Value="_model.Description" />
					<ValidationMessage For="@(() => _model.Description)" />
				</div>
				<div class="field-stack">
					<label>Archived</label>
					<InputCheckbox class="form-check-input" @bind-Value="_model.IsArchived" />
				</div>
			</div>

			<div class="form-footer">
				<button class="btn btn-primary" type="submit">Save Survey</button>
				<a class="btn btn-outline-primary" href="@GetBackUrl()">Back to Surveys</a>
			</div>
		</EditForm>
	</div>
</div>

@code {
	[Parameter]
	public int? Id { get; set; }

	[SupplyParameterFromQuery]
	public bool ShowArchived { get; set; }

	private SurveyDefinitionEditModel _model = new();
	private string? _errorMessage;

	protected override async Task OnParametersSetAsync()
	{
		_model = await AdministrationService.GetSurveyDefinitionAsync(Id);
		_errorMessage = null;
	}

	private async Task SaveAsync()
	{
		try
		{
			await AdministrationService.SaveSurveyDefinitionAsync(_model);
			NavigationManager.NavigateTo(GetBackUrl(_model.IsArchived));
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
	}

	private string GetBackUrl(bool? isArchived = null)
	{
		var showArchived = isArchived ?? (ShowArchived || _model.IsArchived);
		return showArchived ? "admin/surveys?showArchived=true" : "admin/surveys";
	}
}
