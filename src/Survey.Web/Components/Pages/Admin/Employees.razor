@page "/admin/users"
@attribute [PlatformAuthorize(PlatformPermissionKeys.UsersView)]
@inject IPlatformAdministrationService AdministrationService
@inject NavigationManager NavigationManager

<PageTitle>Users</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Platform Access</p>
			<h1>Users</h1>
			<p>View the platform user accounts that can administer the survey platform.</p>
		</div>
		<div class="toolbar">
			<AuthorizeView Policy="@SurveyAuthorizationPolicies.PlatformPermission(PlatformPermissionKeys.UsersManage)">
				<Authorized>
					<a class="btn btn-primary" href="admin/users/new">Add User</a>
				</Authorized>
			</AuthorizeView>
		</div>
	</div>

	<div class="list-card">
		<div class="page-header">
			<div>
				<h2>Platform Users</h2>
				<p>Search by name, email, status, or effective platform scope.</p>
			</div>
			<div class="toolbar">
				<input class="form-control" placeholder="Search users" @bind="_searchText" />
				<button class="btn btn-outline-primary" type="button" @onclick="ApplySearch">Search</button>
				<button class="btn btn-outline-primary" type="button" @onclick="ClearSearch">Clear</button>
			</div>
		</div>

		@if (_items.Count == 0)
		{
			<p class="empty-state">No platform users matched the current search.</p>
		}
		else
		{
			<table class="admin-table">
				<thead>
					<tr>
						<th>Name</th>
						<th>Email</th>
						<th>Status</th>
						<th>Scope</th>
						<th>Permissions</th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in _items)
					{
						<tr>
							<td>@item.FirstName @item.LastName</td>
							<td>@item.Email</td>
							<td>@(item.IsPlatformUserEnabled ? "Enabled" : "Disabled")</td>
							<td>@(item.IsPlatformSuperAdmin ? "Super admin" : "Granular permissions")</td>
							<td>@item.PermissionCount</td>
							<td>
								<div class="table-actions">
									<a class="btn btn-sm btn-outline-primary" href="admin/users/@item.Id">View</a>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}
	</div>
</div>

@code {
	[SupplyParameterFromQuery]
	public string? Search { get; set; }

	private IReadOnlyList<PlatformUserListItem> _items = Array.Empty<PlatformUserListItem>();
	private string _searchText = string.Empty;

	protected override async Task OnParametersSetAsync()
	{
		_searchText = Search ?? string.Empty;
		_items = await AdministrationService.GetPlatformUsersAsync(Search);
	}

	private void ApplySearch()
	{
		var url = string.IsNullOrWhiteSpace(_searchText)
			? "admin/users"
			: $"admin/users?search={Uri.EscapeDataString(_searchText)}";
		NavigationManager.NavigateTo(url);
	}

	private void ClearSearch()
	{
		_searchText = string.Empty;
		NavigationManager.NavigateTo("admin/users");
	}
}
