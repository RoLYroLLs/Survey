@page "/admin/counties/new"
@page "/admin/counties/{Id:int}"
@page "/admin/counties/{Id:int}/edit"
@implements IDisposable
@attribute [PlatformAuthorize]
@inject IPlatformAdministrationService AdministrationService
@inject IPlatformPermissionEvaluator PlatformPermissionEvaluator
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>@GetPageTitle()</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Geography</p>
			<h1>@GetPageTitle()</h1>
			<p>View or update a county record.</p>
		</div>
	</div>

	<div class="form-card narrow-card">
		@if (!string.IsNullOrWhiteSpace(_errorMessage))
		{
			<div class="inline-banner inline-banner--danger mb-3">@_errorMessage</div>
		}

		@if (IsViewMode)
		{
			<div class="page-stack">
				<div class="assignment-detail-list">
					<div class="assignment-detail-row">
						<strong>State / Territory</strong>
						<span>@GetSelectedOptionLabel(_model.StateProvinceOptions, _model.StateProvinceId)</span>
					</div>
					<div class="assignment-detail-row">
						<strong>Name</strong>
						<span>@DisplayOrDash(_model.Name)</span>
					</div>
					<div class="assignment-detail-row">
						<strong>FIPS Code</strong>
						<span>@DisplayOrDash(_model.FipsCode)</span>
					</div>
				</div>

				<div class="form-footer">
					<AuthorizeView Policy="@SurveyAuthorizationPolicies.PlatformPermission(PlatformPermissionKeys.GeographyManage)">
						<Authorized>
							<a class="btn btn-primary" href="/admin/counties/@Id/edit">Edit County</a>
						</Authorized>
					</AuthorizeView>
					<a class="btn btn-outline-primary" href="admin/counties">Back to Counties</a>
				</div>
			</div>
		}
		else
		{
			<EditForm Model="_model" OnValidSubmit="SaveAsync">
				<DataAnnotationsValidator />
				<div class="form-grid form-grid--single">
					<div class="field-stack">
						<FieldLabel Text="State / Territory" Required />
						<SearchableSelect class="form-control"
										  @bind-Value="_model.StateProvinceId"
										  Options="_model.StateProvinceOptions"
										  IncludeEmptyOption="true"
										  EmptyOptionLabel="Select a state or territory"
										  EmptyOptionValue="0" />
						<ValidationMessage For="@(() => _model.StateProvinceId)" />
					</div>
					<div class="field-stack">
						<FieldLabel Text="Name" Required />
						<InputText class="form-control" @bind-Value="_model.Name" />
						<ValidationMessage For="@(() => _model.Name)" />
					</div>
					<div class="field-stack">
						<FieldLabel Text="FIPS Code" Required />
						<InputText class="form-control" @bind-Value="_model.FipsCode" />
						<ValidationMessage For="@(() => _model.FipsCode)" />
					</div>
				</div>

				<div class="form-footer">
					<button class="btn btn-primary" type="submit">Save County</button>
					<a class="btn btn-outline-primary" href="@(Id.HasValue ? $"/admin/counties/{Id.Value}" : "admin/counties")">Cancel</a>
				</div>
			</EditForm>
		}
	</div>
</div>

@code {
	[Parameter]
	public int? Id { get; set; }

	private CountyEditModel _model = new();
	private string? _errorMessage;
	private bool IsViewMode => Id.HasValue && !NavigationManager.Uri.Contains("/edit", StringComparison.OrdinalIgnoreCase);

	protected override void OnInitialized()
	{
		NavigationManager.LocationChanged += OnLocationChanged;
	}

	protected override async Task OnParametersSetAsync()
	{
		if (!await EnsurePageAccessAsync())
		{
			return;
		}

		_model = await AdministrationService.GetCountyAsync(Id, null);
		_errorMessage = null;
	}

	private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
	{
		_ = InvokeAsync(StateHasChanged);
	}

	private async Task SaveAsync()
	{
		try
		{
			var savedId = await AdministrationService.SaveCountyAsync(_model);
			_errorMessage = null;
			ToastService.ShowSuccess("County saved successfully.", "Saved");
			NavigationManager.NavigateTo($"admin/counties/{savedId}");
		}
		catch (Exception ex)
		{
			_errorMessage = null;
			ToastService.ShowError(ex.Message, "Save failed");
		}
	}

	private string GetPageTitle()
	{
		if (IsViewMode)
		{
			return "View County";
		}

		return Id.HasValue ? "Edit County" : "Add County";
	}

	private static string DisplayOrDash(string? value)
	{
		return string.IsNullOrWhiteSpace(value) ? "-" : value;
	}

	private static string GetSelectedOptionLabel(IEnumerable<SelectOption> options, int value)
	{
		return options.FirstOrDefault(option => option.Value == value.ToString())?.Label ?? "-";
	}

	private async Task<bool> EnsurePageAccessAsync()
	{
		var permissionKey = IsViewMode
			? PlatformPermissionKeys.GeographyView
			: PlatformPermissionKeys.GeographyManage;
		if (await PlatformPermissionEvaluator.HasPermissionAsync(permissionKey))
		{
			return true;
		}

		NavigationManager.NavigateTo("/Account/AccessDenied", true);
		return false;
	}

	public void Dispose()
	{
		NavigationManager.LocationChanged -= OnLocationChanged;
	}
}
