@page "/admin/goals"
@attribute [Authorize(Roles = RoleNames.Admin)]
@inject ISurveyAdministrationService AdministrationService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Goals</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Response Targets</p>
			<h1>Goals</h1>
			<p>View the response goals that have been defined.</p>
		</div>
		<div class="toolbar">
			<a class="btn btn-primary" href="admin/goals/new">Add Goal</a>
		</div>
	</div>

	@if (!string.IsNullOrWhiteSpace(_errorMessage))
	{
		<div class="inline-banner inline-banner--danger">@_errorMessage</div>
	}

	<div class="list-card">
		@if (_items.Count == 0)
		{
			<p class="empty-state">No goals have been created yet.</p>
		}
		else
		{
			<table class="admin-table">
				<thead>
					<tr>
						<th>Name</th>
						<th>Area</th>
						<th>Survey</th>
						<th>Window</th>
						<th>Progress</th>
						<th>Dashboard</th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in _items)
					{
						<tr>
							<td>@item.Name</td>
							<td>@(string.IsNullOrWhiteSpace(item.AreaName) ? "All Areas" : item.AreaName)</td>
							<td>@(string.IsNullOrWhiteSpace(item.SurveyName) ? "All Surveys" : item.SurveyName)</td>
							<td>@item.StartDate.ToString("d") - @item.EndDate.ToString("d")</td>
							<td>@item.CompletedResponses / @item.TargetResponseCount (@item.ProgressPercent.ToString("0.0")%)</td>
							<td>
								<button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => ToggleFavoriteAsync(item.Id)">
									@(item.IsFavorite ? "Favorited" : "Favorite")
								</button>
							</td>
							<td>
								<div class="table-actions">
								<a class="btn btn-sm btn-outline-primary" href="admin/goals/@item.Id">View</a>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}
	</div>
</div>

@code {
	private IReadOnlyList<GoalListItem> _items = Array.Empty<GoalListItem>();
	private string? _currentUserId;
	private string? _errorMessage;

	protected override async Task OnInitializedAsync()
	{
		var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
		_currentUserId = authenticationState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
		await LoadGoalsAsync();
	}

	private async Task ToggleFavoriteAsync(int goalId)
	{
		if (string.IsNullOrWhiteSpace(_currentUserId))
		{
			_errorMessage = "The signed-in user could not be resolved.";
			return;
		}

		try
		{
			_errorMessage = null;
			await AdministrationService.ToggleFavoriteGoalAsync(goalId, _currentUserId);
			await LoadGoalsAsync();
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
	}

	private async Task LoadGoalsAsync()
	{
		_items = await AdministrationService.GetGoalsAsync(_currentUserId);
	}
}
