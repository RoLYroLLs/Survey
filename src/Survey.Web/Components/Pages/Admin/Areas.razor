@page "/admin/areas"
@attribute [Authorize(Roles = RoleNames.Admin)]
@inject ISurveyAdministrationService AdministrationService

<PageTitle>Areas</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Geographic Areas</p>
			<h1>Areas</h1>
			<p>@(string.IsNullOrWhiteSpace(_filterLabel) ? "Group counties into reusable areas such as South Florida or Central Florida, then use them for goals and reporting." : $"Showing areas that include {_filterLabel}.")</p>
		</div>
		<div class="toolbar">
			@if (CountyId.HasValue)
			{
				<a class="btn btn-outline-primary" href="admin/areas">View All</a>
			}
			<a class="btn btn-primary" href="admin/areas/new">Add Area</a>
		</div>
	</div>

	<div class="list-card">
		@if (_items.Count == 0)
		{
			<p class="empty-state">No areas have been created yet.</p>
		}
		else
		{
			<table class="admin-table">
				<thead>
					<tr>
						<th>Name</th>
						<th>Description</th>
						<th>Counties</th>
						<th>Goals</th>
						<th>Updated</th>
						<th></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in _items)
					{
						<tr>
							<td>@item.Name</td>
							<td>@item.Description</td>
							<td>@item.CountyCount</td>
							<td>@item.GoalCount</td>
							<td>@item.UpdatedUtc.LocalDateTime.ToString("g")</td>
							<td>
								<div class="table-actions">
									<a class="btn btn-sm btn-outline-primary" href="admin/areas/@item.Id/edit">Edit</a>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}
	</div>
</div>

@code {
	[SupplyParameterFromQuery]
	public int? CountyId { get; set; }

	private IReadOnlyList<AreaListItem> _items = Array.Empty<AreaListItem>();
	private string? _filterLabel;

	protected override async Task OnParametersSetAsync()
	{
		_items = await AdministrationService.GetAreasAsync(CountyId);
		_filterLabel = _items.FirstOrDefault()?.CountyNameFilter;
	}
}
