@page "/admin/zip-mappings/new"
@page "/admin/zip-mappings/{Id:int}"
@page "/admin/zip-mappings/{Id:int}/edit"
@implements IDisposable
@attribute [PlatformAuthorize]
@inject IPlatformAdministrationService AdministrationService
@inject IPlatformPermissionEvaluator PlatformPermissionEvaluator
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>@GetPageTitle()</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">ZIP Crosswalk Row</p>
			<h1>@GetPageTitle()</h1>
			<p>View or update a ZIP mapping record.</p>
		</div>
	</div>

	<div class="form-card narrow-card">
		@if (!string.IsNullOrWhiteSpace(_errorMessage))
		{
			<div class="inline-banner inline-banner--danger mb-3">@_errorMessage</div>
		}

		@if (IsViewMode)
		{
			<div class="page-stack">
				<div class="assignment-detail-list">
					<div class="assignment-detail-row">
						<strong>ZIP Code</strong>
						<span>@DisplayOrDash(_model.ZipCode)</span>
					</div>
					<div class="assignment-detail-row">
						<strong>County FIPS</strong>
						<span>@DisplayOrDash(_model.CountyFips)</span>
					</div>
					<div class="assignment-detail-row">
						<strong>County Name</strong>
						<span>@DisplayOrDash(_model.CountyName)</span>
					</div>
					<div class="assignment-detail-row">
						<strong>State Code</strong>
						<span>@DisplayOrDash(_model.StateCode)</span>
					</div>
					<div class="assignment-detail-row">
						<strong>Residential Ratio</strong>
						<span>@_model.ResidentialRatio</span>
					</div>
				</div>

				<div class="form-footer">
					<AuthorizeView Policy="@SurveyAuthorizationPolicies.PlatformPermission(PlatformPermissionKeys.GeographyManage)">
						<Authorized>
							<a class="btn btn-primary" href="/admin/zip-mappings/@Id/edit">Edit ZIP Mapping</a>
						</Authorized>
					</AuthorizeView>
					<a class="btn btn-outline-primary" href="admin/zip-mappings">Back to ZIP Mappings</a>
				</div>
			</div>
		}
		else
		{
			<EditForm Model="_model" OnValidSubmit="SaveAsync">
				<DataAnnotationsValidator />
				<div class="form-grid">
					<div class="field-stack">
						<FieldLabel Text="ZIP Code" Required />
						<InputText class="form-control" @bind-Value="_model.ZipCode" />
						<ValidationMessage For="@(() => _model.ZipCode)" />
					</div>
					<div class="field-stack">
						<FieldLabel Text="County FIPS" Required />
						<InputText class="form-control" @bind-Value="_model.CountyFips" />
						<ValidationMessage For="@(() => _model.CountyFips)" />
					</div>
					<div class="field-stack">
						<FieldLabel Text="County Name" Required />
						<InputText class="form-control" @bind-Value="_model.CountyName" />
						<ValidationMessage For="@(() => _model.CountyName)" />
					</div>
					<div class="field-stack">
						<FieldLabel Text="State Code" Required />
						<InputText class="form-control" @bind-Value="_model.StateCode" />
						<ValidationMessage For="@(() => _model.StateCode)" />
					</div>
					<div class="field-stack">
						<label>Residential Ratio</label>
						<InputNumber class="form-control" @bind-Value="_model.ResidentialRatio" />
						<ValidationMessage For="@(() => _model.ResidentialRatio)" />
					</div>
				</div>

				<div class="form-footer">
					<button class="btn btn-primary" type="submit">Save Mapping</button>
					<a class="btn btn-outline-primary" href="@(Id.HasValue ? $"/admin/zip-mappings/{Id.Value}" : "admin/zip-mappings")">Cancel</a>
				</div>
			</EditForm>
		}
	</div>
</div>

@code {
	[Parameter]
	public int? Id { get; set; }

	private ZipCountyMappingEditModel _model = new();
	private string? _errorMessage;
	private bool IsViewMode => Id.HasValue && !NavigationManager.Uri.Contains("/edit", StringComparison.OrdinalIgnoreCase);

	protected override void OnInitialized()
	{
		NavigationManager.LocationChanged += OnLocationChanged;
	}

	protected override async Task OnParametersSetAsync()
	{
		if (!await EnsurePageAccessAsync())
		{
			return;
		}

		_model = await AdministrationService.GetZipCountyMappingAsync(Id);
		_errorMessage = null;
	}

	private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
	{
		_ = InvokeAsync(StateHasChanged);
	}

	private async Task SaveAsync()
	{
		try
		{
			var savedId = await AdministrationService.SaveZipCountyMappingAsync(_model);
			_errorMessage = null;
			ToastService.ShowSuccess("ZIP mapping saved successfully.", "Saved");
			NavigationManager.NavigateTo($"admin/zip-mappings/{savedId}");
		}
		catch (Exception ex)
		{
			_errorMessage = null;
			ToastService.ShowError(ex.Message, "Save failed");
		}
	}

	private string GetPageTitle()
	{
		if (IsViewMode)
		{
			return "View ZIP Mapping";
		}

		return Id.HasValue ? "Edit ZIP Mapping" : "Add ZIP Mapping";
	}

	private static string DisplayOrDash(string? value)
	{
		return string.IsNullOrWhiteSpace(value) ? "-" : value;
	}

	private async Task<bool> EnsurePageAccessAsync()
	{
		var permissionKey = IsViewMode
			? PlatformPermissionKeys.GeographyView
			: PlatformPermissionKeys.GeographyManage;
		if (await PlatformPermissionEvaluator.HasPermissionAsync(permissionKey))
		{
			return true;
		}

		NavigationManager.NavigateTo("/Account/AccessDenied", true);
		return false;
	}

	public void Dispose()
	{
		NavigationManager.LocationChanged -= OnLocationChanged;
	}
}
