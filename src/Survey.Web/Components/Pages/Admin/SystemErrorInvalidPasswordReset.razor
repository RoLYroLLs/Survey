@page "/admin/system/errors/invalid-password-reset"
@attribute [PlatformAuthorize(PlatformPermissionKeys.SettingsManage)]

<PageTitle>Invalid Password Reset Preview</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">System Error</p>
			<h1>Invalid Password Reset Preview</h1>
			<p>This is the minimal account recovery failure treatment for an invalid or expired password reset link.</p>
		</div>
	</div>

	<div class="system-preview-stage">
		<div class="form-card narrow-card">
			<div class="page-stack">
				<h1>Invalid Password Reset</h1>
				<p role="alert">The password reset link is invalid.</p>
			</div>
		</div>
	</div>
</div>
