@page "/admin/audit"
@attribute [PlatformAuthorize(PlatformPermissionKeys.AuditView)]
@inject IPlatformAdministrationService AdministrationService
@inject NavigationManager NavigationManager

<PageTitle>Audit</PageTitle>

<div class="page-stack">
	<div class="page-header">
		<div>
			<p class="eyebrow">Platform Oversight</p>
			<h1>Audit</h1>
			<p>Review platform and tenant security-sensitive activity, including denied access attempts.</p>
		</div>
	</div>

	<div class="list-card">
		<div class="page-header">
			<div>
				<h2>Filters</h2>
				<p>Narrow audit rows by plane, tenant, result, or search text.</p>
			</div>
		</div>

		<div class="form-grid">
			<div class="field-stack">
				<label>Plane</label>
				<SearchableSelect class="form-control"
								  @bind-Value="_plane"
								  Options="_planeOptions"
								  IncludeEmptyOption="true"
								  EmptyOptionLabel="All planes" />
			</div>
			<div class="field-stack">
				<label>Tenant</label>
				<SearchableSelect class="form-control"
								  @bind-Value="_tenantId"
								  Options="_tenantOptions"
								  IncludeEmptyOption="true"
								  EmptyOptionLabel="All tenants" />
			</div>
			<div class="field-stack">
				<label>Result</label>
				<SearchableSelect class="form-control"
								  @bind-Value="_succeeded"
								  Options="_resultOptions"
								  IncludeEmptyOption="true"
								  EmptyOptionLabel="All results" />
			</div>
			<div class="field-stack">
				<label>Search</label>
				<input class="form-control" placeholder="Action, target, details, or actor" @bind="_searchText" />
			</div>
		</div>

		<div class="form-footer">
			<button class="btn btn-primary" type="button" @onclick="ApplyFilters">Apply Filters</button>
			<button class="btn btn-outline-primary" type="button" @onclick="ClearFilters">Clear</button>
		</div>
	</div>

	<div class="list-card">
		@if (!_hasLoadedInitialState)
		{
			<p class="empty-state">Loading...</p>
		}
		else if (_items.Count == 0)
		{
			<p class="empty-state">No audit rows matched the current filters.</p>
		}
		else
		{
			<table class="admin-table">
				<thead>
					<tr>
						<th><SortableHeader Label="When" SortKey="when" CurrentSort="@Sort" Href="@GetSortUrl("when")" /></th>
						<th><SortableHeader Label="Plane" SortKey="plane" CurrentSort="@Sort" Href="@GetSortUrl("plane")" /></th>
						<th><SortableHeader Label="Tenant" SortKey="tenant" CurrentSort="@Sort" Href="@GetSortUrl("tenant")" /></th>
						<th><SortableHeader Label="Actor" SortKey="actor" CurrentSort="@Sort" Href="@GetSortUrl("actor")" /></th>
						<th><SortableHeader Label="Action" SortKey="action" CurrentSort="@Sort" Href="@GetSortUrl("action")" /></th>
						<th><SortableHeader Label="Target" SortKey="target" CurrentSort="@Sort" Href="@GetSortUrl("target")" /></th>
						<th><SortableHeader Label="Result" SortKey="result" CurrentSort="@Sort" Href="@GetSortUrl("result")" /></th>
						<th><SortableHeader Label="Details" SortKey="details" CurrentSort="@Sort" Href="@GetSortUrl("details")" /></th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in _items)
					{
						<tr>
							<td>@item.CreatedUtc.LocalDateTime.ToString("g")</td>
							<td>@item.Plane</td>
							<td>@(string.IsNullOrWhiteSpace(item.TenantName) ? "-" : item.TenantName)</td>
							<td>@item.ActorDisplayName</td>
							<td>@item.ActionType</td>
							<td>@GetTargetLabel(item)</td>
							<td>
								<span class="status-pill @(item.Succeeded ? null : "status-pill--danger")">@GetResultLabel(item.Succeeded)</span>
							</td>
							<td>@DisplayOrDash(item.Details)</td>
						</tr>
					}
				</tbody>
			</table>
		}

		<ListPager ShownCount="_items.Count"
				   TotalCount="_totalCount"
				   PageSize="_pageSize"
				   HasMore="_hasMore"
				   IsLoadingMore="_isLoadingMore"
				   PageSizeOptions="ListPagingDefaults.PageSizeOptions"
				   PageSizeChanged="OnPageSizeChangedAsync"
				   OnLoadMore="LoadMoreAsync" />
	</div>
</div>

@code {
	[SupplyParameterFromQuery]
	public string? Plane { get; set; }

	[SupplyParameterFromQuery]
	public int? TenantId { get; set; }

	[SupplyParameterFromQuery]
	public bool? Succeeded { get; set; }

	[SupplyParameterFromQuery]
	public string? Search { get; set; }

	[SupplyParameterFromQuery(Name = "pageSize")]
	public int? PageSize { get; set; }

	[SupplyParameterFromQuery(Name = "sort")]
	public string? Sort { get; set; }

	private IReadOnlyList<AuditLogListItem> _items = Array.Empty<AuditLogListItem>();
	private IReadOnlyList<SelectOption> _tenantOptions = Array.Empty<SelectOption>();
	private string? _plane;
	private int? _tenantId;
	private bool? _succeeded;
	private string _searchText = string.Empty;
	private int _pageSize = PagedQuery.DefaultLimit;
	private int _totalCount;
	private bool _hasMore;
	private bool _isLoadingMore;
	private bool _hasLoadedInitialState;

	private static readonly IReadOnlyList<SelectOption> _planeOptions =
	[
		new() { Value = "tenant", Label = "Tenant" },
		new() { Value = "platform", Label = "Platform" }
	];

	private static readonly IReadOnlyList<SelectOption> _resultOptions =
	[
		new() { Value = "true", Label = "Succeeded" },
		new() { Value = "false", Label = "Denied / Failed" }
	];

	protected override async Task OnParametersSetAsync()
	{
		_hasLoadedInitialState = false;
		try
		{
			_tenantOptions = (await LoadTenantOptionsAsync())
				.Select(item => new SelectOption { Value = item.Id.ToString(), Label = item.Name })
				.ToArray();

			_plane = Plane;
			_tenantId = TenantId;
			_succeeded = Succeeded;
			_searchText = Search ?? string.Empty;
			_pageSize = ListPagingDefaults.NormalizePageSize(PageSize);
			await LoadAsync();
		}
		finally
		{
			_hasLoadedInitialState = true;
		}
	}

	private void ApplyFilters()
	{
		NavigationManager.NavigateTo(BuildUrl(_plane, _tenantId, _succeeded, _searchText, _pageSize, Sort));
	}

	private void ClearFilters()
	{
		_plane = null;
		_tenantId = null;
		_succeeded = null;
		_searchText = string.Empty;
		NavigationManager.NavigateTo(BuildUrl(null, null, null, null, _pageSize, Sort));
	}

	private static string GetTargetLabel(AuditLogListItem item)
	{
		return string.IsNullOrWhiteSpace(item.TargetId)
			? item.TargetType
			: $"{item.TargetType} {item.TargetId}";
	}

	private static string DisplayOrDash(string? value)
	{
		return string.IsNullOrWhiteSpace(value) ? "-" : value;
	}

	private static string GetResultLabel(bool succeeded)
	{
		return succeeded ? "Succeeded" : "Denied";
	}

	private async Task LoadAsync(bool append = false)
	{
		var result = await AdministrationService.GetAuditLogsAsync(
			ListPagingDefaults.CreateRequest(_pageSize, append ? _items.Count : 0, Sort),
			Plane,
			TenantId,
			Succeeded,
			Search);
		_items = append ? _items.Concat(result.Items).ToArray() : result.Items;
		_totalCount = result.TotalCount;
		_hasMore = result.HasMore;
	}

	private async Task LoadMoreAsync()
	{
		_isLoadingMore = true;
		try
		{
			await LoadAsync(append: true);
		}
		finally
		{
			_isLoadingMore = false;
		}
	}

	private Task OnPageSizeChangedAsync(int pageSize)
	{
		NavigationManager.NavigateTo(BuildUrl(Plane, TenantId, Succeeded, Search, pageSize, Sort));
		return Task.CompletedTask;
	}

	private string GetSortUrl(string key)
	{
		return BuildUrl(Plane, TenantId, Succeeded, Search, _pageSize, PagingSort.Toggle(Sort, key));
	}

	private async Task<IReadOnlyList<PlatformTenantListItem>> LoadTenantOptionsAsync()
	{
		var items = new List<PlatformTenantListItem>();
		var offset = 0;
		while (true)
		{
			var result = await AdministrationService.GetPlatformTenantsAsync(
				new PagedQuery
				{
					Offset = offset,
					Limit = PagedQuery.MaxLimit
				});
			items.AddRange(result.Items);
			if (!result.HasMore)
			{
				return items;
			}

			offset += result.Items.Count;
		}
	}

	private static string BuildUrl(string? plane, int? tenantId, bool? succeeded, string? search, int pageSize, string? sort)
	{
		var queryParts = new List<string>
		{
			$"pageSize={pageSize}"
		};
		if (!string.IsNullOrWhiteSpace(plane))
		{
			queryParts.Add($"plane={Uri.EscapeDataString(plane)}");
		}
		if (tenantId.HasValue)
		{
			queryParts.Add($"tenantId={tenantId.Value}");
		}
		if (succeeded.HasValue)
		{
			queryParts.Add($"succeeded={succeeded.Value.ToString().ToLowerInvariant()}");
		}
		if (!string.IsNullOrWhiteSpace(search))
		{
			queryParts.Add($"search={Uri.EscapeDataString(search)}");
		}
		if (!string.IsNullOrWhiteSpace(sort))
		{
			queryParts.Add($"sort={Uri.EscapeDataString(sort)}");
		}

		return $"/admin/audit?{string.Join("&", queryParts)}";
	}
}
