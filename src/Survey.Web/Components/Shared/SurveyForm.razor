@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISurveyAdministrationService AdministrationService
@inject ISurveyExperienceService SurveyExperienceService
@inject ToastService ToastService

@if (_submitted)
{
	<div class="status-card narrow-card">
		<p class="eyebrow">Submission Complete</p>
		<h2>Thank you.</h2>
		<p class="mb-0">@_resultMessage</p>
	</div>
}
else
{
	<div class="survey-shell">
		<div class="list-card">
			<div class="page-header">
				<div>
					<p class="eyebrow">@(_session.IsStaffMode ? "Staff Submission" : "Recipient Survey")</p>
					<h2>@_session.SurveyName</h2>
					<p>@_session.VersionName</p>
				</div>
				@if (_session.IsExpired)
				{
					<span class="status-pill status-pill--danger">Expired</span>
				}
				else if (_session.IsCompleted)
				{
					<span class="status-pill status-pill--muted">Already submitted</span>
				}
				else
				{
					<span class="status-pill">Active</span>
				}
			</div>

			@if (!string.IsNullOrWhiteSpace(_errorMessage))
			{
				<div class="inline-banner inline-banner--danger mt-3">@_errorMessage</div>
			}

			@if (_session.IsExpired || _session.IsCompleted)
			{
				<div class="inline-banner mt-3">This assignment is no longer available for editing.</div>
			}
			else
			{
				<div class="survey-stepper mt-3">
					<div class="@GetStepClass(0)">Contact</div>
					@for (var index = 0; index < _session.Sections.Count; index++)
					{
						<div class="@GetStepClass(index + 1)">@_session.Sections[index].Title</div>
					}
				</div>
			}
		</div>

		@if (!_session.IsExpired && !_session.IsCompleted)
		{
			<div class="form-card">
				@if (_stepIndex == 0)
				{
					<div class="page-stack">
						<div class="page-header">
							<div>
								<h2>Contact Information</h2>
								<p>These details come from the assigned person and location, and can be confirmed or corrected before submission.</p>
							</div>
						</div>

						<div class="form-grid">
							<div class="field-stack">
								<label>First Name</label>
								<input class="form-control" @bind="_submission.Contact.FirstName" />
							</div>
							<div class="field-stack">
								<label>Middle Name</label>
								<input class="form-control" @bind="_submission.Contact.MiddleName" />
							</div>
							<div class="field-stack">
								<label>Last Name</label>
								<input class="form-control" @bind="_submission.Contact.LastName" />
							</div>
							<div class="field-stack">
								<label>Phone Type</label>
								<SearchableSelect class="form-control"
												  @bind-Value="_submission.Contact.PhoneLabel"
												  Options="ContactOptionCatalog.PhoneTypeOptions"
												  IncludeEmptyOption="true"
												  EmptyOptionLabel="Select a type" />
							</div>
							<div class="field-stack">
								<label>Phone Number</label>
								<input class="form-control" @bind="_submission.Contact.PhoneNumber" />
							</div>
							<div class="field-stack">
								<label>Best Time to Contact</label>
								<SearchableSelect class="form-control"
												  @bind-Value="_submission.Contact.BestTimeToContact"
												  Options="ContactOptionCatalog.BestTimeOptions"
												  IncludeEmptyOption="true"
												  EmptyOptionLabel="Select a time" />
							</div>
							<div class="field-stack">
								<label>Preferred Contact Method</label>
								<SearchableSelect class="form-control"
												  @bind-Value="_submission.Contact.PreferredContactMethod"
												  Options="ContactOptionCatalog.PreferredContactMethodOptions"
												  IncludeEmptyOption="true"
												  EmptyOptionLabel="Select a method" />
							</div>
							<div class="field-stack">
								<label>Email Type</label>
								<SearchableSelect class="form-control"
												  @bind-Value="_submission.Contact.EmailLabel"
												  Options="ContactOptionCatalog.EmailTypeOptions"
												  IncludeEmptyOption="true"
												  EmptyOptionLabel="Select a type" />
							</div>
							<div class="field-stack">
								<label>Email Address</label>
								<input class="form-control" type="email" @bind="_submission.Contact.Email" />
							</div>
						</div>

						<div class="card-grid mt-4">
							<section class="content-card">
								<div class="page-header">
									<div>
										<h2>Physical Address</h2>
										<p>Use the saved profile address if it better matches the current response.</p>
									</div>
									<div class="toolbar">
										<button class="btn btn-sm btn-outline-primary" type="button" @onclick="CopyProfilePhysicalToPhysical">Same as Profile Address</button>
									</div>
								</div>
								@AddressFields(_submission.Contact.PhysicalAddress, AddressMode.Physical)
							</section>

							<section class="content-card">
								<div class="page-header">
									<div>
										<h2>Mailing Address</h2>
										<p>Copy from the physical address or from the saved profile mailing address when that is quicker.</p>
									</div>
									<div class="toolbar">
										<button class="btn btn-sm btn-outline-primary" type="button" @onclick="CopyPhysicalToMailing">Same as Physical Address</button>
										<button class="btn btn-sm btn-outline-primary" type="button" @onclick="CopyProfileMailingToMailing">Same as Profile Mailing</button>
									</div>
								</div>
								@AddressFields(_submission.Contact.MailingAddress, AddressMode.Mailing)
							</section>
						</div>
					</div>
				}
				else
				{
					<div class="page-stack">
						<div class="page-header">
							<div>
								<h2>@CurrentSection!.Title</h2>
								@if (!string.IsNullOrWhiteSpace(CurrentSection.Description))
								{
									<p>@CurrentSection.Description</p>
								}
							</div>
						</div>

						@foreach (var question in CurrentSection.Questions)
						{
							<div class="question-card">
								<p class="question-card__prompt">@question.Prompt @(question.IsRequired ? "*" : string.Empty)</p>
								@if (!string.IsNullOrWhiteSpace(question.HelpText))
								{
									<p class="question-card__help">@question.HelpText</p>
								}

								@if (question.Type == SurveyQuestionType.YesNo)
								{
									<div class="option-stack">
										<label class="option-row">
											<input type="radio" name="question-@question.Id" checked="@(GetAnswer(question.Id).YesNoAnswer == true)" @onchange="@(() => SetYesNo(question.Id, true))" />
											<span>Yes</span>
										</label>
										<label class="option-row">
											<input type="radio" name="question-@question.Id" checked="@(GetAnswer(question.Id).YesNoAnswer == false)" @onchange="@(() => SetYesNo(question.Id, false))" />
											<span>No</span>
										</label>
									</div>
								}
								else if (question.Type == SurveyQuestionType.SingleChoice)
								{
									<div class="option-stack">
										@foreach (var option in question.Options)
										{
											<label class="option-row">
												<input type="radio" name="question-@question.Id" checked="@(GetAnswer(question.Id).SelectedOptionId == GetOptionId(option))" @onchange="@(() => SetSelectedOption(question.Id, GetOptionId(option)))" />
												<span>@option.Label</span>
											</label>
										}
									</div>
								}
								else if (question.Type == SurveyQuestionType.MultiSelect)
								{
									<div class="option-stack">
										@foreach (var option in question.Options)
										{
											<label class="option-row">
												<input type="checkbox" checked="@GetAnswer(question.Id).SelectedOptionIds.Contains(GetOptionId(option))" @onchange="@((ChangeEventArgs args) => ToggleSelectedOption(question.Id, GetOptionId(option), args.Value is bool checkedValue && checkedValue))" />
												<span>@option.Label</span>
											</label>
										}
									</div>
								}
								else
								{
									<textarea class="form-control" rows="5" @bind="GetAnswer(question.Id).TextAnswer"></textarea>
								}
							</div>
						}
					</div>
				}

				<div class="form-footer">
					@if (_stepIndex > 0)
					{
						<button class="btn btn-outline-primary" @onclick="PreviousStep" type="button">Previous</button>
					}
					@if (_stepIndex < _session.Sections.Count)
					{
						<button class="btn btn-primary" @onclick="NextStep" type="button">Next</button>
					}
					else
					{
						<button class="btn btn-primary" @onclick="SubmitAsync" type="button">Submit Survey</button>
					}
				</div>
			</div>
		}
	</div>
}

@code {
	[Parameter]
	[EditorRequired]
	public SurveySessionModel Session { get; set; } = default!;

	private SurveySessionModel _session = default!;
	private SurveySubmissionModel _submission = default!;
	private int _stepIndex;
	private bool _submitted;
	private string _resultMessage = string.Empty;
	private string? _errorMessage;

	private enum AddressMode
	{
		Physical,
		Mailing
	}

	protected override void OnParametersSet()
	{
		if (_session == Session)
		{
			return;
		}

		_session = Session;
		_submission = new SurveySubmissionModel
		{
			AssignmentId = Session.AssignmentId,
			Token = Session.Token,
			IsStaffMode = Session.IsStaffMode,
			Contact = new RespondentContactModel
			{
				FirstName = Session.Contact.FirstName,
				MiddleName = Session.Contact.MiddleName,
				LastName = Session.Contact.LastName,
				PhoneNumber = Session.Contact.PhoneNumber,
				PhoneLabel = Session.Contact.PhoneLabel,
				BestTimeToContact = Session.Contact.BestTimeToContact,
				PreferredContactMethod = Session.Contact.PreferredContactMethod,
				Email = Session.Contact.Email,
				EmailLabel = Session.Contact.EmailLabel,
				PhysicalAddress = CloneAddress(Session.Contact.PhysicalAddress),
				MailingAddress = CloneAddress(Session.Contact.MailingAddress),
				ProfilePhysicalAddress = CloneAddress(Session.Contact.ProfilePhysicalAddress),
				ProfileMailingAddress = CloneAddress(Session.Contact.ProfileMailingAddress)
			},
			Answers = Session.Sections
				.SelectMany(section => section.Questions)
				.Select(question => new SurveyAnswerInputModel { QuestionId = question.Id })
				.ToList()
		};
		_stepIndex = 0;
		_submitted = false;
		_resultMessage = string.Empty;
		_errorMessage = null;
	}

	private RenderFragment AddressFields(AddressInputModel address, AddressMode mode) => @<div class="form-grid">
		<div class="field-stack form-grid--single">
			<label>Country</label>
			<SearchableSelect class="form-control"
							  @bind-Value="address.CountryId"
							  AfterValueChanged="() => OnCountryChangedAsync(address)"
							  Options="address.CountryOptions"
							  IncludeEmptyOption="true"
							  EmptyOptionLabel="Select a country"
							  EmptyOptionValue="0" />
		</div>
		<div class="field-stack">
			<label>State / Territory</label>
			<SearchableSelect class="form-control"
							  @bind-Value="address.StateProvinceId"
							  AfterValueChanged="() => OnStateChangedAsync(address)"
							  Options="address.StateProvinceOptions"
							  IncludeEmptyOption="true"
							  EmptyOptionLabel="Select a state or territory"
							  EmptyOptionValue="0"
							  Disabled="@(address.CountryId <= 0)" />
		</div>
		<div class="field-stack">
			<label>County</label>
			<SearchableSelect class="form-control"
							  @bind-Value="address.CountyId"
							  Options="address.CountyOptions"
							  IncludeEmptyOption="true"
							  EmptyOptionLabel="Select a county"
							  Disabled="@(address.StateProvinceId <= 0)" />
		</div>
		<div class="field-stack form-grid--single">
			<label>Address Line 1</label>
			<InputText class="form-control" @bind-Value="address.AddressLine1" disabled="@(!address.CountyId.HasValue)" />
		</div>
		<div class="field-stack form-grid--single">
			<label>Address Line 2</label>
			<InputText class="form-control" @bind-Value="address.AddressLine2" disabled="@(!address.CountyId.HasValue)" />
		</div>
		<div class="field-stack">
			<label>City</label>
			<InputText class="form-control" @bind-Value="address.City" disabled="@(!address.CountyId.HasValue)" />
		</div>
		<div class="field-stack">
			<label>Postal Code</label>
			<InputText class="form-control" @bind-Value="address.PostalCode" disabled="@(!address.CountyId.HasValue)" />
		</div>
	</div>;

	private SurveyAnswerInputModel GetAnswer(int questionId)
	{
		return _submission.Answers.First(answer => answer.QuestionId == questionId);
	}

	private SurveySectionStepModel? CurrentSection =>
		_stepIndex > 0 && _stepIndex <= _session.Sections.Count
			? _session.Sections[_stepIndex - 1]
			: null;

	private static int GetOptionId(SelectOption option)
	{
		return int.Parse(option.Value);
	}

	private void SetYesNo(int questionId, bool value)
	{
		GetAnswer(questionId).YesNoAnswer = value;
	}

	private void SetSelectedOption(int questionId, int optionId)
	{
		GetAnswer(questionId).SelectedOptionId = optionId;
	}

	private void ToggleSelectedOption(int questionId, int optionId, bool isSelected)
	{
		var answer = GetAnswer(questionId);
		if (isSelected)
		{
			if (!answer.SelectedOptionIds.Contains(optionId))
			{
				answer.SelectedOptionIds.Add(optionId);
			}

			return;
		}

		answer.SelectedOptionIds.Remove(optionId);
	}

	private void NextStep()
	{
		if (!ValidateCurrentStep())
		{
			return;
		}

		_errorMessage = null;
		if (_stepIndex < _session.Sections.Count)
		{
			_stepIndex++;
		}
	}

	private void PreviousStep()
	{
		_errorMessage = null;
		if (_stepIndex > 0)
		{
			_stepIndex--;
		}
	}

	private async Task SubmitAsync()
	{
		if (!ValidateCurrentStep())
		{
			return;
		}

		try
		{
			var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
			var submittedByUserId = _session.IsStaffMode
				? authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value
				: null;
			var result = await SurveyExperienceService.SubmitAsync(_submission, submittedByUserId);
			if (!result.Succeeded)
			{
				_errorMessage = result.Message;
				if (_session.IsStaffMode)
				{
					ToastService.ShowError(result.Message, "Submission failed");
				}
				return;
			}

			_submitted = true;
			_resultMessage = result.Message;
			_errorMessage = null;
			if (_session.IsStaffMode)
			{
				ToastService.ShowSuccess(result.Message, "Survey submitted");
			}
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
			if (_session.IsStaffMode)
			{
				ToastService.ShowError(ex.Message, "Submission failed");
			}
		}
	}

	private bool ValidateCurrentStep()
	{
		return _stepIndex == 0
			? ValidateContactStep()
			: ValidateQuestionStep();
	}

	private bool ValidateContactStep()
	{
		var validationErrors = new List<ValidationResult>();
		var isValid = ValidateObject(_submission.Contact, validationErrors);

		if (isValid)
		{
			_errorMessage = null;
			return true;
		}

		_errorMessage = validationErrors.FirstOrDefault()?.ErrorMessage ?? "Complete the required contact information before continuing.";
		return false;
	}

	private bool ValidateQuestionStep()
	{
		if (CurrentSection is null)
		{
			_errorMessage = null;
			return true;
		}

		foreach (var question in CurrentSection.Questions.Where(question => question.IsRequired))
		{
			var answer = GetAnswer(question.Id);
			if (question.Type == SurveyQuestionType.YesNo && answer.YesNoAnswer is null)
			{
				_errorMessage = $"Answer the required question: {question.Prompt}";
				return false;
			}

			if (question.Type == SurveyQuestionType.SingleChoice && answer.SelectedOptionId is null)
			{
				_errorMessage = $"Choose an option for: {question.Prompt}";
				return false;
			}

			if (question.Type == SurveyQuestionType.MultiSelect && answer.SelectedOptionIds.Count == 0)
			{
				_errorMessage = $"Choose at least one option for: {question.Prompt}";
				return false;
			}

			if (question.Type == SurveyQuestionType.LongText && string.IsNullOrWhiteSpace(answer.TextAnswer))
			{
				_errorMessage = $"Enter a response for: {question.Prompt}";
				return false;
			}
		}

		_errorMessage = null;
		return true;
	}

	private static bool ValidateObject(object model, List<ValidationResult> validationErrors)
	{
		return Validator.TryValidateObject(model, new ValidationContext(model), validationErrors, true);
	}

	private async Task OnCountryChangedAsync(AddressInputModel address)
	{
		address.StateProvinceId = 0;
		address.CountyId = null;
		address.StateProvinceOptions = address.CountryId > 0
			? await AdministrationService.GetStateProvinceSelectOptionsAsync(address.CountryId)
			: Array.Empty<SelectOption>();
		address.CountyOptions = Array.Empty<SelectOption>();
	}

	private async Task OnStateChangedAsync(AddressInputModel address)
	{
		address.CountyId = null;
		address.CountyOptions = address.StateProvinceId > 0
			? await AdministrationService.GetCountySelectOptionsAsync(address.StateProvinceId)
			: Array.Empty<SelectOption>();
	}

	private void CopyProfilePhysicalToPhysical()
	{
		_submission.Contact.PhysicalAddress = CloneAddress(_submission.Contact.ProfilePhysicalAddress);
	}

	private void CopyPhysicalToMailing()
	{
		_submission.Contact.MailingAddress = CloneAddress(_submission.Contact.PhysicalAddress);
	}

	private void CopyProfileMailingToMailing()
	{
		_submission.Contact.MailingAddress = CloneAddress(_submission.Contact.ProfileMailingAddress);
	}

	private static AddressInputModel CloneAddress(AddressInputModel source)
	{
		return new AddressInputModel
		{
			AddressLine1 = source.AddressLine1,
			AddressLine2 = source.AddressLine2,
			City = source.City,
			CountryId = source.CountryId,
			StateProvinceId = source.StateProvinceId,
			CountyId = source.CountyId,
			PostalCode = source.PostalCode,
			CountryOptions = source.CountryOptions,
			StateProvinceOptions = source.StateProvinceOptions,
			CountyOptions = source.CountyOptions
		};
	}

	private string GetStepClass(int index)
	{
		return index == _stepIndex
			? "survey-stepper__item active"
			: "survey-stepper__item";
	}
}
