@page "/Account/Register"
@using System.ComponentModel.DataAnnotations
@using System.Text
@using System.Text.Encodings.Web
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@inject UserManager<ApplicationUser> UserManager
@inject IEmailSender<ApplicationUser> EmailSender
@inject global::Survey.Infrastructure.Persistence.InitialSetupStateService InitialSetupStateService
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Create Account</PageTitle>

<div class="status-card narrow-card">
	<p class="eyebrow">Step 1 of 4</p>
<h1>Create Account</h1>
	<p class="mb-4">Start with your email, username, and password. You’ll verify your email before continuing.</p>

	@if (!string.IsNullOrWhiteSpace(_errorMessage))
	{
		<div class="inline-banner inline-banner--danger mb-3">@_errorMessage</div>
	}

	<EditForm Model="Input" OnValidSubmit="RegisterAsync" FormName="register-account" method="post">
		<DataAnnotationsValidator />
		<ValidationSummary />

		<div class="form-grid">
			<div class="field-stack">
				<FieldLabel Text="Email" Required />
				<InputText class="form-control form-control-lg" @bind-Value="Input.Email" autocomplete="email username" />
				<ValidationMessage For="@(() => Input.Email)" />
			</div>
			<div class="field-stack">
				<FieldLabel Text="Username" Required />
				<InputText class="form-control form-control-lg" @bind-Value="Input.UserName" autocomplete="username" />
				<ValidationMessage For="@(() => Input.UserName)" />
			</div>
			<div class="field-stack">
				<FieldLabel Text="Password" Required />
				<SecretInput class="form-control form-control-lg" @bind-Value="Input.Password" autocomplete="new-password" />
				<ValidationMessage For="@(() => Input.Password)" />
			</div>
			<div class="field-stack">
				<FieldLabel Text="Confirm Password" Required />
				<SecretInput class="form-control form-control-lg" @bind-Value="Input.ConfirmPassword" autocomplete="new-password" />
				<ValidationMessage For="@(() => Input.ConfirmPassword)" />
			</div>
		</div>

		<div class="form-footer">
			<button class="btn btn-primary" type="submit" disabled="@_isSaving">Continue</button>
			<a class="btn btn-outline-primary" href="Account/Login">Cancel</a>
		</div>
	</EditForm>
</div>

@code {
	private bool _isSaving;
	private string? _errorMessage;

	[SupplyParameterFromForm]
	private RegisterAccountModel Input { get; set; } = default!;

	[SupplyParameterFromQuery]
	private string? ReturnUrl { get; set; }

	[SupplyParameterFromQuery(Name = "email")]
	private string? PrefilledEmail { get; set; }

	protected override async Task OnInitializedAsync()
	{
		var setupState = await InitialSetupStateService.GetStatusAsync();
		if (!setupState.HasUsers)
		{
			NavigationManager.NavigateTo("/setup", forceLoad: true);
			return;
		}

		if (!setupState.IsComplete)
		{
			NavigationManager.NavigateTo("/Account/Login", forceLoad: true);
			return;
		}

		Input ??= new();
		if (string.IsNullOrWhiteSpace(Input.Email) && !string.IsNullOrWhiteSpace(PrefilledEmail))
		{
			Input.Email = PrefilledEmail;
		}
	}

	private async Task RegisterAsync()
	{
		if (_isSaving)
		{
			return;
		}

		_isSaving = true;
		_errorMessage = null;

		try
		{
			var trimmedEmail = Input.Email.Trim();
			var trimmedUserName = Input.UserName.Trim();
			var existingUser = await UserManager.FindByEmailAsync(trimmedEmail);
			if (existingUser is not null)
			{
				throw new InvalidOperationException("An account with that email already exists.");
			}

			var existingUserName = await UserManager.FindByNameAsync(trimmedUserName);
			if (existingUserName is not null)
			{
				throw new InvalidOperationException("That username is already in use.");
			}

			var user = new ApplicationUser
			{
				UserName = trimmedUserName,
				Email = trimmedEmail,
				EmailConfirmed = false,
				IsPlatformSuperAdmin = false,
				IsPlatformUserEnabled = false
			};
			UserAvatarPalette.EnsureAssigned(user);

			var createResult = await UserManager.CreateAsync(user, Input.Password);
			if (!createResult.Succeeded)
			{
				throw new InvalidOperationException(string.Join("; ", createResult.Errors.Select(static error => error.Description)));
			}

			var userId = await UserManager.GetUserIdAsync(user);
			var code = await UserManager.GenerateEmailConfirmationTokenAsync(user);
			code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(code));
			var callbackUrl = NavigationManager.GetUriWithQueryParameters(
				NavigationManager.ToAbsoluteUri("Account/ConfirmEmail").AbsoluteUri,
				new Dictionary<string, object?>
				{
					["userId"] = userId,
					["code"] = code,
					["returnUrl"] = ReturnUrl
				});

			await EmailSender.SendConfirmationLinkAsync(user, trimmedEmail, HtmlEncoder.Default.Encode(callbackUrl));
			RedirectManager.RedirectTo("Account/RegisterConfirmation", new()
			{
				["email"] = trimmedEmail,
				["returnUrl"] = ReturnUrl
			});
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
		finally
		{
			_isSaving = false;
		}
	}

	private sealed class RegisterAccountModel
	{
		[Required]
		[EmailAddress]
		[StringLength(256)]
		public string Email { get; set; } = string.Empty;

		[Required]
		[StringLength(256)]
		public string UserName { get; set; } = string.Empty;

		[Required]
		[StringLength(100)]
		[DataType(DataType.Password)]
		public string Password { get; set; } = string.Empty;

		[Required]
		[StringLength(100)]
		[DataType(DataType.Password)]
		[Compare(nameof(Password))]
		public string ConfirmPassword { get; set; } = string.Empty;
	}
}
