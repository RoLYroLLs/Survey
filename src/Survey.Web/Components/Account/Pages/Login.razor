@page "/Account/Login"
@attribute [AllowAnonymous]

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager
@inject global::Survey.Infrastructure.Persistence.InitialSetupStateService InitialSetupStateService

<PageTitle>Log in</PageTitle>

<div class="page-stack">
	<div class="form-card narrow-card">
		<StatusMessage Message="@errorMessage" />
		<EditForm EditContext="editContext" method="post" OnSubmit="LoginUser" FormName="login">
			<DataAnnotationsValidator />
			<div class="page-stack">
				<h1>Log in</h1>
				<ValidationSummary class="text-danger" role="alert" />
				<div class="mb-3">
					<label for="Input.Identifier" class="form-label">Username or Email</label>
					<InputText @bind-Value="Input.Identifier" id="Input.Identifier" class="form-control form-control-lg" autocomplete="username webauthn" aria-required="true" placeholder="Username or name@example.com" />
					<ValidationMessage For="() => Input.Identifier" class="text-danger" />
				</div>
				<div class="mb-3">
					<label for="Input.Password" class="form-label">Password</label>
					<SecretInput @bind-Value="Input.Password" Id="Input.Password" class="form-control form-control-lg" autocomplete="current-password" aria-required="true" placeholder="Password" />
					<ValidationMessage For="() => Input.Password" class="text-danger" />
				</div>
				<div class="toolbar toolbar--between toolbar--auth-options mb-3">
					<label class="form-label mb-0">
						<InputCheckbox @bind-Value="Input.RememberMe" class="darker-border-checkbox form-check-input" />
						Remember me
					</label>
					<a href="Account/ForgotPassword">Forgot Password?</a>
				</div>
				<div class="page-stack">
					<button type="submit" class="w-100 btn btn-lg btn-primary">Log in</button>
					<PasskeySubmit Operation="PasskeyOperation.Request" Name="PasskeyInput" EmailName="Input.Identifier" class="w-100 btn btn-lg btn-outline-secondary">Log in with passkey</PasskeySubmit>
					@if (_canCreateAccount)
					{
						<p class="text-center mb-0">Don't have an account? <a href="@GetRegisterUrl()">Sign up</a></p>
					}
				</div>
			</div>
		</EditForm>
	</div>
</div>

@code {
    private string? errorMessage;
    private EditContext editContext = default!;
	private bool _canCreateAccount;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

	protected override async Task OnInitializedAsync()
	{
		var setupState = await InitialSetupStateService.GetStatusAsync();
		if (!setupState.HasUsers)
		{
			NavigationManager.NavigateTo("/setup", forceLoad: true);
			return;
		}

		_canCreateAccount = setupState.IsComplete;

        Input ??= new();
		PasskeyInput ??= new();

        editContext = new EditContext(Input);

		if (HttpMethods.IsGet(HttpContext.Request.Method))
		{
            // Clear the existing external cookie to ensure a clean login process
            await HttpContext.SignOutAsync(IdentityConstants.ExternalScheme);
        }
    }

	public async Task LoginUser()
	{
        if (!string.IsNullOrWhiteSpace(PasskeyInput.CredentialJson) || !string.IsNullOrWhiteSpace(PasskeyInput.Error))
        {
            await LoginWithPasskeyAsync();
            return;
        }

		if (!editContext.Validate())
		{
			return;
		}

		if (string.IsNullOrWhiteSpace(Input.Password))
		{
			errorMessage = "Error: The Password field is required.";
			return;
		}

        // This doesn't count login failures towards account lockout
        // To enable password failures to trigger account lockout, set lockoutOnFailure: true
        var user = await FindUserForSignInAsync(Input.Identifier);
        if (user is null)
        {
            errorMessage = "Error: Invalid login attempt.";
            return;
        }

		var result = await SignInManager.PasswordSignInAsync(user, Input.Password!, Input.RememberMe, lockoutOnFailure: false);
		await HandleLoginResultAsync(result, user);
	}

	private async Task LoginWithPasskeyAsync()
	{
		if (!string.IsNullOrWhiteSpace(PasskeyInput.Error))
		{
			errorMessage = $"Error: {PasskeyInput.Error}";
			return;
		}

		if (string.IsNullOrWhiteSpace(PasskeyInput.CredentialJson))
		{
			errorMessage = "Error: The browser did not provide a passkey.";
			return;
		}

		var result = await SignInManager.PasskeySignInAsync(PasskeyInput.CredentialJson);
		var user = await UserManager.GetUserAsync(HttpContext.User);
		await HandleLoginResultAsync(result, user);
	}

	private async Task HandleLoginResultAsync(SignInResult result, ApplicationUser? user)
	{
		if (result.Succeeded)
		{
			var setupState = await InitialSetupStateService.GetStatusAsync();
			if (!setupState.IsComplete)
			{
				if (user is null || !user.IsBootstrapPlatformOwner)
				{
					await SignInManager.SignOutAsync();
					errorMessage = "Error: The platform setup is still in progress. Only the initial platform super admin can sign in until setup is complete.";
					return;
				}

				Logger.LogInformation("Bootstrap platform owner logged in during initial setup.");
				RedirectManager.RedirectTo("/setup/initial-seeding");
				return;
			}

			Logger.LogInformation("User logged in.");
			RedirectManager.RedirectTo(GetPostLoginUrl());
		}
		else if (result.RequiresTwoFactor)
		{
			RedirectManager.RedirectTo(
				"Account/LoginWith2fa",
				new() { ["returnUrl"] = ReturnUrl, ["rememberMe"] = Input.RememberMe });
		}
		else if (result.IsLockedOut)
		{
			Logger.LogWarning("User account locked out.");
			RedirectManager.RedirectTo("Account/Lockout");
		}
		else if (result.IsNotAllowed)
		{
			errorMessage = "Error: Confirm your email before logging in.";
		}
		else
		{
			errorMessage = "Error: Invalid login attempt.";
		}

		return;
	}

	private string GetRegisterUrl()
	{
		return string.IsNullOrWhiteSpace(ReturnUrl)
			? "Account/Register"
			: $"Account/Register?returnUrl={Uri.EscapeDataString(ReturnUrl)}";
	}

	private string GetPostLoginUrl()
	{
		return string.IsNullOrWhiteSpace(ReturnUrl)
			? "/app"
			: ReturnUrl;
	}

    private async Task<ApplicationUser?> FindUserForSignInAsync(string identifier)
    {
        var trimmedIdentifier = identifier.Trim();
        if (string.IsNullOrWhiteSpace(trimmedIdentifier))
        {
            return null;
        }

        var normalizedUserName = UserManager.NormalizeName(trimmedIdentifier);
        var normalizedEmail = UserManager.NormalizeEmail(trimmedIdentifier);
        var userMatches = await UserManager.Users
            .Where(user => user.NormalizedUserName == normalizedUserName || user.NormalizedEmail == normalizedEmail)
            .Take(3)
            .ToListAsync();

        if (userMatches.Count == 0)
        {
            return null;
        }

        var userNameMatch = userMatches.FirstOrDefault(user => string.Equals(user.NormalizedUserName, normalizedUserName, StringComparison.Ordinal));
        var emailMatch = userMatches.FirstOrDefault(user => string.Equals(user.NormalizedEmail, normalizedEmail, StringComparison.Ordinal));

        if (trimmedIdentifier.Contains('@'))
        {
            return emailMatch ?? userNameMatch;
        }

        return userNameMatch ?? emailMatch;
    }

    private sealed class InputModel
    {
        [Required]
        [StringLength(256)]
        public string Identifier { get; set; } = "";

        [DataType(DataType.Password)]
        public string? Password { get; set; }

        [Display(Name = "Remember me?")]
        public bool RememberMe { get; set; }
    }

	[SupplyParameterFromForm(FormName = "login")]
	private PasskeyInputModel PasskeyInput { get; set; } = default!;
}
