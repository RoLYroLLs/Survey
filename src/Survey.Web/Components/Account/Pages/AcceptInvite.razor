@page "/Account/AcceptInvite"
@using Microsoft.AspNetCore.Identity
@inject ITenantAdministrationService AdministrationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager NavigationManager

<PageTitle>Accept Invite</PageTitle>

<div class="status-card narrow-card">
	<p class="eyebrow">Tenant Invitation</p>
	<h1>Accept invitation</h1>

	@if (_context is null)
	{
		<p>Loading invitation...</p>
	}
	else if (!_context.IsValid)
	{
		<div class="inline-banner inline-banner--danger">@_context.ErrorMessage</div>
		<div class="form-footer">
			<a class="btn btn-outline-primary" href="Account/Login">Back to Login</a>
		</div>
	}
	else
	{
		<div class="page-stack">
			<div class="inline-banner inline-banner--info">
				You were invited to join <strong>@_context.TenantName</strong> as <strong>@_context.Role</strong>.
			</div>
			<p><strong>Invited email:</strong> @_context.Email</p>
			@if (_context.ExpiresAtUtc.HasValue)
			{
				<p><strong>Expires:</strong> @_context.ExpiresAtUtc.Value.ToLocalTime().ToString("f")</p>
			}

			@if (!string.IsNullOrWhiteSpace(_errorMessage))
			{
				<div class="inline-banner inline-banner--danger">@_errorMessage</div>
			}

			@if (_context.ExistingAccountFound)
			{
				@if (!_isAuthenticated)
				{
					<p>An account already exists for this email address. Sign in first, then reopen this invitation.</p>
					<div class="form-footer">
						<a class="btn btn-primary" href="@GetLoginUrl()">Sign In</a>
					</div>
				}
				else if (!_isMatchingUser)
				{
					<p>You are signed in as <strong>@_currentEmail</strong>. Sign in with <strong>@_context.Email</strong> to accept this invitation.</p>
					<div class="form-footer">
						<a class="btn btn-primary" href="@GetLoginUrl()">Switch Account</a>
					</div>
				}
				else
				{
					<div class="form-footer">
						<button class="btn btn-primary" type="button" @onclick="AcceptExistingAsync">Accept Invitation</button>
					</div>
				}
			}
			else if (_isAuthenticated)
			{
				<p>Sign out of the current account before creating the invited account for <strong>@_context.Email</strong>.</p>
			}
			else
			{
				<EditForm Model="_registrationModel" OnValidSubmit="AcceptNewAsync">
					<DataAnnotationsValidator />
					<ValidationSummary />

					<div class="form-grid">
						<div class="field-stack">
							<FieldLabel Text="First Name" Required />
							<InputText class="form-control" @bind-Value="_registrationModel.FirstName" />
							<ValidationMessage For="@(() => _registrationModel.FirstName)" />
						</div>
						<div class="field-stack">
							<FieldLabel Text="Last Name" Required />
							<InputText class="form-control" @bind-Value="_registrationModel.LastName" />
							<ValidationMessage For="@(() => _registrationModel.LastName)" />
						</div>
						<div class="field-stack">
							<FieldLabel Text="Password" Required />
							<SecretInput class="form-control" @bind-Value="_registrationModel.Password" />
							<ValidationMessage For="@(() => _registrationModel.Password)" />
						</div>
						<div class="field-stack">
							<FieldLabel Text="Confirm Password" Required />
							<SecretInput class="form-control" @bind-Value="_registrationModel.ConfirmPassword" />
							<ValidationMessage For="@(() => _registrationModel.ConfirmPassword)" />
						</div>
					</div>

					<div class="form-footer">
						<button class="btn btn-primary" type="submit">Create Account and Join Tenant</button>
					</div>
				</EditForm>
			}
		</div>
	}
</div>

@code {
	[SupplyParameterFromQuery(Name = "token")]
	public string? Token { get; set; }

	private TenantInvitationAcceptanceContextModel? _context;
	private readonly TenantInvitationRegistrationModel _registrationModel = new();
	private string? _errorMessage;
	private bool _isAuthenticated;
	private bool _isMatchingUser;
	private string? _currentUserId;
	private string? _currentEmail;

	protected override async Task OnParametersSetAsync()
	{
		_errorMessage = null;
		_registrationModel.Token = Token ?? string.Empty;
		_context = await AdministrationService.GetTenantInvitationAcceptanceAsync(Token ?? string.Empty);

		var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
		var principal = authenticationState.User;
		_isAuthenticated = principal.Identity?.IsAuthenticated == true;

		if (_isAuthenticated)
		{
			var user = await UserManager.GetUserAsync(principal);
			_currentUserId = user?.Id;
			_currentEmail = user?.Email;
		}
		else
		{
			_currentUserId = null;
			_currentEmail = null;
		}

		_isMatchingUser = _isAuthenticated
			&& !string.IsNullOrWhiteSpace(_currentEmail)
			&& _context is not null
			&& string.Equals(_currentEmail, _context.Email, StringComparison.OrdinalIgnoreCase);
	}

	private async Task AcceptExistingAsync()
	{
		if (string.IsNullOrWhiteSpace(_currentUserId) || _context is null)
		{
			return;
		}

		try
		{
			var userId = await AdministrationService.AcceptTenantInvitationForExistingUserAsync(_context.Token, _currentUserId);
			var user = await UserManager.FindByIdAsync(userId);
			if (user is not null)
			{
				await SignInManager.RefreshSignInAsync(user);
			}

			NavigationManager.NavigateTo("/app", forceLoad: true);
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
	}

	private async Task AcceptNewAsync()
	{
		try
		{
			var userId = await AdministrationService.AcceptTenantInvitationForNewUserAsync(_registrationModel);
			var user = await UserManager.FindByIdAsync(userId)
				?? throw new InvalidOperationException("The new account could not be loaded after creation.");
			await SignInManager.SignInAsync(user, isPersistent: false);
			NavigationManager.NavigateTo("/app", forceLoad: true);
		}
		catch (Exception ex)
		{
			_errorMessage = ex.Message;
		}
	}

	private string GetLoginUrl()
	{
		return $"Account/Login?returnUrl={Uri.EscapeDataString($"/Account/AcceptInvite?token={Token}")}";
	}
}
