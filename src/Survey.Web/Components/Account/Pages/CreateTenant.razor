@page "/Account/CreateTenant"
@page "/admin/tenants/new"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject SurveyDbContext DbContext
@inject Survey.Infrastructure.Security.TenantExecutionContext TenantExecutionContext
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Create Tenant</PageTitle>

<div class="status-card narrow-card">
	<p class="eyebrow">@(_hasExistingTenantMembership ? "Tenant Setup" : "Step 4 of 4")</p>
			<h1>Create Tenant</h1>
	<p class="mb-4">@(_hasExistingTenantMembership
		? "Create another tenant for yourself and you'll become its owner automatically."
		: "Your first tenant is where you'll manage people, assignments, responses, and reporting.")</p>

	@if (!string.IsNullOrWhiteSpace(_errorMessage))
	{
		<div class="inline-banner inline-banner--danger mb-3">@_errorMessage</div>
	}

	@if (!_isReady)
	{
		<p>Loading tenant setup...</p>
	}
	else
	{
		<EditForm Model="Input" OnValidSubmit="CreateTenantAsync" FormName="create-tenant" method="post">
			<DataAnnotationsValidator />
			<ValidationSummary />

			<div class="field-stack">
				<FieldLabel Text="Tenant Name" Required />
				<InputText class="form-control form-control-lg" @bind-Value="Input.TenantName" />
				<ValidationMessage For="@(() => Input.TenantName)" />
			</div>

			<div class="form-footer">
				<button class="btn btn-lg btn-primary" type="submit" disabled="@_isSaving">Create Tenant</button>
			</div>
		</EditForm>
	}
</div>

@code {
	private bool _isReady;
	private bool _isSaving;
	private string? _errorMessage;
	private ApplicationUser? _user;
	private bool _hasExistingTenantMembership;

	[SupplyParameterFromForm]
	private CreateTenantModel Input { get; set; } = default!;

	[SupplyParameterFromQuery]
	private string? ReturnUrl { get; set; }

	protected override async Task OnInitializedAsync()
	{
		Input ??= new();

		var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
		_user = await UserManager.GetUserAsync(authenticationState.User);
		if (_user is null)
		{
			_errorMessage = "The signed-in account could not be loaded.";
			return;
		}

		_hasExistingTenantMembership = await DbContext.TenantMemberships
			.AsNoTracking()
			.AnyAsync(membership => membership.UserId == _user.Id);

		if (!_hasExistingTenantMembership && !_user.HasCompletedSelfSignupProfile())
		{
			RedirectManager.RedirectTo(BuildProfileUrl());
			return;
		}

		if (string.IsNullOrWhiteSpace(Input.TenantName))
		{
			Input.TenantName = _hasExistingTenantMembership ? "My New Tenant" : "Default Tenant";
		}

		_isReady = true;
	}

	private async Task CreateTenantAsync()
	{
		if (_isSaving || _user is null)
		{
			return;
		}

		_isSaving = true;
		_errorMessage = null;
		var transactionCommitted = false;

		await using var transaction = await DbContext.Database.BeginTransactionAsync();

		try
		{
			var tenant = new Tenant(Input.TenantName);
			var duplicateOwnedTenantExists = await DbContext.TenantMemberships
				.AsNoTracking()
				.AnyAsync(
					membership => membership.UserId == _user.Id
						&& membership.Role == TenantRole.Owner
						&& membership.Tenant.Slug == tenant.Slug);
			if (duplicateOwnedTenantExists)
			{
				throw new InvalidOperationException("You already own a tenant with that name. Please choose a different tenant name.");
			}

			DbContext.Tenants.Add(tenant);
			await DbContext.SaveChangesAsync();

			var membership = new TenantMembership(tenant.Id, _user.Id, TenantRole.Owner);
			DbContext.TenantMemberships.Add(membership);
			await DbContext.SaveChangesAsync();

			_user.ActiveTenantMembershipId = membership.Id;
			var updateResult = await UserManager.UpdateAsync(_user);
			if (!updateResult.Succeeded)
			{
				throw new InvalidOperationException(string.Join("; ", updateResult.Errors.Select(static error => error.Description)));
			}
			var siteDefaultThemeKey = await DbContext.SiteSettings
				.AsNoTracking()
				.Where(setting => setting.Id == SiteSetting.DefaultId)
				.Join(
					DbContext.PlatformThemes.AsNoTracking(),
					setting => setting.ThemePresetKey,
					theme => theme.Key,
					(setting, _) => setting.ThemePresetKey)
				.FirstOrDefaultAsync();
			if (!string.IsNullOrWhiteSpace(siteDefaultThemeKey))
			{
				TenantExecutionContext.UseTenant(tenant.Id);
				DbContext.TenantSettings.Add(new TenantSetting(tenant.Id, siteDefaultThemeKey));
				await DbContext.SaveChangesAsync();
			}
			await transaction.CommitAsync();
			transactionCommitted = true;

			await SignInManager.RefreshSignInAsync(_user);
			NavigationManager.NavigateTo(GetPostCreateUrl(), forceLoad: true);
		}
		catch (Exception ex)
		{
			if (!transactionCommitted)
			{
				await transaction.RollbackAsync();
			}

			_errorMessage = ex.Message;
		}
		finally
		{
			_isSaving = false;
		}
	}

	private string BuildProfileUrl()
	{
		return string.IsNullOrWhiteSpace(ReturnUrl)
			? "Account/CompleteProfile"
			: $"Account/CompleteProfile?returnUrl={Uri.EscapeDataString(ReturnUrl)}";
	}

	private string GetPostCreateUrl()
	{
		if (!string.IsNullOrWhiteSpace(ReturnUrl)
			&& Uri.IsWellFormedUriString(ReturnUrl, UriKind.Relative)
			&& ReturnUrl.StartsWith('/'))
		{
			return ReturnUrl;
		}

		return "/app";
	}

	private sealed class CreateTenantModel
	{
		[Required]
		[StringLength(200)]
		public string TenantName { get; set; } = "Default Tenant";
	}
}
