@page "/Account/ForgotPasswordConfirmation"
@attribute [AllowAnonymous]

<PageTitle>Forgot Password Confirmation</PageTitle>

<div class="form-card narrow-card">
	<div class="page-stack">
		<h1>Check Your Email</h1>
		<p role="alert">If the account exists, a password reset link has been sent.</p>
		<div class="toolbar">
			<a class="btn btn-primary btn-lg" href="/Account/Login">Back to Login</a>
		</div>
	</div>
</div>
