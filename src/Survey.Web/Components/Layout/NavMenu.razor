@implements IDisposable
@inject NavigationManager NavigationManager
@inject ITenantContextAccessor TenantContextAccessor
@inject Microsoft.AspNetCore.Identity.SignInManager<ApplicationUser> SignInManager

<div class="nav-shell">
	<nav class="nav-shell__links">
		@if (IsAccountManageSection)
		{
			@if (CanSeeBackToTenant)
			{
				<a class="nav-shell__back-link nav-shell__back-link--spaced" href="app">
					<span class="nav-shell__icon"><OutlineIcon Name="back" CssClass="nav-shell__icon-svg" /></span>
					<span>Back to Tenant</span>
				</a>
			}
			<p class="nav-shell__caption">Account</p>
			<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="Account/Manage" Match="NavLinkMatch.All">
				<span class="nav-shell__icon"><OutlineIcon Name="settings" CssClass="nav-shell__icon-svg" /></span>
				<span>Profile</span>
			</NavLink>
			<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="Account/Manage/Email">
				<span class="nav-shell__icon"><OutlineIcon Name="email" CssClass="nav-shell__icon-svg" /></span>
				<span>Email</span>
			</NavLink>
			<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="Account/Manage/ChangePassword">
				<span class="nav-shell__icon"><OutlineIcon Name="password" CssClass="nav-shell__icon-svg" /></span>
				<span>Password</span>
			</NavLink>
			@if (_hasExternalLogins)
			{
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="Account/Manage/ExternalLogins">
					<span class="nav-shell__icon"><OutlineIcon Name="platform" CssClass="nav-shell__icon-svg" /></span>
					<span>External logins</span>
				</NavLink>
			}
			<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="Account/Manage/TwoFactorAuthentication">
				<span class="nav-shell__icon"><OutlineIcon Name="security" CssClass="nav-shell__icon-svg" /></span>
				<span>Two-factor authentication</span>
			</NavLink>
			<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="Account/Manage/Passkeys">
				<span class="nav-shell__icon"><OutlineIcon Name="passkey" CssClass="nav-shell__icon-svg" /></span>
				<span>Passkeys</span>
			</NavLink>
			<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="Account/Manage/PersonalData">
				<span class="nav-shell__icon"><OutlineIcon Name="profile" CssClass="nav-shell__icon-svg" /></span>
				<span>Personal data</span>
			</NavLink>
		}
		else if (IsPlatformSection)
		{
			@if (IsPlatformSystemSection)
			{
				<a class="nav-shell__back-link nav-shell__back-link--spaced" href="admin">
					<span class="nav-shell__icon"><OutlineIcon Name="back" CssClass="nav-shell__icon-svg" /></span>
					<span>Back to Platform Admin</span>
				</a>
				<p class="nav-shell__caption">System</p>
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/system" Match="NavLinkMatch.All">
					<span class="nav-shell__icon"><OutlineIcon Name="settings" CssClass="nav-shell__icon-svg" /></span>
					<span>Home</span>
				</NavLink>
				<p class="nav-shell__caption">Error</p>
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/system/errors" Match="NavLinkMatch.All">
					<span class="nav-shell__icon"><OutlineIcon Name="audit" CssClass="nav-shell__icon-svg" /></span>
					<span>Catalog</span>
				</NavLink>
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/system/errors/global">
					<span class="nav-shell__icon"><OutlineIcon Name="platform" CssClass="nav-shell__icon-svg" /></span>
					<span>Global Error</span>
				</NavLink>
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/system/errors/setup">
					<span class="nav-shell__icon"><OutlineIcon Name="settings" CssClass="nav-shell__icon-svg" /></span>
					<span>Setup Error</span>
				</NavLink>
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/system/errors/form">
					<span class="nav-shell__icon"><OutlineIcon Name="profile" CssClass="nav-shell__icon-svg" /></span>
					<span>Form Error</span>
				</NavLink>
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/system/errors/not-found">
					<span class="nav-shell__icon"><OutlineIcon Name="search" CssClass="nav-shell__icon-svg" /></span>
					<span>Not Found</span>
				</NavLink>
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/system/errors/access-denied">
					<span class="nav-shell__icon"><OutlineIcon Name="security" CssClass="nav-shell__icon-svg" /></span>
					<span>Access Denied</span>
				</NavLink>
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/system/errors/lockout">
					<span class="nav-shell__icon"><OutlineIcon Name="password" CssClass="nav-shell__icon-svg" /></span>
					<span>Lockout</span>
				</NavLink>
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/system/errors/invalid-user">
					<span class="nav-shell__icon"><OutlineIcon Name="users" CssClass="nav-shell__icon-svg" /></span>
					<span>Invalid User</span>
				</NavLink>
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/system/errors/invalid-password-reset">
					<span class="nav-shell__icon"><OutlineIcon Name="email" CssClass="nav-shell__icon-svg" /></span>
					<span>Invalid Password Reset</span>
				</NavLink>
			}
			else
			{
				@if (CanSeeBackToTenant)
				{
					<a class="nav-shell__back-link nav-shell__back-link--spaced" href="app">
						<span class="nav-shell__icon"><OutlineIcon Name="back" CssClass="nav-shell__icon-svg" /></span>
						<span>Back to Tenant</span>
					</a>
				}
				@if (CanSeePlatformSection)
				{
					<p class="nav-shell__caption">Platform</p>
				}
				@if (CanSeePlatformHome)
				{
					<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin" Match="NavLinkMatch.All">
						<span class="nav-shell__icon"><OutlineIcon Name="home" CssClass="nav-shell__icon-svg" /></span>
						<span>Home</span>
					</NavLink>
				}
				@if (CanSeePlatformUsers)
				{
					<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/users">
						<span class="nav-shell__icon"><OutlineIcon Name="users" CssClass="nav-shell__icon-svg" /></span>
						<span>Users</span>
					</NavLink>
				}
				@if (CanSeePlatformTenants)
				{
					<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/tenants">
						<span class="nav-shell__icon"><OutlineIcon Name="tenant" CssClass="nav-shell__icon-svg" /></span>
						<span>Tenants</span>
					</NavLink>
				}

				@if (CanSeePlatformJobs || CanSeePlatformEmails)
				{
					<p class="nav-shell__caption">Operations</p>
				}
				@if (CanSeePlatformJobs)
				{
					<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/jobs">
						<span class="nav-shell__icon"><OutlineIcon Name="platform" CssClass="nav-shell__icon-svg" /></span>
						<span>Jobs</span>
					</NavLink>
				}
				@if (CanSeePlatformEmails)
				{
					<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/emails">
						<span class="nav-shell__icon"><OutlineIcon Name="email" CssClass="nav-shell__icon-svg" /></span>
						<span>Emails</span>
					</NavLink>
				}

				@if (CanSeePlatformAudit)
				{
					<p class="nav-shell__caption">Governance</p>
					<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/audit">
						<span class="nav-shell__icon"><OutlineIcon Name="audit" CssClass="nav-shell__icon-svg" /></span>
						<span>Audit</span>
					</NavLink>
				}

				@if (CanSeePlatformThemes)
				{
					<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/themes">
						<span class="nav-shell__icon"><OutlineIcon Name="theme" CssClass="nav-shell__icon-svg" /></span>
						<span>Themes</span>
					</NavLink>
				}
				@if (CanSeePlatformGeography)
				{
					<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/countries">
						<span class="nav-shell__icon"><OutlineIcon Name="country" CssClass="nav-shell__icon-svg" /></span>
						<span>Countries</span>
					</NavLink>
					<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/state-provinces">
						<span class="nav-shell__icon"><OutlineIcon Name="state" CssClass="nav-shell__icon-svg" /></span>
						<span>States / Territories</span>
					</NavLink>
					<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/counties">
						<span class="nav-shell__icon"><OutlineIcon Name="county" CssClass="nav-shell__icon-svg" /></span>
						<span>Counties</span>
					</NavLink>
					<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/addresses">
						<span class="nav-shell__icon"><OutlineIcon Name="address" CssClass="nav-shell__icon-svg" /></span>
						<span>Addresses</span>
					</NavLink>
					<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/zip-mappings">
						<span class="nav-shell__icon"><OutlineIcon Name="zip" CssClass="nav-shell__icon-svg" /></span>
						<span>ZIP Mappings</span>
					</NavLink>
				}
				@if (CanSeePlatformSystem)
				{
					<p class="nav-shell__caption">System</p>
					<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin/system">
						<span class="nav-shell__icon"><OutlineIcon Name="settings" CssClass="nav-shell__icon-svg" /></span>
						<span>Settings</span>
					</NavLink>
				}
			}
		}
		else
		{
			@if (CanSeeOverviewSection)
			{
				<p class="nav-shell__caption">Overview</p>
			}
			@if (CanSeeDashboard)
			{
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="app" Match="NavLinkMatch.All">
					<span class="nav-shell__icon"><OutlineIcon Name="dashboard" CssClass="nav-shell__icon-svg" /></span>
					<span>Dashboard</span>
				</NavLink>
			}

			@if (CanSeeSurveyOperationsSection)
			{
				<p class="nav-shell__caption">Survey Operations</p>
			}
			@if (CanSeePeople)
			{
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="app/people">
					<span class="nav-shell__icon"><OutlineIcon Name="people" CssClass="nav-shell__icon-svg" /></span>
					<span>People</span>
				</NavLink>
			}
			@if (CanSeeAssignments)
			{
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="app/assignments">
					<span class="nav-shell__icon"><OutlineIcon Name="assignments" CssClass="nav-shell__icon-svg" /></span>
					<span>Assignments</span>
				</NavLink>
			}
			@if (CanSeeResponses)
			{
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="app/responses">
					<span class="nav-shell__icon"><OutlineIcon Name="responses" CssClass="nav-shell__icon-svg" /></span>
					<span>Responses</span>
				</NavLink>
			}

			@if (CanSeeSurveyBuilderSection)
			{
				<p class="nav-shell__caption">Survey Builder</p>
			}
			@if (CanSeeSurveyBuilder)
			{
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="app/surveys">
					<span class="nav-shell__icon"><OutlineIcon Name="surveys" CssClass="nav-shell__icon-svg" /></span>
					<span>Surveys</span>
				</NavLink>
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="app/versions">
					<span class="nav-shell__icon"><OutlineIcon Name="versions" CssClass="nav-shell__icon-svg" /></span>
					<span>Versions</span>
				</NavLink>
			}

			@if (CanSeeReportingSection)
			{
				<p class="nav-shell__caption">Reporting</p>
			}
			@if (CanSeeReports)
			{
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="app/reports">
					<span class="nav-shell__icon"><OutlineIcon Name="reports" CssClass="nav-shell__icon-svg" /></span>
					<span>Reports</span>
				</NavLink>
			}
			@if (CanSeeAreas)
			{
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="app/areas">
					<span class="nav-shell__icon"><OutlineIcon Name="areas" CssClass="nav-shell__icon-svg" /></span>
					<span>Areas</span>
				</NavLink>
			}
			@if (CanSeeGoals)
			{
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="app/goals">
					<span class="nav-shell__icon"><OutlineIcon Name="goals" CssClass="nav-shell__icon-svg" /></span>
					<span>Goals</span>
				</NavLink>
			}

			@if (CanSeeAdminSection)
			{
				<p class="nav-shell__caption">Admin</p>
			}
			@if (CanSeeUsers)
			{
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="app/users">
					<span class="nav-shell__icon"><OutlineIcon Name="users" CssClass="nav-shell__icon-svg" /></span>
					<span>Users</span>
				</NavLink>
			}
			@if (CanSeeTenantSettings)
			{
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="app/geography">
					<span class="nav-shell__icon"><OutlineIcon Name="geography" CssClass="nav-shell__icon-svg" /></span>
					<span>Geography</span>
				</NavLink>
			}
			@if (CanSeeTenantSettings)
			{
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="app/tenant-details">
					<span class="nav-shell__icon"><OutlineIcon Name="tenant" CssClass="nav-shell__icon-svg" /></span>
					<span>Tenant Details</span>
				</NavLink>
			}
			@if (CanSeeTenantSettings)
			{
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="app/theme">
					<span class="nav-shell__icon"><OutlineIcon Name="theme" CssClass="nav-shell__icon-svg" /></span>
					<span>Theme</span>
				</NavLink>
			}

			@if (CanSeeMainPlatformSection)
			{
				<p class="nav-shell__caption">Platform</p>
				<NavLink class="nav-shell__link" ActiveClass="nav-shell__link--active" href="admin">
					<span class="nav-shell__icon"><OutlineIcon Name="settings" CssClass="nav-shell__icon-svg" /></span>
					<span>Settings</span>
				</NavLink>
			}
		}
	</nav>

	<div class="nav-shell__footer">
		<span>&copy; 2026 Survey</span>
	</div>
</div>

@code {
	private string _currentUrl = string.Empty;
	private CurrentAccessContext _accessContext = new();
	private bool _hasExternalLogins;

	private bool IsPlatformSection =>
		!string.IsNullOrWhiteSpace(_currentUrl)
		&& _currentUrl.StartsWith("admin", StringComparison.OrdinalIgnoreCase);
	private bool IsPlatformSystemSection =>
		!string.IsNullOrWhiteSpace(_currentUrl)
		&& _currentUrl.StartsWith("admin/system", StringComparison.OrdinalIgnoreCase);

	private bool IsAccountManageSection =>
		!string.IsNullOrWhiteSpace(_currentUrl)
		&& _currentUrl.StartsWith("Account/Manage", StringComparison.OrdinalIgnoreCase);

	protected override async Task OnInitializedAsync()
	{
		_currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
		NavigationManager.LocationChanged += OnLocationChanged;
		await LoadContextAsync();
	}

	private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
	{
		_ = InvokeAsync(async () =>
		{
			_currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
			await LoadContextAsync();
			StateHasChanged();
		});
	}

	private async Task LoadContextAsync()
	{
		_accessContext = await TenantContextAccessor.GetCurrentAsync();
		_hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
	}

	private bool CanSeePlatformHome => _accessContext.IsPlatformUserEnabled && _accessContext.PlatformPermissions.Count > 0;
	private bool CanSeePlatformUsers => HasPlatformPermission(PlatformPermissionKeys.UsersView);
	private bool CanSeePlatformTenants => HasPlatformPermission(PlatformPermissionKeys.TenantsView);
	private bool CanSeePlatformAudit => HasPlatformPermission(PlatformPermissionKeys.AuditView);
	private bool CanSeePlatformJobs => HasPlatformPermission(PlatformPermissionKeys.JobsView);
	private bool CanSeePlatformEmails => HasPlatformPermission(PlatformPermissionKeys.JobsView);
	private bool CanSeePlatformThemes => HasPlatformPermission(PlatformPermissionKeys.SettingsManage);
	private bool CanSeePlatformSystem => HasPlatformPermission(PlatformPermissionKeys.SettingsManage);
	private bool CanSeePlatformGeography => HasPlatformPermission(PlatformPermissionKeys.GeographyView);
	private bool CanSeeBackToTenant => _accessContext.HasTenantAccess;
	private bool CanSeePlatformSection => CanSeePlatformHome || CanSeePlatformUsers || CanSeePlatformTenants || CanSeePlatformAudit || CanSeePlatformJobs || CanSeePlatformEmails || CanSeePlatformThemes || CanSeePlatformSystem || CanSeePlatformGeography;

	private bool CanSeeDashboard => HasTenantPermission(TenantPermissionKeys.DashboardView);
	private bool CanSeeAssignments => HasTenantPermission(TenantPermissionKeys.AssignmentsView);
	private bool CanSeePeople => HasTenantPermission(TenantPermissionKeys.PeopleView);
	private bool CanSeeResponses => HasTenantPermission(TenantPermissionKeys.ResponsesView);
	private bool CanSeeSurveyBuilder => HasTenantPermission(TenantPermissionKeys.SurveysView);
	private bool CanSeeReports => HasTenantPermission(TenantPermissionKeys.ReportsView);
	private bool CanSeeGoals => HasTenantPermission(TenantPermissionKeys.GoalsView);
	private bool CanSeeAreas => HasTenantPermission(TenantPermissionKeys.AreasView);
	private bool CanSeeUsers => HasTenantPermission(TenantPermissionKeys.UsersView);
	private bool CanSeeOwnerSettings => _accessContext.TenantRole == TenantRole.Owner;
	private bool CanSeeTenantSettings => _accessContext.TenantRole is TenantRole.Owner or TenantRole.Admin;

	private bool CanSeeOverviewSection => CanSeeDashboard;
	private bool CanSeeSurveyOperationsSection => CanSeeAssignments || CanSeePeople || CanSeeResponses;
	private bool CanSeeSurveyBuilderSection => CanSeeSurveyBuilder;
	private bool CanSeeReportingSection => CanSeeReports || CanSeeGoals || CanSeeAreas;
	private bool CanSeeMainPlatformSection => CanSeePlatformSystem;
	private bool CanSeeAdminSection => CanSeeUsers || CanSeeTenantSettings;

	private bool HasTenantPermission(string permissionKey)
	{
		return _accessContext.HasTenantAccess && _accessContext.TenantPermissions.Contains(permissionKey);
	}

	private bool HasPlatformPermission(string permissionKey)
	{
		return _accessContext.IsPlatformUserEnabled && _accessContext.PlatformPermissions.Contains(permissionKey);
	}

	public void Dispose()
	{
		NavigationManager.LocationChanged -= OnLocationChanged;
	}
}
