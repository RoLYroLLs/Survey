@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager NavigationManager

<div class="shell @(IsSinglePaneShellRoute ? "shell--setup" : string.Empty) @(IsFocusedShellRoute ? "shell--setup-center" : string.Empty) @(IsAuthFocusRoute ? "shell--auth-focus" : string.Empty)">
	<header class="shell__topbar">
		<TopBar />
	</header>

	@if (!IsSinglePaneShellRoute)
	{
		<aside class="shell__sidebar">
			<NavMenu />
		</aside>
	}

	<div class="shell__content">
		<ToastHost />

		<main class="shell__main @(IsSinglePaneShellRoute ? "shell__main--setup" : string.Empty) @(IsFocusedShellRoute ? "shell__main--setup-center" : string.Empty) @(IsAuthFocusRoute ? "shell__main--auth-focus" : string.Empty) @(IsWideAuthFocusRoute ? "shell__main--auth-wide" : string.Empty)">
			@Body
		</main>
	</div>
</div>

@code {
	private string _currentUrl = string.Empty;
	private string CurrentPathOnly => _currentUrl.Split('?', '#')[0].Trim('/');

	private bool IsAuthFocusRoute =>
		string.Equals(CurrentPathOnly, "Account/Login", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "Account/Register", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "Account/ForgotPassword", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "Account/RegisterConfirmation", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "Account/ConfirmEmail", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "Account/ConfirmEmailChange", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "Account/ForgotPasswordConfirmation", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "Account/ResetPassword", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "Account/ResetPasswordConfirmation", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "Account/ResendEmailConfirmation", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "Account/LoginWith2fa", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "Account/LoginWithRecoveryCode", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "Account/Lockout", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "Account/AccessDenied", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "Account/InvalidPasswordReset", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "Account/InvalidUser", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "Account/ExternalLogin", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "Account/CompleteProfile", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "Account/CreateTenant", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "Account/AcceptPlatformInvite", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "not-found", StringComparison.OrdinalIgnoreCase);

	private bool IsWideAuthFocusRoute =>
		string.Equals(CurrentPathOnly, "Account/CompleteProfile", StringComparison.OrdinalIgnoreCase);

	private bool IsSetupFocusRoute =>
		string.Equals(CurrentPathOnly, "setup", StringComparison.OrdinalIgnoreCase)
		|| string.Equals(CurrentPathOnly, "setup/platform-admin", StringComparison.OrdinalIgnoreCase);

	private bool IsSetupShellRoute =>
		string.Equals(CurrentPathOnly, "setup", StringComparison.OrdinalIgnoreCase)
		|| (!string.IsNullOrWhiteSpace(CurrentPathOnly)
			&& CurrentPathOnly.StartsWith("setup/", StringComparison.OrdinalIgnoreCase));

	private bool IsSinglePaneShellRoute => IsSetupShellRoute || IsAuthFocusRoute;

	private bool IsFocusedShellRoute => IsSetupFocusRoute || IsAuthFocusRoute;

	protected override void OnInitialized()
	{
		_currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
		NavigationManager.LocationChanged += OnLocationChanged;
	}

	private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
	{
		_currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
		_ = InvokeAsync(StateHasChanged);
	}

	public void Dispose()
	{
		NavigationManager.LocationChanged -= OnLocationChanged;
	}
}
