@inherits LayoutComponentBase
@inject global::Survey.Infrastructure.Persistence.InitialSetupStateService InitialSetupStateService

<div class="marketing-shell">
	<header class="marketing-topbar">
		<a class="marketing-topbar__brand" href="/">Survey</a>
		<nav class="marketing-topbar__nav">
			<a href="/">Overview</a>
			<a href="/pricing">Pricing</a>
			<AuthorizeView>
				<Authorized>
					<a class="btn btn-primary marketing-topbar__cta" href="@GetAuthorizedCtaUrl()">@GetAuthorizedCtaLabel()</a>
				</Authorized>
				<NotAuthorized>
					<a href="/Account/Login">Login</a>
					@if (_canCreateAccount)
					{
						<a class="btn btn-primary marketing-topbar__cta" href="/Account/Register">Create Account</a>
					}
				</NotAuthorized>
			</AuthorizeView>
		</nav>
	</header>

	<main class="marketing-main">
		@Body
	</main>
</div>

@code {
	private bool _canCreateAccount;
	private bool _isSetupComplete;

	protected override async Task OnInitializedAsync()
	{
		var setupState = await InitialSetupStateService.GetStatusAsync();
		_isSetupComplete = setupState.IsComplete;
		_canCreateAccount = _isSetupComplete;
	}

	private string GetAuthorizedCtaUrl()
	{
		return _isSetupComplete ? "/app" : "/setup/initial-seeding";
	}

	private string GetAuthorizedCtaLabel()
	{
		return _isSetupComplete ? "Go to Dashboard" : "Continue Setup";
	}
}
