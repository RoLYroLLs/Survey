@inherits LayoutComponentBase

<div class="marketing-shell">
	<header class="marketing-topbar">
		<a class="marketing-topbar__brand" href="/">Survey</a>
		<nav class="marketing-topbar__nav">
			<a href="/">Overview</a>
			<a href="/pricing">Pricing</a>
			<AuthorizeView>
				<Authorized>
					<a class="btn btn-primary marketing-topbar__cta" href="/app">Go to Dashboard</a>
				</Authorized>
				<NotAuthorized>
					<a href="/Account/Login">Login</a>
					<a class="btn btn-primary marketing-topbar__cta" href="/Account/Register">Create Account</a>
				</NotAuthorized>
			</AuthorizeView>
		</nav>
	</header>

	<main class="marketing-main">
		@Body
	</main>
</div>
